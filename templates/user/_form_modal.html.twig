{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <h2 class="modal-title fs-5">{{ title }}</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.firstName) }}</div>
            <div class="col-md-6">{{ form_row(form.lastName) }}</div>
            <div class="col-md-6">{{ form_row(form.email) }}</div>
            <div class="col-md-6" data-secret-field>
                {{ form_label(form.plainPassword) }}
                <div class="input-group">
                    {{ form_widget(form.plainPassword) }}
                    <button type="button" class="btn btn-outline-secondary secret-action" data-secret-toggle aria-label="Afficher le mot de passe pendant 2 secondes" title="Afficher pendant 2 secondes">
                        <i class="bi bi-eye"></i>
                    </button>
                    <button type="button" class="btn btn-outline-secondary secret-action" data-secret-copy aria-label="Copier le mot de passe" title="Copier">
                        <i class="bi bi-copy"></i>
                    </button>
                </div>
                {{ form_errors(form.plainPassword) }}
                <button type="button" class="btn btn-link btn-sm text-secondary text-decoration-none px-0 pt-2" data-secret-generate>
                    <i class="bi bi-stars me-1"></i>Générer un mot de passe sécurisé
                </button>
            </div>

            {% if form.roles is defined %}
                <div class="col-lg-6">
                    <div class="choice-tags-field h-100" data-choice-tags data-choice-tags-single="true">
                        {{ form_label(form.roles, null, {'label_attr': {'class': 'form-label fw-semibold mb-2'}}) }}
                        <button class="choice-tags-control" type="button" data-choice-tags-toggle aria-expanded="false">
                            <span class="choice-tags-selected" data-choice-tags-selected></span>
                            <span class="choice-tags-placeholder" data-choice-tags-placeholder>Cliquer pour choisir un rôle</span>
                            <i class="bi bi-chevron-down ms-auto"></i>
                        </button>
                        <div class="choice-tags-menu d-none" data-choice-tags-menu>
                            {% for choice in form.roles %}
                                <label class="choice-tags-option" data-choice-tags-option>
                                    {{ form_widget(choice, {attr: {'class': 'choice-tags-native', 'data-choice-tags-input': 'true'}}) }}
                                    <span>{{ choice.vars.label }}</span>
                                </label>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.roles) }}
                        {% do form.roles.setRendered() %}
                    </div>
                </div>
            {% endif %}

            <div class="{{ form.roles is defined ? 'col-lg-6' : 'col-12' }}">
                <div class="choice-tags-field h-100" data-choice-tags>
                    {{ form_label(form.modules, 'Droits / modules accessibles', {'label_attr': {'class': 'form-label fw-semibold mb-2'}}) }}
                    <button class="choice-tags-control" type="button" data-choice-tags-toggle aria-expanded="false">
                        <span class="choice-tags-selected" data-choice-tags-selected></span>
                        <span class="choice-tags-placeholder" data-choice-tags-placeholder>Cliquer pour ajouter des droits</span>
                        <i class="bi bi-chevron-down ms-auto"></i>
                    </button>
                    <div class="choice-tags-menu d-none" data-choice-tags-menu>
                        {% for choice in form.modules %}
                            <label class="choice-tags-option" data-choice-tags-option>
                                {{ form_widget(choice, {attr: {'class': 'choice-tags-native', 'data-choice-tags-input': 'true'}}) }}
                                <span>{{ choice.vars.label }}</span>
                            </label>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.modules) }}
                    {% do form.modules.setRendered() %}
                </div>
            </div>

            <div class="col-12">{{ form_row(form.isActive) }}</div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">{{ submit_label }}</button>
    </div>
{{ form_end(form) }}
