{% extends 'base.html.twig' %}

{% block title %}Charges cout de revient{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Configuration des charges</h1>
        <p class="text-secondary mb-0">{{ charges|length }} charge{{ charges|length > 1 ? 's' : '' }} configuree{{ charges|length > 1 ? 's' : '' }}.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="{{ path('app_cout_revient_index') }}">
            <i class="bi bi-arrow-left me-2"></i>Cout de revient
        </a>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createCoutChargeModal">
            <i class="bi bi-plus-circle me-2"></i>Nouvelle charge
        </button>
    </div>
</div>

<form class="card border-0 shadow-sm mb-4" method="get">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md">
                <label class="form-label" for="cout-charge-search">Recherche</label>
                <input id="cout-charge-search" class="form-control" type="search" name="q" value="{{ query }}" placeholder="Nom, categorie, note">
            </div>
            <div class="col-12 col-md-auto">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search me-2"></i>Filtrer
                </button>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Charge</th>
                    <th>Categorie</th>
                    <th>Calcul</th>
                    <th class="text-end">Cout</th>
                    <th>Statut</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for charge in charges %}
                <tr class="{{ charge.active ? '' : 'opacity-75' }}">
                    <td>
                        <div class="fw-semibold">{{ charge.name }}</div>
                        <div class="small text-secondary">{{ charge.description ?: 'Aucune note.' }}</div>
                    </td>
                    <td><span class="badge text-bg-light">{{ charge.categoryLabel }}</span></td>
                    <td>{{ charge.calculationUnitLabel }}</td>
                    <td class="text-end fw-semibold">{{ charge.unitCost|number_format(4, ',', ' ')|replace({',0000': '', ',000': ''}) }} dh / {{ charge.calculationUnitShortLabel }}</td>
                    <td>
                        <span class="badge {{ charge.active ? 'text-bg-success' : 'text-bg-secondary' }}">
                            {{ charge.active ? 'Active' : 'Inactive' }}
                        </span>
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary" type="button" title="Modifier" aria-label="Modifier" data-remote-modal="{{ path('app_cout_revient_charge_form', {id: charge.id}) }}">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button
                                class="btn btn-outline-secondary"
                                type="button"
                                data-confirm-url="{{ path('app_cout_revient_charge_toggle', {id: charge.id}) }}"
                                data-token="{{ csrf_token('toggle_cout_charge_' ~ charge.id) }}"
                                data-confirm-message="{{ charge.active ? 'Desactiver cette charge ? Elle ne sera plus proposee sur les nouveaux lots.' : 'Activer cette charge ?' }}"
                            >
                                <i class="bi {{ charge.active ? 'bi-slash-circle' : 'bi-check-circle' }}"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td class="text-center text-secondary py-5" colspan="6">Aucune charge configuree.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createCoutChargeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
        <div class="modal-content">
            {% include 'cout_revient/charge_config/_form_modal.html.twig' with {
                form: create_form,
                title: 'Creer une charge',
                submit_label: 'Creer'
            } %}
        </div>
    </div>
</div>
{% endblock %}
