{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header border-0 pb-0">
        <div>
            <h2 class="modal-title h4">{{ title }}</h2>
            <p class="text-secondary mb-0">Parametrez les charges reutilisables dans les lots.</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="row g-3">
            <div class="col-12 col-lg-6">{{ form_row(form.name) }}</div>
            <div class="col-12 col-lg-3">{{ form_row(form.category) }}</div>
            <div class="col-12 col-lg-3">{{ form_row(form.calculationUnit) }}</div>
            <div class="col-12 col-lg-4">{{ form_row(form.unitCost) }}</div>
            <div class="col-12 col-lg-4">{{ form_row(form.sortOrder) }}</div>
            <div class="col-12 col-lg-4 d-flex align-items-end">{{ form_row(form.isActive) }}</div>
            <div class="col-12">{{ form_row(form.description) }}</div>
        </div>
        {{ form_rest(form) }}
    </div>
    <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2 me-2"></i>{{ submit_label }}
        </button>
    </div>
{{ form_end(form) }}
