{% set size = size|default('btn-sm') %}
{% if is_granted('COUT_REVIENT_EDIT', item) %}
    <a class="btn {{ size }} btn-outline-primary" href="{{ path('app_cout_revient_edit', {id: item.id}) }}">
        <i class="bi bi-pencil me-1"></i>Modifier
    </a>
{% endif %}
{% if is_granted('COUT_REVIENT_DUPLICATE', item) %}
    <button class="btn {{ size }} btn-outline-secondary" data-confirm-url="{{ path('app_cout_revient_duplicate', {id: item.id}) }}" data-token="{{ csrf_token('duplicate_cout_revient_' ~ item.id) }}" data-confirm-message="Dupliquer ce lot ?">
        <i class="bi bi-copy me-1"></i>Dupliquer
    </button>
{% endif %}
{% if is_granted('COUT_REVIENT_VALIDATE', item) %}
    <button class="btn {{ size }} btn-outline-success" data-confirm-url="{{ path('app_cout_revient_validate', {id: item.id}) }}" data-token="{{ csrf_token('validate_cout_revient_' ~ item.id) }}" data-confirm-message="Valider ce cout de revient ?">
        <i class="bi bi-check2-circle me-1"></i>Valider
    </button>
{% endif %}
{% if is_granted('COUT_REVIENT_EXPORT', item) %}
    <a class="btn {{ size }} btn-outline-success" href="{{ path('app_cout_revient_export_excel_item', {id: item.id}) }}">
        <i class="bi bi-file-earmark-excel me-1"></i>Excel
    </a>
{% endif %}
<button class="btn {{ size }} btn-outline-secondary" type="button" onclick="window.print()">
    <i class="bi bi-printer me-1"></i>Imprimer
</button>
{% if is_granted('COUT_REVIENT_DELETE', item) %}
    <button class="btn {{ size }} btn-outline-danger" data-confirm-url="{{ path('app_cout_revient_delete', {id: item.id}) }}" data-confirm-method="DELETE" data-token="{{ csrf_token('delete_cout_revient_' ~ item.id) }}" data-confirm-message="Supprimer ce lot ?">
        <i class="bi bi-trash me-1"></i>Supprimer
    </button>
{% endif %}
