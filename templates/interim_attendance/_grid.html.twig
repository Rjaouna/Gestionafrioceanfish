{% if items|length > 0 %}
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Interimaire</th>
                    <th>Type</th>
                    <th>Creneaux</th>
                    <th class="text-end">Heures</th>
                    <th class="text-end">Taux</th>
                    <th class="text-end">Montant</th>
                </tr>
                </thead>
                <tbody>
                {% for item in items %}
                    <tr>
                        <td class="text-nowrap">{{ item.attendanceDate ? item.attendanceDate|date('d/m/Y') : '-' }}</td>
                        <td>
                            <div class="fw-semibold">{{ item.worker ? item.worker.fullName : '-' }}</div>
                            <div class="small text-secondary">{{ item.worker ? item.worker.registrationNumber : '' }}</div>
                        </td>
                        <td><span class="badge {{ item.mode == 'hourly' ? 'text-bg-primary' : 'text-bg-warning' }}">{{ item.modeLabel }}</span></td>
                        <td>
                            <div>{{ item.presenceLabel }}</div>
                            <div class="small text-secondary">{{ item.timeRangeLabel }}</div>
                        </td>
                        <td class="text-end text-nowrap">{{ item.totalHoursValue|number_format(2, ',', ' ') }} h</td>
                        <td class="text-end text-nowrap">{{ item.hourlyRateValue|number_format(2, ',', ' ') }}</td>
                        <td class="text-end fw-semibold text-nowrap">{{ item.totalAmountValue|number_format(2, ',', ' ') }} MAD</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary-subtle text-secondary fs-2 empty-state-mark">
                <i class="bi bi-calendar-check"></i>
            </span>
            <h2 class="h5 mt-3">Aucun pointage</h2>
            <p class="text-secondary mb-0">Ajoutez un pointage depuis la fiche d'un interimaire.</p>
        </div>
    </div>
{% endif %}

{% if pagination.pages > 1 %}
    <div class="d-flex justify-content-center gap-2 mt-4">
        <a class="btn btn-outline-secondary btn-sm {{ pagination.page <= 1 ? 'disabled' : '' }}" href="#" data-ajax-region-page="interimAttendanceGrid" data-page="{{ pagination.page - 1 }}">
            <i class="bi bi-chevron-left"></i>
        </a>
        <span class="btn btn-light btn-sm disabled">Page {{ pagination.page }} / {{ pagination.pages }}</span>
        <a class="btn btn-outline-secondary btn-sm {{ pagination.page >= pagination.pages ? 'disabled' : '' }}" href="#" data-ajax-region-page="interimAttendanceGrid" data-page="{{ pagination.page + 1 }}">
            <i class="bi bi-chevron-right"></i>
        </a>
    </div>
{% endif %}
