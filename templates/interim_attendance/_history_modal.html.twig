<div class="modal-header">
    <div>
        <h2 class="modal-title fs-5">Historique pointage</h2>
        <p class="text-secondary small mb-0">{{ worker.fullName }} - {{ month|date('m/Y') }}</p>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
</div>
<div class="modal-body">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary" type="button" data-remote-modal="{{ path('app_interim_attendance_worker_history', {id: worker.id, month: previous_month}) }}">
                <i class="bi bi-chevron-left"></i>
            </button>
            <button class="btn btn-outline-secondary" type="button" data-remote-modal="{{ path('app_interim_attendance_worker_history', {id: worker.id, month: next_month}) }}">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="badge text-bg-primary">{{ totals.hours|number_format(2, ',', ' ') }} h</span>
            {% if totals.taskKg|default(0) > 0 %}
                <span class="badge text-bg-warning">{{ totals.taskKg|number_format(2, ',', ' ') }} kg tache</span>
            {% endif %}
            <span class="badge text-bg-success">{{ totals.amount|number_format(2, ',', ' ') }} MAD</span>
            <span class="badge text-bg-light border">{{ totals.count }} ligne{{ totals.count > 1 ? 's' : '' }}</span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Presence</th>
                <th>Detail</th>
                <th class="text-end">Heures / kg</th>
                <th class="text-end">Tarif</th>
                <th class="text-end">Montant</th>
            </tr>
            </thead>
            <tbody>
            {% for item in items %}
                <tr>
                    <td class="text-nowrap">{{ item.attendanceDate|date('d/m/Y') }}</td>
                    <td>{{ item.presenceLabel }}</td>
                    <td class="small text-secondary">{{ item.timeRangeLabel }}</td>
                    <td class="text-end text-nowrap">
                        {% if item.mode == 'task' %}
                            {{ item.taskWeightKgValue|number_format(2, ',', ' ') }} kg
                        {% else %}
                            {{ item.totalHoursValue|number_format(2, ',', ' ') }} h
                        {% endif %}
                    </td>
                    <td class="text-end text-nowrap">
                        {% if item.mode == 'task' %}
                            {{ item.taskUnitPriceValue|number_format(2, ',', ' ') }} / {{ item.taskUnit ?: '-' }}
                        {% else %}
                            {{ item.hourlyRateValue|number_format(2, ',', ' ') }} / h
                        {% endif %}
                    </td>
                    <td class="text-end fw-semibold text-nowrap">{{ item.totalAmountValue|number_format(2, ',', ' ') }} MAD</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center text-secondary py-4">Aucun pointage sur ce mois.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
    <button class="btn btn-primary" type="button" data-remote-modal="{{ path('app_interim_attendance_choice', {id: worker.id}) }}">
        <i class="bi bi-calendar-plus me-1"></i>Ajouter
    </button>
</div>
