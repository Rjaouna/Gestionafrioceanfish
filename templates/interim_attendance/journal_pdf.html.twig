<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Journal pointage - {{ periodLabel }}</title>
    <style>
        @page { size: A4 landscape; margin: 11mm; }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            color: #0f172a;
            background: #eef4f8;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 11px;
        }
        .print-actions {
            position: fixed;
            top: 14px;
            right: 14px;
            z-index: 10;
            display: flex;
            gap: 8px;
        }
        .print-actions button {
            border: 1px solid #142b68;
            border-radius: 6px;
            background: #142b68;
            color: #fff;
            padding: 8px 12px;
            font-weight: 700;
            cursor: pointer;
        }
        .page {
            width: 297mm;
            min-height: 210mm;
            margin: 0 auto;
            padding: 11mm;
            background: #fff;
        }
        .topbar {
            display: grid;
            grid-template-columns: 185px 1fr;
            gap: 18px;
            align-items: center;
            padding-bottom: 12px;
            border-bottom: 3px solid #142b68;
        }
        .logo {
            width: 185px;
            height: auto;
            display: block;
        }
        .company {
            text-align: right;
            color: #334155;
            line-height: 1.45;
        }
        .company strong {
            display: block;
            color: #142b68;
            font-size: 17px;
            letter-spacing: .08em;
        }
        .title-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 18px;
            align-items: start;
            margin: 18px 0 14px;
        }
        h1 {
            margin: 0 0 5px;
            color: #142b68;
            font-size: 24px;
            line-height: 1.15;
        }
        .subtitle {
            color: #64748b;
            font-size: 12px;
        }
        .doc-meta {
            min-width: 255px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            overflow: hidden;
        }
        .doc-meta div {
            display: grid;
            grid-template-columns: 95px 1fr;
            border-bottom: 1px solid #e2e8f0;
        }
        .doc-meta div:last-child { border-bottom: 0; }
        .doc-meta span,
        .doc-meta strong { padding: 7px 9px; }
        .doc-meta span {
            color: #64748b;
            background: #f8fafc;
            font-weight: 700;
        }
        .summary {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 9px;
            margin-bottom: 14px;
        }
        .summary-card {
            border: 1px solid #dbe4ee;
            border-radius: 8px;
            padding: 9px 11px;
            background: #f8fafc;
        }
        .summary-card span {
            display: block;
            color: #64748b;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .04em;
        }
        .summary-card strong {
            display: block;
            margin-top: 4px;
            color: #0f172a;
            font-size: 18px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            page-break-inside: auto;
        }
        tr { page-break-inside: avoid; page-break-after: auto; }
        th {
            padding: 8px 7px;
            border: 1px solid #94a3b8;
            background: #eaf1f8;
            color: #142b68;
            text-align: left;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .04em;
        }
        td {
            padding: 8px 7px;
            border: 1px solid #cbd5e1;
            vertical-align: top;
        }
        tfoot th {
            background: #142b68;
            border-color: #142b68;
            color: #fff;
        }
        .text-end { text-align: right; }
        .text-nowrap { white-space: nowrap; }
        .performance-badge {
            display: inline-block;
            min-width: 82px;
            padding: 4px 8px;
            border: 1px solid;
            border-radius: 12px;
            text-align: center;
            font-weight: 700;
        }
        .performance-high {
            color: #166534;
            background: #dcfce7;
            border-color: #86efac;
        }
        .performance-medium {
            color: #92400e;
            background: #fef3c7;
            border-color: #fcd34d;
        }
        .performance-low {
            color: #991b1b;
            background: #fee2e2;
            border-color: #fca5a5;
        }
        .performance-none {
            color: #475569;
            background: #f1f5f9;
            border-color: #cbd5e1;
        }
        .performance-legend {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 6px;
            margin: 0 0 8px;
            color: #64748b;
            font-size: 9px;
        }
        .performance-legend .performance-badge {
            min-width: auto;
            padding: 3px 7px;
        }
        .empty {
            margin-top: 20px;
            padding: 28px;
            border: 1px dashed #94a3b8;
            border-radius: 10px;
            color: #475569;
            text-align: center;
        }
        .footer {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 22px;
            margin-top: 28px;
        }
        .signature {
            min-height: 58px;
            padding-top: 8px;
            border-top: 1px solid #0f172a;
            color: #334155;
            font-weight: 700;
        }
        @media print {
            * {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            body { background: #fff; }
            .print-actions { display: none; }
            .page { width: auto; min-height: auto; margin: 0; padding: 0; }
        }
    </style>
</head>
<body>
    <div class="print-actions">
        <button type="button" onclick="window.print()">Imprimer / PDF</button>
    </div>

    <main class="page">
        <header class="topbar">
            <img class="logo" src="{{ asset('images/logo-afriocean-fish.svg') }}" alt="AFRIOCEAN FISH">
            <div class="company">
                <strong>AFRIOCEAN FISH</strong>
                Gestion interne usine<br>
                Journal pointage personnel<br>
                Document genere depuis l'application
            </div>
        </header>

        <section class="title-row">
            <div>
                <h1>Journal de journee</h1>
                <div class="subtitle">Periode : {{ periodLabel }}</div>
            </div>
            <div class="doc-meta">
                <div><span>Date</span><strong>{{ generated_at|date('d/m/Y H:i') }}</strong></div>
                <div><span>Prepare par</span><strong>{{ generated_by }}</strong></div>
                <div><span>Lignes</span><strong>{{ totals.lines }}</strong></div>
            </div>
        </section>

        <section class="summary">
            <div class="summary-card">
                <span>Interimaires</span>
                <strong>{{ totals.workers }}</strong>
            </div>
            <div class="summary-card">
                <span>Nettoyage anchois</span>
                <strong>{{ totals.cleaningKg|number_format(2, ',', ' ') }} kg</strong>
            </div>
            <div class="summary-card">
                <span>Mise en caisse</span>
                <strong>{{ totals.boxingKg|number_format(2, ',', ' ') }} kg</strong>
            </div>
        </section>

        {% if rows is empty %}
            <div class="empty">Aucun pointage saisi sur cette periode.</div>
        {% else %}
            <div class="performance-legend">
                <span>Niveau sur la periode :</span>
                <span class="performance-badge performance-high">Meilleur</span>
                <span class="performance-badge performance-medium">Moyen</span>
                <span class="performance-badge performance-low">Plus faible</span>
            </div>
            <table>
                <thead>
                <tr>
                    <th style="width: 34%;">Nom</th>
                    <th style="width: 16%;">Matricule</th>
                    <th style="width: 17%;" class="text-end">Nettoyage</th>
                    <th style="width: 17%;" class="text-end">Mise en caisse</th>
                    <th style="width: 16%;" class="text-end">Total gagne</th>
                </tr>
                </thead>
                <tbody>
                {% for row in rows %}
                    <tr>
                        <td><strong>{{ row.fullName ?: '-' }}</strong></td>
                        <td>{{ row.registrationNumber ?: '-' }}</td>
                        <td class="text-end text-nowrap">
                            <span class="performance-badge performance-{{ row.cleaningPerformance }}">
                                {{ row.cleaningKg|number_format(2, ',', ' ') }} kg
                            </span>
                        </td>
                        <td class="text-end text-nowrap">
                            <span class="performance-badge performance-{{ row.boxingPerformance }}">
                                {{ row.boxingKg|number_format(2, ',', ' ') }} kg
                            </span>
                        </td>
                        <td class="text-end text-nowrap">
                            <span class="performance-badge performance-{{ row.earnedPerformance }}">
                                {{ row.earnedAmount|number_format(2, ',', ' ') }} MAD
                            </span>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
                <tfoot>
                <tr>
                    <th colspan="2">Totaux</th>
                    <th class="text-end">{{ totals.cleaningKg|number_format(2, ',', ' ') }} kg</th>
                    <th class="text-end">{{ totals.boxingKg|number_format(2, ',', ' ') }} kg</th>
                    <th class="text-end">{{ totals.earnedAmount|number_format(2, ',', ' ') }} MAD</th>
                </tr>
                </tfoot>
            </table>
        {% endif %}

        <section class="footer">
            <div class="signature">Responsable pointage</div>
            <div class="signature">Controle production</div>
            <div class="signature">Validation direction</div>
        </section>
    </main>

    <script>
        window.addEventListener('load', function () {
            if (new URLSearchParams(window.location.search).get('auto') === '1') {
                window.print();
            }
        });
    </script>
</body>
</html>
