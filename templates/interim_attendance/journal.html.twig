{% extends 'base.html.twig' %}

{% block title %}Journal pointage{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Journal de journee</h1>
        <p class="text-secondary mb-0">Nettoyage anchois et mise en caisse par interimaire.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="{{ path('app_interim_attendance_index') }}">
            <i class="bi bi-calendar-check me-2"></i>Pointage
        </a>
        <a class="btn btn-primary" href="{{ path('app_interim_attendance_journal_pdf', filters|merge({auto: 1})) }}" target="_blank" rel="noopener">
            <i class="bi bi-file-earmark-pdf me-2"></i>Exporter PDF
        </a>
    </div>
</div>

<form class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label" for="journalDateFrom">Du</label>
                <input id="journalDateFrom" class="form-control" type="date" name="dateFrom" value="{{ filters.dateFrom }}">
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="journalDateTo">Au</label>
                <input id="journalDateTo" class="form-control" type="date" name="dateTo" value="{{ filters.dateTo }}">
            </div>
            <div class="col-12 col-md-4 d-grid">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-funnel me-2"></i>Filtrer
                </button>
            </div>
        </div>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Periode</div>
                <div class="h5 mb-0">{{ periodLabel }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Interimaires</div>
                <div class="h5 mb-0">{{ totals.workers }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Nettoyage</div>
                <div class="h5 mb-0">{{ totals.cleaningKg|number_format(2, ',', ' ') }} kg</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Mise en caisse</div>
                <div class="h5 mb-0">{{ totals.boxingKg|number_format(2, ',', ' ') }} kg</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    {% if rows|length > 0 %}
        <div class="card-header bg-white border-0 d-flex flex-wrap align-items-center justify-content-end gap-2 pt-3 px-3">
            <span class="small text-secondary me-1">Niveau sur la periode :</span>
            <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">Meilleur</span>
            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle">Moyen</span>
            <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle">Plus faible</span>
        </div>
    {% endif %}
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th>Nom</th>
                <th>Matricule</th>
                <th class="text-end">Nettoyage</th>
                <th class="text-end">Mise en caisse</th>
                <th class="text-end">Total gagne</th>
            </tr>
            </thead>
            <tbody>
            {% for row in rows %}
                <tr>
                    <td class="fw-semibold">{{ row.fullName ?: '-' }}</td>
                    <td>{{ row.registrationNumber ?: '-' }}</td>
                    <td class="text-end text-nowrap">
                        {% set cleaningClass = row.cleaningPerformance == 'high'
                            ? 'bg-success-subtle text-success-emphasis border-success-subtle'
                            : (row.cleaningPerformance == 'medium'
                                ? 'bg-warning-subtle text-warning-emphasis border-warning-subtle'
                                : (row.cleaningPerformance == 'low'
                                    ? 'bg-danger-subtle text-danger-emphasis border-danger-subtle'
                                    : 'bg-light text-secondary border-light-subtle')) %}
                        <span class="badge border {{ cleaningClass }} px-3 py-2">
                            {{ row.cleaningKg|number_format(2, ',', ' ') }} kg
                        </span>
                    </td>
                    <td class="text-end text-nowrap">
                        {% set boxingClass = row.boxingPerformance == 'high'
                            ? 'bg-success-subtle text-success-emphasis border-success-subtle'
                            : (row.boxingPerformance == 'medium'
                                ? 'bg-warning-subtle text-warning-emphasis border-warning-subtle'
                                : (row.boxingPerformance == 'low'
                                    ? 'bg-danger-subtle text-danger-emphasis border-danger-subtle'
                                    : 'bg-light text-secondary border-light-subtle')) %}
                        <span class="badge border {{ boxingClass }} px-3 py-2">
                            {{ row.boxingKg|number_format(2, ',', ' ') }} kg
                        </span>
                    </td>
                    <td class="text-end text-nowrap">
                        {% set earnedClass = row.earnedPerformance == 'high'
                            ? 'bg-success-subtle text-success-emphasis border-success-subtle'
                            : (row.earnedPerformance == 'medium'
                                ? 'bg-warning-subtle text-warning-emphasis border-warning-subtle'
                                : (row.earnedPerformance == 'low'
                                    ? 'bg-danger-subtle text-danger-emphasis border-danger-subtle'
                                    : 'bg-light text-secondary border-light-subtle')) %}
                        <span class="badge border {{ earnedClass }} px-3 py-2">
                            {{ row.earnedAmount|number_format(2, ',', ' ') }} MAD
                        </span>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-secondary py-5">Aucun pointage sur cette periode.</td>
                </tr>
            {% endfor %}
            </tbody>
            {% if rows|length > 0 %}
                <tfoot class="table-light">
                <tr>
                    <th colspan="2">Totaux</th>
                    <th class="text-end">{{ totals.cleaningKg|number_format(2, ',', ' ') }} kg</th>
                    <th class="text-end">{{ totals.boxingKg|number_format(2, ',', ' ') }} kg</th>
                    <th class="text-end text-success-emphasis">{{ totals.earnedAmount|number_format(2, ',', ' ') }} MAD</th>
                </tr>
                </tfoot>
            {% endif %}
        </table>
    </div>
</div>
{% endblock %}
