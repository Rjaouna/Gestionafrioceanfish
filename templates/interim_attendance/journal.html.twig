{% extends 'base.html.twig' %}

{% block title %}Journal pointage{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Journal de journee</h1>
        <p class="text-secondary mb-0">Nettoyage anchois et mise en caisse par interimaire.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="{{ path('app_interim_attendance_index') }}">
            <i class="bi bi-calendar-check me-2"></i>Pointage
        </a>
        <a class="btn btn-primary" href="{{ path('app_interim_attendance_journal_pdf', filters|merge({auto: 1})) }}" target="_blank" rel="noopener">
            <i class="bi bi-file-earmark-pdf me-2"></i>Exporter PDF
        </a>
    </div>
</div>

<form class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label" for="journalDateFrom">Du</label>
                <input id="journalDateFrom" class="form-control" type="date" name="dateFrom" value="{{ filters.dateFrom }}">
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="journalDateTo">Au</label>
                <input id="journalDateTo" class="form-control" type="date" name="dateTo" value="{{ filters.dateTo }}">
            </div>
            <div class="col-12 col-md-4 d-grid">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-funnel me-2"></i>Filtrer
                </button>
            </div>
        </div>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Periode</div>
                <div class="h5 mb-0">{{ periodLabel }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Interimaires</div>
                <div class="h5 mb-0">{{ totals.workers }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Nettoyage</div>
                <div class="h5 mb-0">{{ totals.cleaningKg|number_format(2, ',', ' ') }} kg</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Mise en caisse</div>
                <div class="h5 mb-0">{{ totals.boxingKg|number_format(2, ',', ' ') }} kg</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th>Nom</th>
                <th>Matricule</th>
                <th class="text-end">Nettoyage</th>
                <th class="text-end">Mise en caisse</th>
            </tr>
            </thead>
            <tbody>
            {% for row in rows %}
                <tr>
                    <td class="fw-semibold">{{ row.fullName ?: '-' }}</td>
                    <td>{{ row.registrationNumber ?: '-' }}</td>
                    <td class="text-end text-nowrap">{{ row.cleaningKg|number_format(2, ',', ' ') }} kg</td>
                    <td class="text-end text-nowrap">{{ row.boxingKg|number_format(2, ',', ' ') }} kg</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-secondary py-5">Aucun pointage sur cette periode.</td>
                </tr>
            {% endfor %}
            </tbody>
            {% if rows|length > 0 %}
                <tfoot class="table-light">
                <tr>
                    <th colspan="2">Totaux</th>
                    <th class="text-end">{{ totals.cleaningKg|number_format(2, ',', ' ') }} kg</th>
                    <th class="text-end">{{ totals.boxingKg|number_format(2, ',', ' ') }} kg</th>
                </tr>
                </tfoot>
            {% endif %}
        </table>
    </div>
</div>
{% endblock %}
