{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
{% set first_name = app.user.firstName ?? app.user.displayName %}
{% set section_labels = {
    agenda: 'Agenda - RDV',
    maintenance: 'Maintenance',
    expenses: 'Dépenses',
    documents: 'Documents',
    contacts: 'Contacts',
    passwords: 'Coffre d’accès',
    users: 'Utilisateurs',
    modules: 'Configuration'
} %}

<div class="dashboard-shell dashboard-home">
    <section class="dashboard-command-center mb-4">
        <div class="dashboard-command-copy">
            <span class="dashboard-kicker">Pilotage opérationnel</span>
            <h1 class="h3 fw-bold mb-2">Bonjour {{ first_name }}</h1>
            <p class="text-secondary mb-0">Vue consolidée de l’activité, des risques et des prochaines actions.</p>
        </div>

        <div class="dashboard-command-metrics">
            {% for metric in dashboard.hero_metrics %}
                <div class="dashboard-command-metric">
                    <span class="text-{{ metric.tone }}"><i class="bi {{ metric.icon }}"></i></span>
                    <strong>{{ metric.value }}</strong>
                    <small>{{ metric.label }}</small>
                </div>
            {% endfor %}
        </div>
    </section>

    <form class="dashboard-filter-bar mb-4" method="get" action="{{ path('app_dashboard') }}">
        <div class="dashboard-filter-title">
            <span class="dashboard-kicker">Période analysée</span>
            <strong>{{ dashboard.period.label }}</strong>
        </div>

        <div class="dashboard-filter-fields">
            <label class="form-label" for="dashboardPeriod">Période</label>
            <select id="dashboardPeriod" name="period" class="form-select">
                <option value="today" {{ dashboard.period.key == 'today' ? 'selected' : '' }}>Aujourd’hui</option>
                <option value="week" {{ dashboard.period.key == 'week' ? 'selected' : '' }}>Cette semaine</option>
                <option value="month" {{ dashboard.period.key == 'month' ? 'selected' : '' }}>Ce mois-ci</option>
                <option value="year" {{ dashboard.period.key == 'year' ? 'selected' : '' }}>Cette année</option>
                <option value="custom" {{ dashboard.period.key == 'custom' ? 'selected' : '' }}>Personnalisée</option>
            </select>
        </div>

        <div class="dashboard-filter-fields">
            <label class="form-label" for="dashboardFrom">Du</label>
            <input id="dashboardFrom" class="form-control" type="date" name="from" value="{{ dashboard.period.from_value }}">
        </div>

        <div class="dashboard-filter-fields">
            <label class="form-label" for="dashboardTo">Au</label>
            <input id="dashboardTo" class="form-control" type="date" name="to" value="{{ dashboard.period.to_value }}">
        </div>

        <div class="dashboard-filter-actions">
            <button class="btn btn-primary" type="submit">
                <i class="bi bi-funnel me-1"></i>Filtrer
            </button>
            <a class="btn btn-outline-secondary" href="{{ path('app_dashboard') }}">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Réinitialiser
            </a>
        </div>
    </form>

    {% if dashboard.executive_kpis is empty %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Aucun module ne vous a encore été attribué.
        </div>
    {% else %}
        <section class="dashboard-kpi-grid mb-4" aria-label="Indicateurs principaux">
            {% for kpi in dashboard.executive_kpis %}
                <a class="dashboard-kpi-card dashboard-kpi-card-{{ kpi.tone|default('primary') }} card border-0 shadow-sm" href="{{ path(kpi.route) }}">
                    <div class="dashboard-kpi-head">
                        <span class="dashboard-kpi-title">{{ kpi.label }}</span>
                        <span class="dashboard-kpi-icon"><i class="bi {{ kpi.icon }}"></i></span>
                    </div>
                    <div class="dashboard-kpi-value">{{ kpi.value_display|default(kpi.value) }}</div>
                    <div class="dashboard-kpi-hint">{{ kpi.hint }}</div>
                </a>
            {% endfor %}
        </section>
    {% endif %}

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-7">
            <section class="dashboard-module-card card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <span class="dashboard-kicker">Charge active</span>
                            <h2 class="h5 mb-1">Activité à piloter</h2>
                        </div>
                        <span class="badge bg-primary-subtle text-primary-emphasis">{{ dashboard.alert_count }} alerte{{ dashboard.alert_count > 1 ? 's' : '' }}</span>
                    </div>

                    {% include 'components/_dashboard_chart.html.twig' with {
                        title: 'Volumes',
                        subtitle: 'Agenda, maintenance, validations',
                        chart: dashboard.operational_chart,
                        chart_type: 'bars',
                        tone: 'primary',
                        progress: dashboard.alert_count,
                        progress_label: 'Alertes'
                    } only %}
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-5">
            <section class="dashboard-module-card card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <span class="dashboard-kicker">Points de contrôle</span>
                            <h2 class="h5 mb-1">À surveiller</h2>
                        </div>
                    </div>

                    <div class="dashboard-health-grid">
                        {% for card in dashboard.health_cards %}
                            <div class="dashboard-health-card dashboard-health-card-{{ card.tone }}">
                                <span><i class="bi {{ card.icon }}"></i></span>
                                <strong>{{ card.value }}</strong>
                                <div>
                                    <b>{{ card.label }}</b>
                                    <small>{{ card.caption }}</small>
                                </div>
                            </div>
                        {% else %}
                            <div class="dashboard-empty">
                                <i class="bi bi-check2-circle"></i>
                                <span>Aucun point bloquant.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-4">
            <section class="dashboard-panel card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">Prochaines échéances</h2>
                    <p class="text-secondary small mb-0">RDV et interventions à traiter.</p>
                </div>
                <div class="card-body">
                    <div class="dashboard-timeline">
                        {% for item in dashboard.schedule %}
                            <a class="dashboard-timeline-item dashboard-timeline-link" href="{{ path(item.route) }}">
                                <span class="dashboard-alert-icon bg-{{ item.tone }}-subtle text-{{ item.tone }}-emphasis"><i class="bi {{ item.icon }}"></i></span>
                                <div class="min-w-0">
                                    <div class="fw-semibold text-truncate">{{ item.title }}</div>
                                    <div class="small text-secondary">{{ item.meta }}</div>
                                </div>
                                <span class="badge text-bg-light text-secondary">{{ item.kind }}</span>
                            </a>
                        {% else %}
                            <div class="dashboard-empty">
                                <i class="bi bi-calendar-check"></i>
                                <span>Aucune échéance ouverte.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-4">
            <section class="dashboard-panel card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">Alertes prioritaires</h2>
                    <p class="text-secondary small mb-0">Éléments qui demandent une action.</p>
                </div>
                <div class="card-body">
                    <div class="dashboard-alert-list">
                        {% for alert in dashboard.alerts %}
                            <div class="dashboard-alert-item">
                                <span class="dashboard-alert-icon bg-{{ alert.tone }}-subtle text-{{ alert.tone }}-emphasis"><i class="bi {{ alert.icon }}"></i></span>
                                <div class="min-w-0">
                                    <div class="fw-semibold text-truncate">{{ alert.title }}</div>
                                    <div class="small text-secondary">{{ alert.text }}</div>
                                </div>
                            </div>
                        {% else %}
                            <div class="dashboard-empty">
                                <i class="bi bi-check2-circle"></i>
                                <span>Aucune alerte prioritaire.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-4">
            <section class="dashboard-panel card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">Accès rapides</h2>
                    <p class="text-secondary small mb-0">Espaces les plus utiles au quotidien.</p>
                </div>
                <div class="card-body">
                    <div class="dashboard-action-list">
                        {% for action in dashboard.quick_actions %}
                            <a class="dashboard-action-card" href="{{ path(action.route) }}">
                                <span class="bg-{{ action.tone }}-subtle text-{{ action.tone }}-emphasis"><i class="bi {{ action.icon }}"></i></span>
                                <div>
                                    <strong>{{ action.label }}</strong>
                                    <small>{{ action.text }}</small>
                                </div>
                                <i class="bi bi-arrow-right-short"></i>
                            </a>
                        {% else %}
                            <div class="dashboard-empty">
                                <i class="bi bi-grid"></i>
                                <span>Aucun raccourci disponible.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>
    </div>

    <section class="dashboard-panel card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Actions récentes</h2>
                    <p class="text-secondary small mb-0">Derniers éléments créés ou mis en visibilité dans vos modules.</p>
                </div>
                <span class="badge bg-light text-secondary">{{ dashboard.recent_activity|length }} mouvement{{ dashboard.recent_activity|length > 1 ? 's' : '' }}</span>
            </div>
        </div>
        <div class="card-body">
            <div class="dashboard-recent-grid">
                {% for item in dashboard.recent_activity %}
                    <a class="dashboard-recent-item" href="{{ path(item.route) }}">
                        <span class="dashboard-alert-icon bg-{{ item.tone }}-subtle text-{{ item.tone }}-emphasis"><i class="bi {{ item.icon }}"></i></span>
                        <div class="min-w-0">
                            <div class="d-flex flex-wrap align-items-center gap-2">
                                <strong class="text-truncate">{{ item.title }}</strong>
                                <span class="badge text-bg-light text-secondary">{{ item.kind }}</span>
                            </div>
                            <small class="text-secondary">{{ item.meta }}</small>
                        </div>
                        <time class="dashboard-recent-date">{{ item.date_label }}</time>
                    </a>
                {% else %}
                    <div class="dashboard-empty">
                        <i class="bi bi-clock-history"></i>
                        <span>Aucune activité récente disponible.</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {% if dashboard.available.agenda or dashboard.available.expenses %}
    <div class="row g-4 mb-4">
        {% if dashboard.available.agenda %}
        <div class="col-12 col-xl-6">
            <section class="dashboard-module-card card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <span class="dashboard-kicker">Agenda</span>
                            <h2 class="h5 mb-1">Répartition des rendez-vous</h2>
                        </div>
                        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_appointment_calendar') }}">Ouvrir</a>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            {% include 'components/_dashboard_chart.html.twig' with {
                                title: 'Statuts',
                                subtitle: dashboard.period.label,
                                chart: dashboard.charts.agenda,
                                chart_type: 'bars',
                                tone: 'primary',
                                progress: dashboard.agenda_overview.period_count,
                                progress_label: 'RDV'
                            } only %}
                        </div>
                        <div class="col-12 col-md-6">
                            {% include 'components/_dashboard_chart.html.twig' with {
                                title: 'Priorités',
                                subtitle: dashboard.period.label,
                                chart: dashboard.charts.agenda_priorities,
                                chart_type: 'bars',
                                tone: 'warning',
                                progress: dashboard.agenda_overview.high_priority,
                                progress_label: 'Haute'
                            } only %}
                        </div>
                    </div>
                </div>
            </section>
        </div>
        {% endif %}

        {% if dashboard.available.expenses %}
        <div class="col-12 col-xl-6">
            <section class="dashboard-module-card card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <span class="dashboard-kicker">Finances</span>
                            <h2 class="h5 mb-1">Dépenses par catégorie</h2>
                        </div>
                        <a class="btn btn-sm btn-outline-warning" href="{{ path('app_expense_index') }}">Ouvrir</a>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            {% include 'components/_dashboard_chart.html.twig' with {
                                title: 'Montants TTC',
                                subtitle: dashboard.period.label,
                                chart: dashboard.expense_type_chart,
                                chart_type: 'bars',
                                tone: 'warning',
                                progress: dashboard.finance_overview.period_count,
                                progress_label: 'Dépenses'
                            } only %}
                        </div>
                        <div class="col-12 col-md-6">
                            {% include 'components/_dashboard_chart.html.twig' with {
                                title: 'Statuts',
                                subtitle: dashboard.period.label,
                                chart: dashboard.charts.expense_status,
                                chart_type: 'bars',
                                tone: 'warning',
                                progress: dashboard.finance_overview.period_pending_count,
                                progress_label: 'À valider'
                            } only %}
                        </div>
                    </div>
                </div>
            </section>
        </div>
        {% endif %}
    </div>
    {% endif %}

    <section class="dashboard-panel card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Modules accessibles</h2>
                    <p class="text-secondary small mb-0">Vue synthétique des domaines actifs.</p>
                </div>
                <span class="badge bg-secondary-subtle text-secondary-emphasis">{{ dashboard.sections|length }} module{{ dashboard.sections|length > 1 ? 's' : '' }}</span>
            </div>
        </div>
        <div class="card-body">
            <div class="dashboard-module-summary">
                {% for section in dashboard.sections %}
                    {% set tone = section.tone == 'dark' ? 'secondary' : section.tone %}
                    <a class="dashboard-module-summary-item" href="{{ path(section.route) }}">
                        <span class="dashboard-module-icon bg-{{ tone }}-subtle text-{{ tone }}-emphasis"><i class="bi {{ section.icon }}"></i></span>
                        <div class="min-w-0">
                            <strong>{{ section_labels[section.slug]|default(section.name) }}</strong>
                            <small>{{ section.metrics|length }} indicateur{{ section.metrics|length > 1 ? 's' : '' }}</small>
                        </div>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                {% else %}
                    <div class="dashboard-empty">
                        <i class="bi bi-grid"></i>
                        <span>Aucun module disponible.</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
</div>
{% endblock %}
