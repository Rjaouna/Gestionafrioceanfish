{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
{% set first_name = app.user.firstName ?? app.user.displayName %}
{% set inventory = dashboard.inventory_overview|default({}) %}
{% set finance = dashboard.finance_overview|default({}) %}
{% set agenda = dashboard.agenda_overview|default({}) %}
{% set section_labels = {
    agenda: 'Agenda - RDV',
    inventory: 'Inventaire',
    maintenance: 'Maintenance',
    expenses: 'Dépenses',
    documents: 'Documents',
    contacts: 'Contacts',
    passwords: 'Coffre d’accès',
    users: 'Utilisateurs',
    modules: 'Configuration',
    statistics: 'Statistiques'
} %}

<div class="dashboard-shell dashboard-home">
    <section class="dashboard-command-center mb-4">
        <div class="dashboard-command-copy">
            <span class="dashboard-kicker">Cockpit direction</span>
            <h1 class="h3 fw-bold mb-2">Bonjour {{ first_name }}</h1>
            <p class="text-secondary mb-0">
                Synthèse utile pour décider : argent à valider, matériel à suivre, RDV prioritaires, contrats à risque et sécurité des accès.
            </p>
        </div>

        <div class="dashboard-command-metrics">
            {% for metric in dashboard.hero_metrics %}
                <div class="dashboard-command-metric">
                    <span class="text-{{ metric.tone }}"><i class="bi {{ metric.icon }}"></i></span>
                    <strong>{{ metric.value }}</strong>
                    <small>{{ metric.label }}</small>
                </div>
            {% endfor %}
        </div>
    </section>

   

    {% if dashboard.executive_kpis is empty %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Aucun module ne vous a encore été attribué.
        </div>
    {% else %}
        <section class="dashboard-kpi-grid mb-4" aria-label="Indicateurs direction">
            {% for kpi in dashboard.executive_kpis %}
                <a class="dashboard-kpi-card dashboard-kpi-card-{{ kpi.tone|default('primary') }} card border-0 shadow-sm" href="{{ path(kpi.route) }}">
                    <div class="dashboard-kpi-head">
                        <span class="dashboard-kpi-title">{{ kpi.label }}</span>
                        <span class="dashboard-kpi-icon"><i class="bi {{ kpi.icon }}"></i></span>
                    </div>
                    <div class="dashboard-kpi-value">{{ kpi.value_display|default(kpi.value) }}</div>
                    <div class="dashboard-kpi-hint">{{ kpi.hint }}</div>
                </a>
            {% endfor %}
        </section>
    {% endif %}

    

    <div class="row g-4 mb-4">
        {% if dashboard.available.expenses %}
            <div class="col-12 col-xxl-6">
                <section class="dashboard-module-card card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <span class="dashboard-kicker">Finances</span>
                                <h2 class="h5 mb-1">Dépenses et validations</h2>
                                <p class="text-secondary small mb-0">Le montant à piloter, pas seulement la liste des dépenses.</p>
                            </div>
                            <a class="btn btn-sm btn-outline-warning" href="{{ path('app_expense_index') }}">Ouvrir</a>
                        </div>

                        <div class="dashboard-card-metrics mb-3">
                            <div class="dashboard-card-metric">
                                <span>Total période</span>
                                <strong>{{ finance.period_total|default(0)|number_format(0, ',', ' ') }} dh</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>À valider</span>
                                <strong>{{ finance.period_pending_count|default(0) }}</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>Payé</span>
                                <strong>{{ finance.paid_total|default(0)|number_format(0, ',', ' ') }} dh</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>Refusées</span>
                                <strong>{{ finance.refused_count|default(0) }}</strong>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Par catégorie',
                                    subtitle: dashboard.period.label,
                                    chart: dashboard.charts.expense_types,
                                    chart_type: 'pie',
                                    center_value: finance.period_total|default(0)|number_format(0, ',', ' ') ~ ' dh',
                                    center_label: 'Période',
                                    tone: 'warning'
                                } only %}
                            </div>
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Statuts',
                                    subtitle: 'Validation / paiement',
                                    chart: dashboard.charts.expense_status,
                                    chart_type: 'bars',
                                    tone: 'warning',
                                    progress: finance.period_pending_count|default(0),
                                    progress_label: 'À valider'
                                } only %}
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        {% endif %}

        {% if dashboard.available.inventory %}
            <div class="col-12 col-xxl-6">
                <section class="dashboard-module-card card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <span class="dashboard-kicker">Inventaire</span>
                                <h2 class="h5 mb-1">Matériel, sites et demandes</h2>
                                <p class="text-secondary small mb-0">Suivi des transferts, inventaires terrain et matériel à risque.</p>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <a class="btn btn-sm btn-outline-primary" href="{{ path('app_inventory_item_index') }}">Matériel</a>
                                <a class="btn btn-sm btn-outline-primary" href="{{ path('app_inventory_consumable_stock_index') }}">Consommables</a>
                                <a class="btn btn-sm btn-primary" href="{{ path('app_inventory_request_index') }}">Demandes</a>
                            </div>
                        </div>

                        <div class="dashboard-card-metrics mb-3">
                            <div class="dashboard-card-metric">
                                <span>Matériel actif</span>
                                <strong>{{ inventory.active_items|default(0) }}</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>Demandes</span>
                                <strong>{{ inventory.pending_requests|default(0) }}</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>Transports</span>
                                <strong>{{ inventory.pending_transfers|default(0) }}</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>À surveiller</span>
                                <strong>{{ inventory.unavailable_items|default(0) }}</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>Alertes stock</span>
                                <strong>{{ inventory.consumable_alerts|default(0) }}</strong>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Demandes en attente',
                                    subtitle: 'Transport / inventaire',
                                    chart: dashboard.charts.inventory_requests,
                                    chart_type: 'pie',
                                    center_value: inventory.pending_requests|default(0),
                                    center_label: 'À valider',
                                    tone: 'info'
                                } only %}
                            </div>
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Par site',
                                    subtitle: 'Matériel actif',
                                    chart: dashboard.charts.inventory_sites,
                                    chart_type: 'bars',
                                    tone: 'primary',
                                    progress: inventory.active_items|default(0),
                                    progress_label: 'Actifs'
                                } only %}
                            </div>
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Situation logistique',
                                    subtitle: 'Ancienne / nouvelle usine',
                                    chart: dashboard.charts.inventory_logistics,
                                    chart_type: 'pie',
                                    center_value: inventory.active_items|default(0),
                                    center_label: 'Matériels',
                                    tone: 'primary'
                                } only %}
                            </div>
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Statut matériel',
                                    subtitle: 'Disponibilité',
                                    chart: dashboard.charts.inventory_status,
                                    chart_type: 'bars',
                                    tone: 'success',
                                    progress: inventory.unavailable_items|default(0),
                                    progress_label: 'À surveiller'
                                } only %}
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        {% endif %}
    </div>

    <div class="row g-4 mb-4">
        {% if dashboard.available.agenda %}
            <div class="col-12 col-xl-6">
                <section class="dashboard-module-card card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <span class="dashboard-kicker">Agenda - RDV</span>
                                <h2 class="h5 mb-1">Charge commerciale et opérationnelle</h2>
                                <p class="text-secondary small mb-0">RDV à venir, priorités et confirmations à surveiller.</p>
                            </div>
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_appointment_calendar') }}">Calendrier</a>
                        </div>

                        <div class="dashboard-card-metrics mb-3">
                            <div class="dashboard-card-metric">
                                <span>Aujourd’hui</span>
                                <strong>{{ agenda.today|default(0) }}</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>7 jours</span>
                                <strong>{{ agenda.next_7_days|default(0) }}</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>En attente</span>
                                <strong>{{ agenda.pending|default(0) }}</strong>
                            </div>
                            <div class="dashboard-card-metric">
                                <span>Priorité haute</span>
                                <strong>{{ agenda.high_priority|default(0) }}</strong>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Statuts RDV',
                                    subtitle: dashboard.period.label,
                                    chart: dashboard.charts.agenda,
                                    chart_type: 'bars',
                                    tone: 'primary',
                                    progress: agenda.period_count|default(0),
                                    progress_label: 'RDV'
                                } only %}
                            </div>
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Priorités',
                                    subtitle: 'Niveau de risque',
                                    chart: dashboard.charts.agenda_priorities,
                                    chart_type: 'pie',
                                    center_value: agenda.high_priority|default(0),
                                    center_label: 'Hautes',
                                    tone: 'warning'
                                } only %}
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        {% endif %}

        {% if dashboard.available.maintenance %}
            <div class="col-12 col-xl-6">
                <section class="dashboard-module-card card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <span class="dashboard-kicker">Maintenance</span>
                                <h2 class="h5 mb-1">Contrats et interventions</h2>
                                <p class="text-secondary small mb-0">Ce qui arrive à échéance et ce qui reste ouvert.</p>
                            </div>
                            <a class="btn btn-sm btn-outline-success" href="{{ path('app_maintenance_intervention_index') }}">Interventions</a>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Interventions',
                                    subtitle: 'Statuts',
                                    chart: dashboard.charts.interventions,
                                    chart_type: 'bars',
                                    tone: 'success',
                                    progress: dashboard.health_cards|length,
                                    progress_label: 'Suivi'
                                } only %}
                            </div>
                            <div class="col-12 col-lg-6">
                                {% include 'components/_dashboard_chart.html.twig' with {
                                    title: 'Santé contrats',
                                    subtitle: 'Actifs / échéance',
                                    chart: dashboard.charts.contracts_health,
                                    chart_type: 'pie',
                                    center_value: dashboard.alert_count,
                                    center_label: 'Alertes',
                                    tone: 'warning'
                                } only %}
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        {% endif %}
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-4">
            <section class="dashboard-panel card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">Prochaines échéances</h2>
                    <p class="text-secondary small mb-0">RDV et interventions à préparer.</p>
                </div>
                <div class="card-body">
                    <div class="dashboard-timeline">
                        {% for item in dashboard.schedule %}
                            <a class="dashboard-timeline-item dashboard-timeline-link" href="{{ path(item.route) }}">
                                <span class="dashboard-alert-icon bg-{{ item.tone }}-subtle text-{{ item.tone }}-emphasis"><i class="bi {{ item.icon }}"></i></span>
                                <div class="min-w-0">
                                    <div class="fw-semibold text-truncate">{{ item.title }}</div>
                                    <div class="small text-secondary">{{ item.meta }}</div>
                                </div>
                                <span class="badge text-bg-light text-secondary">{{ item.kind }}</span>
                            </a>
                        {% else %}
                            <div class="dashboard-empty">
                                <i class="bi bi-calendar-check"></i>
                                <span>Aucune échéance ouverte.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-4">
            <section class="dashboard-panel card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">Actions rapides</h2>
                    <p class="text-secondary small mb-0">Accès aux écrans qui font avancer les validations.</p>
                </div>
                <div class="card-body">
                    <div class="dashboard-action-list">
                        {% for action in dashboard.quick_actions %}
                            <a class="dashboard-action-card" href="{{ path(action.route) }}">
                                <span class="bg-{{ action.tone }}-subtle text-{{ action.tone }}-emphasis"><i class="bi {{ action.icon }}"></i></span>
                                <div>
                                    <strong>{{ action.label }}</strong>
                                    <small>{{ action.text }}</small>
                                </div>
                                <i class="bi bi-arrow-right-short"></i>
                            </a>
                        {% else %}
                            <div class="dashboard-empty">
                                <i class="bi bi-grid"></i>
                                <span>Aucun raccourci disponible.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-4">
            <section class="dashboard-panel card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">Activité récente</h2>
                    <p class="text-secondary small mb-0">Derniers mouvements significatifs.</p>
                </div>
                <div class="card-body">
                    <div class="dashboard-alert-list">
                        {% for item in dashboard.recent_activity|slice(0, 6) %}
                            <a class="dashboard-recent-item" href="{{ path(item.route) }}">
                                <span class="dashboard-alert-icon bg-{{ item.tone }}-subtle text-{{ item.tone }}-emphasis"><i class="bi {{ item.icon }}"></i></span>
                                <div class="min-w-0">
                                    <strong class="text-truncate">{{ item.title }}</strong>
                                    <small>{{ item.kind }} · {{ item.meta }}</small>
                                </div>
                                <time class="dashboard-recent-date">{{ item.date_label }}</time>
                            </a>
                        {% else %}
                            <div class="dashboard-empty">
                                <i class="bi bi-clock-history"></i>
                                <span>Aucune activité récente.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>
    </div>

    <section class="dashboard-panel card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Couverture des modules</h2>
                    <p class="text-secondary small mb-0">Résumé des domaines actifs pour ne pas perdre le contexte métier.</p>
                </div>
                <span class="badge bg-secondary-subtle text-secondary-emphasis">{{ dashboard.sections|length }} module{{ dashboard.sections|length > 1 ? 's' : '' }}</span>
            </div>
        </div>
        <div class="card-body">
            <div class="dashboard-module-summary">
                {% for section in dashboard.sections %}
                    {% set tone = section.tone == 'dark' ? 'secondary' : section.tone %}
                    <a class="dashboard-module-summary-item" href="{{ path(section.route) }}">
                        <span class="dashboard-module-icon bg-{{ tone }}-subtle text-{{ tone }}-emphasis"><i class="bi {{ section.icon }}"></i></span>
                        <div class="min-w-0">
                            <strong>{{ section_labels[section.slug]|default(section.name) }}</strong>
                            <small>{{ section.headline|default(section.metrics|length ~ ' indicateurs') }}</small>
                        </div>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                {% else %}
                    <div class="dashboard-empty">
                        <i class="bi bi-grid"></i>
                        <span>Aucun module disponible.</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
</div>
{% endblock %}
