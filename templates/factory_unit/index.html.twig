{% extends 'base.html.twig' %}

{% block title %}Composition usine{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Composition usine</h1>
        <p class="text-secondary mb-0">Tunnels, chambres froides et zones de stockage utilisables dans les charges et le workflow.</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createFactoryUnitModal">
        <i class="bi bi-plus-circle me-2"></i>Ajouter une piece
    </button>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-secondary small">Pieces declarees</div>
                <div class="h4 mb-0">{{ stats.total }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-secondary small">Disponibles</div>
                <div class="h4 mb-0 text-success">{{ stats.active }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-secondary small">Tunnels</div>
                <div class="h4 mb-0">{{ stats.tunnels }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-secondary small">Saturees</div>
                <div class="h4 mb-0 {{ stats.saturated > 0 ? 'text-danger' : '' }}">{{ stats.saturated }}</div>
            </div>
        </div>
    </div>
</div>

<form class="card border-0 shadow-sm mb-4" method="get">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-lg">
                <label class="form-label" for="factory-search">Recherche</label>
                <input id="factory-search" class="form-control" type="search" name="q" value="{{ filters.q }}" placeholder="Nom, reference, emplacement">
            </div>
            <div class="col-12 col-md-4 col-lg-3">
                <label class="form-label" for="factory-type">Type</label>
                <select id="factory-type" class="form-select" name="type">
                    <option value="">Tous</option>
                    {% for value, label in type_choices %}
                        <option value="{{ value }}" {{ filters.type == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-12 col-md-4 col-lg-3">
                <label class="form-label" for="factory-status">Statut</label>
                <select id="factory-status" class="form-select" name="status">
                    <option value="">Tous</option>
                    {% for value, label in status_choices %}
                        <option value="{{ value }}" {{ filters.status == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-12 col-md-4 col-lg-2">
                <label class="form-label" for="factory-saturation">Saturation</label>
                <select id="factory-saturation" class="form-select" name="saturation">
                    <option value="">Toutes</option>
                    <option value="non_sature" {{ filters.saturation == 'non_sature' ? 'selected' : '' }}>Non saturee</option>
                    <option value="sature" {{ filters.saturation == 'sature' ? 'selected' : '' }}>Saturee</option>
                </select>
            </div>
            <div class="col-12 col-lg-auto">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search me-2"></i>Filtrer
                </button>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Piece</th>
                    <th>Capacite</th>
                    <th>Dimensions</th>
                    <th>Temperature</th>
                    <th>Emplacement</th>
                    <th>Statut</th>
                    <th>Charge</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for item in items %}
                <tr class="{{ item.active ? '' : 'opacity-75' }}">
                    <td>
                        <div class="fw-semibold">{{ item.displayName }}</div>
                        <div class="small text-secondary">{{ item.typeLabel }}</div>
                    </td>
                    <td>
                        <div class="fw-semibold">{{ (item.capacityKg + 0)|number_format(0, ',', ' ') }} kg</div>
                        <div class="small text-secondary">{{ item.capacityPallets }} palette{{ item.capacityPallets > 1 ? 's' : '' }} - {{ item.capacityBoxes }} caisse{{ item.capacityBoxes > 1 ? 's' : '' }}</div>
                    </td>
                    <td>
                        <div>{{ (item.lengthMeters + 0)|number_format(2, ',', ' ') }} x {{ (item.widthMeters + 0)|number_format(2, ',', ' ') }} x {{ (item.heightMeters + 0)|number_format(2, ',', ' ') }} m</div>
                        <div class="small text-secondary">{{ item.surfaceM2|number_format(2, ',', ' ') }} m2 - {{ item.volumeM3|number_format(2, ',', ' ') }} m3</div>
                    </td>
                    <td>
                        {% if item.targetTemperature is not null or item.minTemperature is not null or item.maxTemperature is not null %}
                            <div class="small">Cible {{ item.targetTemperature is not null ? (item.targetTemperature + 0)|number_format(2, ',', ' ') ~ ' deg C' : '-' }}</div>
                            <div class="small text-secondary">Min {{ item.minTemperature is not null ? (item.minTemperature + 0)|number_format(2, ',', ' ') ~ ' deg C' : '-' }} / Max {{ item.maxTemperature is not null ? (item.maxTemperature + 0)|number_format(2, ',', ' ') ~ ' deg C' : '-' }}</div>
                        {% else %}
                            <span class="text-secondary">Non renseignee</span>
                        {% endif %}
                    </td>
                    <td>
                        <div>{{ item.locationLabel ?: 'Non precise' }}</div>
                        <div class="small text-secondary">{{ item.floorLevel ?: 'Niveau non precise' }}</div>
                    </td>
                    <td>
                        <div class="d-flex flex-column gap-1 align-items-start">
                            <span class="badge {{ item.statusBadgeClass }}">{{ item.statusLabel }}</span>
                            <span class="badge {{ item.saturated ? 'text-bg-danger' : 'text-bg-success' }}">{{ item.saturated ? 'Saturee' : 'Non saturee' }}</span>
                            <span class="badge {{ item.active ? 'text-bg-primary' : 'text-bg-secondary' }}">{{ item.active ? 'Selectionnable' : 'Masquee' }}</span>
                        </div>
                    </td>
                    <td>
                        <span class="badge text-bg-light">Creee automatiquement</span>
                        <div class="small text-secondary">Desactivee par defaut dans les couts.</div>
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary" type="button" title="Modifier" aria-label="Modifier" data-remote-modal="{{ path('app_factory_unit_form', {id: item.id}) }}">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button
                                class="btn btn-outline-warning"
                                type="button"
                                title="{{ item.saturated ? 'Marquer non saturee' : 'Marquer saturee' }}"
                                aria-label="{{ item.saturated ? 'Marquer non saturee' : 'Marquer saturee' }}"
                                data-confirm-url="{{ path('app_factory_unit_saturation', {id: item.id}) }}"
                                data-token="{{ csrf_token('factory_unit_saturation_' ~ item.id) }}"
                                data-confirm-message="{{ item.saturated ? 'Rendre cette piece disponible pour le stockage ?' : 'Marquer cette piece comme saturee ? Elle ne sera plus proposee pour le stockage.' }}"
                            >
                                <i class="bi {{ item.saturated ? 'bi-unlock' : 'bi-lock' }}"></i>
                            </button>
                            <button
                                class="btn btn-outline-secondary"
                                type="button"
                                title="{{ item.active ? 'Masquer des selections' : 'Rendre selectionnable' }}"
                                aria-label="{{ item.active ? 'Masquer des selections' : 'Rendre selectionnable' }}"
                                data-confirm-url="{{ path('app_factory_unit_active', {id: item.id}) }}"
                                data-token="{{ csrf_token('factory_unit_active_' ~ item.id) }}"
                                data-confirm-message="{{ item.active ? 'Retirer cette piece des listes de selection ?' : 'Rendre cette piece selectionnable ?' }}"
                            >
                                <i class="bi {{ item.active ? 'bi-eye-slash' : 'bi-eye' }}"></i>
                            </button>
                            <button
                                class="btn btn-outline-danger"
                                type="button"
                                title="Supprimer si vide"
                                aria-label="Supprimer si vide"
                                data-confirm-url="{{ path('app_factory_unit_delete', {id: item.id}) }}"
                                data-confirm-method="DELETE"
                                data-token="{{ csrf_token('factory_unit_delete_' ~ item.id) }}"
                                data-confirm-message="Supprimer cette piece usine ? L'action sera refusee si elle contient encore du stock ou un lot en cours."
                            >
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td class="text-center text-secondary py-5" colspan="8">Aucune piece usine declaree.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createFactoryUnitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
        <div class="modal-content">
            {% include 'factory_unit/_form_modal.html.twig' with {
                form: create_form,
                title: 'Ajouter une piece usine',
                submit_label: 'Créer'
            } %}
        </div>
    </div>
</div>
{% endblock %}
