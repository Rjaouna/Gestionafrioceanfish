{% extends 'base.html.twig' %}

{% block title %}Nouvelle fiche interimaire{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Nouvelle fiche interimaire</h1>
        <p class="text-secondary mb-0">Creation d'une fiche de poste au format interne.</p>
    </div>
    <a class="btn btn-outline-secondary" href="{{ path('app_interim_worker_index') }}">
        <i class="bi bi-arrow-left me-2"></i>Retour
    </a>
</div>

<div class="modal-content border-0 shadow-sm">
    {% include 'interim_worker/_form_modal.html.twig' with {
        form: form,
        worker: worker,
        title: 'Ajouter un interimaire',
        submit_label: 'Ajouter',
        filter_choices: filter_choices,
        hide_close: true
    } %}
</div>
{% endblock %}
