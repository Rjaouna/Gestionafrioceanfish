{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header border-0 pb-0">
        <div>
            <h2 class="modal-title h4">A ne pas rappeler</h2>
            <p class="text-secondary mb-0">{{ worker.fullName }} · {{ worker.registrationNumber }}</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-danger">
            Utilisez ce statut uniquement pour un motif grave. La fiche passera en rouge et restera visible dans les filtres pour eviter de rappeler cette personne.
        </div>
        <div class="row g-3">
            <div class="col-md-5">{{ form_row(form.actionDate) }}</div>
            <div class="col-12">{{ form_row(form.reason) }}</div>
        </div>
        {{ form_rest(form) }}
    </div>
    <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-exclamation-octagon me-2"></i>Bloquer le rappel
        </button>
    </div>
{{ form_end(form) }}
