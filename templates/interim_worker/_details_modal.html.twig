<div class="modal-header">
    <div>
        <h2 class="modal-title fs-5">{{ worker.fullName }}</h2>
        <p class="text-secondary small mb-0">{{ worker.position }} · {{ worker.registrationNumber }}</p>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
</div>
<div class="modal-body">
    {% if worker.status == 'a_ne_pas_rappeler' %}
        <div class="alert alert-danger d-flex gap-2 align-items-start">
            <i class="bi bi-exclamation-octagon mt-1"></i>
            <div>
                <strong>A ne pas rappeler.</strong>
                {% if worker.doNotRecallReason %}
                    <div class="small mt-1">{{ worker.doNotRecallReason }}</div>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 bg-light">
                <div class="card-body text-center">
                    {% if worker.hasPhoto %}
                        <img class="img-fluid rounded-3 mb-3" style="max-height: 260px;" src="{{ path('app_interim_worker_photo', {id: worker.id}) }}" alt="Photo {{ worker.fullName }}">
                    {% else %}
                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle text-primary fs-1 mb-3" style="width: 96px; height: 96px;">
                            <i class="bi bi-person"></i>
                        </span>
                    {% endif %}
                    <span class="badge {{ worker.statusBadgeClass }}">{{ worker.statusLabel }}</span>
                    <span class="badge {{ worker.workerTypeBadgeClass }}">{{ worker.workerTypeLabel }}</span>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="row g-3">
                <div class="col-md-6"><div class="text-secondary small">Téléphone</div><strong>{{ worker.phone }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">CIN</div><strong>{{ worker.cin ?: '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Passeport</div><strong>{{ worker.passportNumber ?: '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Nationalite</div><strong>{{ worker.nationality ?: '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Sexe</div><strong>{{ worker.genderLabel }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Pays emetteur</div><strong>{{ worker.passportIssueCountry ?: '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Delivrance passeport</div><strong>{{ worker.passportIssuedAt ? worker.passportIssuedAt|date('d/m/Y') : '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Expiration passeport</div><strong>{{ worker.passportExpiresAt ? worker.passportExpiresAt|date('d/m/Y') : '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Date de naissance</div><strong>{{ worker.birthDate ? worker.birthDate|date('d/m/Y') : '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Lieu de naissance</div><strong>{{ worker.birthPlace ?: '-' }}</strong></div>
                <div class="col-12"><div class="text-secondary small">Adresse</div><strong>{{ worker.address ?: '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Profil</div><strong>{{ worker.workerTypeLabel }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Situation familiale</div><strong>{{ worker.familySituationLabel }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Nombre d'enfants</div><strong>{{ worker.childrenCount }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Date d'embauche</div><strong>{{ worker.hireDate ? worker.hireDate|date('d/m/Y') : '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Signature salarie</div><strong>{{ worker.employeeSignature ?: '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Signature responsable</div><strong>{{ worker.managerSignature ?: '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Date de signature</div><strong>{{ worker.signatureDate ? worker.signatureDate|date('d/m/Y') : '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Fin de mission</div><strong>{{ worker.missionEndDate ? worker.missionEndDate|date('d/m/Y') : '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Dernier changement de statut</div><strong>{{ worker.lastStatusChangedAt ? worker.lastStatusChangedAt|date('d/m/Y') : '-' }}</strong></div>
                <div class="col-md-6"><div class="text-secondary small">Date blocage rappel</div><strong>{{ worker.doNotRecallAt ? worker.doNotRecallAt|date('d/m/Y') : '-' }}</strong></div>
                <div class="col-12"><div class="text-secondary small">Agence d'interim</div><strong>{{ worker.tempAgency ?: '-' }}</strong></div>
                {% if worker.missionEndReason %}
                    <div class="col-12"><div class="text-secondary small">Motif de fin de mission</div><strong class="text-break d-block">{{ worker.missionEndReason }}</strong></div>
                {% endif %}
            </div>
        </div>
    </div>

    {% set day_summary = attendance_day_summary|default(null) %}
    {% if day_summary %}
        <hr class="my-4">
        <section class="border rounded-3 bg-light p-3">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                <div>
                    <h3 class="h6 mb-1">Pointage du jour</h3>
                    <div class="small text-secondary">{{ day_summary.date|date('d/m/Y') }}</div>
                </div>
                <span class="badge text-bg-light border">{{ day_summary.totals.lines }} ligne{{ day_summary.totals.lines > 1 ? 's' : '' }}</span>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <div class="border rounded-3 bg-white p-3 h-100">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                            <strong>Nettoyage anchois</strong>
                            <span class="badge text-bg-warning">{{ day_summary.cleaning.lines }} saisie{{ day_summary.cleaning.lines > 1 ? 's' : '' }}</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Caisses</span>
                            <span class="fw-semibold">{{ day_summary.cleaning.caisses|number_format(0, ',', ' ') }}</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Poids</span>
                            <span class="fw-semibold">{{ day_summary.cleaning.kg|number_format(2, ',', ' ') }} kg</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Tarif</span>
                            <span class="fw-semibold">{{ day_summary.rates.cleaning|number_format(2, ',', ' ') }} MAD / 30 kg</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span class="text-secondary">Montant</span>
                            <span class="fw-bold">{{ day_summary.cleaning.amount|number_format(2, ',', ' ') }} MAD</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded-3 bg-white p-3 h-100">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                            <strong>Mise en caisse</strong>
                            <span class="badge text-bg-info">{{ day_summary.boxing.lines }} saisie{{ day_summary.boxing.lines > 1 ? 's' : '' }}</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Poids</span>
                            <span class="fw-semibold">{{ day_summary.boxing.kg|number_format(2, ',', ' ') }} kg</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Tarif</span>
                            <span class="fw-semibold">{{ day_summary.rates.boxing|number_format(2, ',', ' ') }} MAD / kg</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span class="text-secondary">Montant</span>
                            <span class="fw-bold">{{ day_summary.boxing.amount|number_format(2, ',', ' ') }} MAD</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded-3 bg-white p-3 h-100">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                            <strong>Total journee</strong>
                            <span class="badge text-bg-success">{{ day_summary.totals.amount|number_format(2, ',', ' ') }} MAD</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Poids taches</span>
                            <span class="fw-semibold">{{ day_summary.totals.taskKg|number_format(2, ',', ' ') }} kg</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Heures</span>
                            <span class="fw-semibold">{{ day_summary.totals.hours|number_format(2, ',', ' ') }} h</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span class="text-secondary">Total paie</span>
                            <span class="fw-bold">{{ day_summary.totals.amount|number_format(2, ',', ' ') }} MAD</span>
                        </div>
                    </div>
                </div>
            </div>

            {% if day_summary.items|length > 0 %}
                <div class="table-responsive mt-3">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Type</th>
                            <th>Detail</th>
                            <th class="text-end">Heures / kg</th>
                            <th class="text-end">Montant</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for item in day_summary.items %}
                            <tr>
                                <td>{{ item.presenceLabel }}</td>
                                <td class="small text-secondary">{{ item.timeRangeLabel }}</td>
                                <td class="text-end text-nowrap">
                                    {% if item.mode == 'task' %}
                                        {{ item.taskWeightKgValue|number_format(2, ',', ' ') }} kg
                                    {% else %}
                                        {{ item.totalHoursValue|number_format(2, ',', ' ') }} h
                                    {% endif %}
                                </td>
                                <td class="text-end fw-semibold text-nowrap">{{ item.totalAmountValue|number_format(2, ',', ' ') }} MAD</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="small text-secondary mt-3">Aucun pointage saisi pour cette journee.</div>
            {% endif %}
        </section>
    {% endif %}

    <hr class="my-4">
    <h3 class="h6">Observations du responsable</h3>
    <p class="mb-4 text-break">{{ worker.managerObservations ?: 'Aucune observation.' }}</p>

    {% if worker.internalComment %}
        <h3 class="h6">Commentaire interne</h3>
        <p class="mb-4 text-break">{{ worker.internalComment }}</p>
    {% endif %}

    <h3 class="h6">Historique des actions</h3>
    <div class="list-group mb-4">
        {% for action in worker.actions|slice(0, 6) %}
            <div class="list-group-item">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <strong>{{ action.actionTypeLabel }}</strong>
                        {% if action.previousStatusLabel or action.newStatusLabel %}
                            <div class="small text-secondary">
                                {{ action.previousStatusLabel ?: '-' }} -> {{ action.newStatusLabel ?: '-' }}
                            </div>
                        {% endif %}
                    </div>
                    <small class="text-secondary text-nowrap">{{ action.actionAt|date('d/m/Y') }}</small>
                </div>
                {% if action.reason %}
                    <div class="small mt-2 text-break">{{ action.reason }}</div>
                {% endif %}
                {% if action.performedBy %}
                    <div class="small text-secondary mt-1">Par {{ action.performedBy.displayName }}</div>
                {% endif %}
            </div>
        {% else %}
            <div class="text-secondary small">Aucune action enregistree.</div>
        {% endfor %}
    </div>

    <h3 class="h6">Documents joints</h3>
    <div class="list-group">
        {% for document in worker.documents %}
            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center gap-3" href="{{ path('app_interim_worker_document_download', {id: document.id}) }}">
                <span class="text-truncate"><i class="bi bi-paperclip me-2"></i>{{ document.originalFileName }}</span>
                <small class="text-secondary">{{ document.fileSizeLabel }}</small>
            </a>
        {% else %}
            <div class="text-secondary small">Aucun document joint.</div>
        {% endfor %}
    </div>
</div>
<div class="modal-footer">
    <a class="btn btn-outline-secondary" href="{{ path('app_interim_worker_print', {id: worker.id}) }}" target="_blank" rel="noopener">
        <i class="bi bi-printer me-1"></i>Imprimer la fiche
    </a>
    {% if is_granted('INTERIM_WORKER_EDIT', worker) %}
        <button class="btn btn-outline-secondary" data-remote-modal="{{ path('app_interim_worker_status_form', {id: worker.id}) }}">
            <i class="bi bi-arrow-repeat me-1"></i>Statut
        </button>
        {% if worker.status not in ['fin_mission', 'a_ne_pas_rappeler'] %}
            <button class="btn btn-outline-warning" data-remote-modal="{{ path('app_interim_worker_end_mission_form', {id: worker.id}) }}">
                <i class="bi bi-flag me-1"></i>Fin de mission
            </button>
        {% endif %}
        {% if worker.status != 'a_ne_pas_rappeler' %}
            <button class="btn btn-outline-danger" data-remote-modal="{{ path('app_interim_worker_do_not_recall_form', {id: worker.id}) }}">
                <i class="bi bi-exclamation-octagon me-1"></i>A ne pas rappeler
            </button>
        {% endif %}
        {% if is_granted('MODULE_ACCESS', 'pointage-personnel') %}
            <button class="btn btn-outline-success" data-remote-modal="{{ path('app_interim_attendance_choice', {id: worker.id}) }}">
                <i class="bi bi-calendar-plus me-1"></i>Pointage
            </button>
        {% endif %}
        {% if is_granted('MODULE_ACCESS', 'pointage-personnel') and is_granted('INTERIM_WORKER_VIEW', worker) %}
            <button class="btn btn-outline-secondary" data-remote-modal="{{ path('app_interim_attendance_worker_history', {id: worker.id}) }}">
                <i class="bi bi-clock-history me-1"></i>Historique
            </button>
        {% endif %}
        <button class="btn btn-primary" data-remote-modal="{{ path('app_interim_worker_form', {id: worker.id}) }}">
            <i class="bi bi-pencil me-1"></i>Modifier
        </button>
    {% endif %}
</div>
