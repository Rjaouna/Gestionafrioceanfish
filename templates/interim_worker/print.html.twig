<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Fiche de poste - {{ worker.fullName }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        @page { size: A4; margin: 16mm; }
        body { background: #f8f9fa; color: #111; }
        .sheet { width: 210mm; min-height: 297mm; margin: 0 auto; background: #fff; padding: 18mm; box-shadow: 0 .5rem 2rem rgba(0, 0, 0, .12); }
        .photo-box { width: 38mm; height: 45mm; border: 1px solid #333; display: flex; align-items: center; justify-content: center; overflow: hidden; font-size: .85rem; }
        .field-line { border-bottom: 1px dotted #333; min-height: 1.7rem; flex: 1; padding-left: .5rem; }
        .comments-lines { min-height: 70mm; border-bottom: 1px solid #aaa; background: repeating-linear-gradient(to bottom, transparent 0, transparent 8mm, rgba(0, 0, 0, .55) 8.3mm); white-space: pre-wrap; }
        .signature-line { border-bottom: 1px solid #333; min-width: 58mm; display: inline-block; padding: 0 .5rem; }
        @media print {
            body { background: #fff; }
            .sheet { width: auto; min-height: auto; margin: 0; padding: 0; box-shadow: none; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>
<div class="no-print container py-3 text-end">
    <button class="btn btn-primary" onclick="window.print()">Imprimer</button>
</div>
<main class="sheet">
    <div class="d-flex align-items-start justify-content-between mb-4">
        <div class="photo-box">
            {% if worker.hasPhoto %}
                <img src="{{ path('app_interim_worker_photo', {id: worker.id}) }}" alt="Photo" style="width:100%; height:100%; object-fit:cover;">
            {% else %}
                PHOTO
            {% endif %}
        </div>
        <h1 class="h5 text-center fw-bold text-decoration-underline flex-grow-1 mt-4">FICHE DE POSTE - INTERIMAIRE</h1>
        <div style="width: 38mm;"></div>
    </div>

    {% set rows = [
        ['Nom et Prénom', worker.fullName],
        ['Adresse', worker.address],
        ['Poste', worker.position],
        ['Matricule', worker.registrationNumber],
        ['Téléphone', worker.phone],
        ['Date de naissance', worker.birthDate ? worker.birthDate|date('d/m/Y') : ''],
        ['Lieu de naissance', worker.birthPlace],
        ['CIN', worker.cin]
    ] %}

    <div class="d-grid gap-3 mb-3">
        {% for row in rows %}
            <div class="d-flex align-items-end">
                <strong class="me-2">{{ row[0] }} :</strong>
                <span class="field-line">{{ row[1] ?: '' }}</span>
            </div>
        {% endfor %}
    </div>

    <div class="mb-3">
        <strong>Situation familiale :</strong>
        <span class="ms-2">{{ (worker.familySituation == 'celibataire' ? '&#9745;' : '&#9744;')|raw }} Celibataire</span>
        <span class="ms-2">{{ (worker.familySituation == 'marie' ? '&#9745;' : '&#9744;')|raw }} Marie(e)</span>
        <span class="ms-2">{{ (worker.familySituation == 'divorce' ? '&#9745;' : '&#9744;')|raw }} Divorce(e)</span>
        <span class="ms-2">{{ (worker.familySituation == 'veuf' ? '&#9745;' : '&#9744;')|raw }} Veuf(ve)</span>
    </div>

    <div class="d-grid gap-3 mb-5">
        <div class="d-flex align-items-end">
            <strong class="me-2">Nombre d'enfants :</strong>
            <span class="field-line">{{ worker.childrenCount }}</span>
        </div>
        <div class="d-flex align-items-end">
            <strong class="me-2">Date d'embauche :</strong>
            <span class="field-line">{{ worker.hireDate ? worker.hireDate|date('d/m/Y') : '' }}</span>
        </div>
    </div>

    <hr class="border-dark my-4">
    <h2 class="h5 fw-bold mb-4">OBSERVATIONS / COMMENTAIRES DU RESPONSABLE</h2>
    <div class="comments-lines p-2">{{ worker.managerObservations ?: '' }}</div>

    <div class="mt-5 pt-4">
        <div class="d-flex justify-content-between gap-4 mb-4">
            <div><strong>Signature du salarie :</strong> <span class="signature-line">{{ worker.employeeSignature ?: '' }}</span></div>
        </div>
        <div class="d-flex justify-content-between gap-4">
            <div><strong>Signature du responsable :</strong> <span class="signature-line">{{ worker.managerSignature ?: '' }}</span></div>
            <div><strong>Date :</strong> {{ worker.signatureDate ? worker.signatureDate|date('d / m / Y') : '____ / ____ / ______' }}</div>
        </div>
    </div>
</main>
</body>
</html>
