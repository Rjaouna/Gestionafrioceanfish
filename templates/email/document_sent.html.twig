<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>Document transmis</title>
    </head>
    <body style="margin:0;background:#f6f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;">
        <div style="max-width:640px;margin:0 auto;padding:24px 16px;">
            <div style="background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;padding:24px;">
                <p style="margin:0 0 6px;font-size:13px;color:#64748b;text-transform:uppercase;letter-spacing:.04em;">Afriocean fish Gestion</p>
                <h1 style="margin:0 0 18px;font-size:22px;line-height:1.25;color:#111827;">Document transmis</h1>

                <p style="margin:0 0 14px;font-size:15px;line-height:1.6;">Bonjour,</p>
                <p style="margin:0 0 20px;font-size:15px;line-height:1.6;">
                    {{ actor.displayName }} vous transmet un document en pièce jointe.
                </p>

                <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;font-size:14px;">
                    <tr>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#64748b;width:170px;">Expéditeur</td>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#111827;">{{ actor.displayName }}</td>
                    </tr>
                    {% if actor.email %}
                        <tr>
                            <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#64748b;">Email expéditeur</td>
                            <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#111827;">{{ actor.email }}</td>
                        </tr>
                    {% endif %}
                    <tr>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#64748b;">Document</td>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#111827;">{{ document.name }}</td>
                    </tr>
                    <tr>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#64748b;">Fichier joint</td>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#111827;">{{ document.originalFileName }}</td>
                    </tr>
                    <tr>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#64748b;">Taille</td>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#111827;">{{ (document.fileSize / 1024)|number_format(1, ',', ' ') }} Ko</td>
                    </tr>
                    {% if document.description %}
                        <tr>
                            <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#64748b;">Description</td>
                            <td style="padding:10px 0;border-top:1px solid #e5e7eb;color:#111827;">{{ document.description|nl2br }}</td>
                        </tr>
                    {% endif %}
                    <tr>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb;color:#64748b;">Lien</td>
                        <td style="padding:10px 0;border-top:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb;color:#111827;">{{ document_url }}</td>
                    </tr>
                </table>

                <p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#64748b;">
                    Le document est également attaché à cet e-mail. Vous pouvez répondre directement à ce message si besoin.
                </p>
            </div>
        </div>
    </body>
</html>
