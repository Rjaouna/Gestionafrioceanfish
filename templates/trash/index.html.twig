{% extends 'base.html.twig' %}

{% block title %}Corbeille{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Corbeille</h1>
        <p class="text-secondary mb-0">{{ items|length }} element{{ items|length > 1 ? 's' : '' }} supprime{{ items|length > 1 ? 's' : '' }} en attente de decision.</p>
    </div>
    <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis px-3 py-2">
        <i class="bi bi-shield-lock me-1"></i>Super administrateur uniquement
    </span>
</div>

{% include 'trash/_filters.html.twig' %}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        {% if items %}
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Element</th>
                            <th>Module</th>
                            <th>Supprime le</th>
                            <th>Supprime par</th>
                            <th>Motif</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="trashList">
                        {% for item in items %}
                            {% include 'trash/_trash_row.html.twig' with {item: item} %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="p-4 text-center d-none" data-search-empty>
                <i class="bi bi-search text-secondary fs-2"></i>
                <p class="text-secondary mb-0 mt-2">Aucun element ne correspond a cette recherche.</p>
            </div>
        {% else %}
            <div class="text-center py-5">
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success-subtle text-success fs-2 empty-state-mark">
                    <i class="bi bi-check2-circle"></i>
                </span>
                <h2 class="h5 mt-3">Corbeille vide</h2>
                <p class="text-secondary mb-0">Aucun element supprime pour le moment.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
