<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form class="row g-3 align-items-end" method="get">
            <div class="col-lg-4">
                <label class="form-label small text-secondary" for="trashSearch">Recherche</label>
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-search text-primary"></i>
                    </span>
                    <input
                        id="trashSearch"
                        type="search"
                        name="q"
                        value="{{ query }}"
                        class="form-control"
                        placeholder="Nom, module, utilisateur, motif..."
                        data-list-search
                        data-search-target="trashList"
                    >
                    <button class="btn btn-outline-secondary {{ query ? '' : 'd-none' }}" type="button" data-clear-search aria-label="Effacer la recherche">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-6 col-lg-2">
                <label class="form-label small text-secondary" for="trashType">Type</label>
                <select id="trashType" name="type" class="form-select">
                    <option value="">Tous</option>
                    {% for type, config in trashables %}
                        <option value="{{ type }}" {{ filters.type == type ? 'selected' : '' }}>{{ config.label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-6 col-lg-2">
                <label class="form-label small text-secondary" for="trashModule">Module</label>
                <select id="trashModule" name="module" class="form-select">
                    <option value="">Tous</option>
                    {% for module in modules %}
                        <option value="{{ module }}" {{ filters.module == module ? 'selected' : '' }}>{{ module }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-6 col-lg-2">
                <label class="form-label small text-secondary" for="trashDeletedBy">Supprime par</label>
                <select id="trashDeletedBy" name="deletedBy" class="form-select">
                    <option value="">Tous</option>
                    {% for user in deleted_users %}
                        <option value="{{ user.id }}" {{ filters.deletedBy == user.id ? 'selected' : '' }}>{{ user.displayName }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3 col-lg-1">
                <label class="form-label small text-secondary" for="trashDateFrom">Du</label>
                <input id="trashDateFrom" class="form-control" type="date" name="dateFrom" value="{{ filters.dateFrom }}">
            </div>
            <div class="col-md-3 col-lg-1">
                <label class="form-label small text-secondary" for="trashDateTo">Au</label>
                <input id="trashDateTo" class="form-control" type="date" name="dateTo" value="{{ filters.dateTo }}">
            </div>
            <div class="col-12 d-flex justify-content-end gap-2">
                <a class="btn btn-outline-secondary" href="{{ path('app_trash_index') }}">Reinitialiser</a>
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-funnel me-1"></i>Filtrer
                </button>
            </div>
        </form>
    </div>
</div>
