{% extends 'base.html.twig' %}

{% block title %}Contrats{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Contrats</h1>
        <p class="text-secondary mb-0">Creation, suivi et generation PDF des contrats clients.</p>
    </div>
    <a class="btn btn-primary" href="{{ path('app_generated_contract_conditioning_new') }}">
        <i class="bi bi-file-earmark-plus me-2"></i>Nouveau contrat
    </a>
</div>

<section class="mb-4">
    <div class="row g-3">
        <div class="col-12 col-lg-5">
            <a class="card border-0 shadow-sm h-100 text-decoration-none text-reset" href="{{ path('app_generated_contract_conditioning_new') }}">
                <div class="card-body d-flex align-items-center gap-3">
                    <span class="rounded-3 bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center fs-3 module-mark">
                        <i class="bi bi-box-seam"></i>
                    </span>
                    <span>
                        <strong class="d-block mb-1">Contrat de conditionnement</strong>
                        <small class="text-secondary">Client, campagne, representant, signatures et PDF avec en-tete AFRIOCEAN.</small>
                    </span>
                    <i class="bi bi-chevron-right ms-auto text-secondary"></i>
                </div>
            </a>
        </div>
    </div>
</section>

<form class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-lg-3">
                <label class="form-label" for="contractSearch">Recherche</label>
                <input id="contractSearch" class="form-control" type="search" name="q" value="{{ filters.q }}" placeholder="Reference, client, representant...">
            </div>
            <div class="col-12 col-md-6 col-lg-2">
                <label class="form-label" for="contractType">Type</label>
                <select id="contractType" class="form-select" name="type">
                    <option value="">Tous</option>
                    {% for value, label in types %}
                        <option value="{{ value }}" {{ filters.type == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-12 col-md-6 col-lg-2">
                <label class="form-label" for="contractStatus">Statut</label>
                <select id="contractStatus" class="form-select" name="status">
                    <option value="">Tous</option>
                    {% for value, label in statuses %}
                        <option value="{{ value }}" {{ filters.status == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-12 col-md-6 col-lg-2">
                <label class="form-label" for="contractDateFrom">Du</label>
                <input id="contractDateFrom" class="form-control" type="date" name="dateFrom" value="{{ filters.dateFrom }}">
            </div>
            <div class="col-12 col-md-6 col-lg-2">
                <label class="form-label" for="contractDateTo">Au</label>
                <input id="contractDateTo" class="form-control" type="date" name="dateTo" value="{{ filters.dateTo }}">
            </div>
            <div class="col-12 col-lg-1 d-grid">
                <button class="btn btn-primary" type="submit" title="Filtrer" aria-label="Filtrer">
                    <i class="bi bi-funnel"></i>
                </button>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center gap-3">
        <div>
            <h2 class="h5 mb-1">Contrats generes</h2>
            <p class="text-secondary small mb-0">{{ pagination.total }} contrat{{ pagination.total > 1 ? 's' : '' }} trouve{{ pagination.total > 1 ? 's' : '' }}.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Reference</th>
                <th>Type</th>
                <th>Client</th>
                <th>Campagne</th>
                <th>Statut</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for contract in contracts %}
                <tr>
                    <td class="text-nowrap">{{ contract.contractDate|date('d/m/Y') }}</td>
                    <td class="fw-semibold">{{ contract.reference }}</td>
                    <td>{{ contract.contractTypeLabel }}</td>
                    <td>
                        <div class="fw-semibold">{{ contract.clientCompanyName }}</div>
                        <small class="text-secondary">{{ contract.representativeName }}</small>
                    </td>
                    <td>{{ contract.campaign }}</td>
                    <td>
                        <span class="badge {{ contract.statusBadgeClass }}">{{ contract.statusLabel }}</span>
                        {% if contract.lastGeneratedAt %}
                            <div class="small text-secondary mt-1">{{ contract.lastGeneratedAt|date('d/m/Y H:i') }}</div>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a class="btn btn-outline-secondary" href="{{ path('app_generated_contract_show', {id: contract.id}) }}" title="Voir" aria-label="Voir">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a class="btn btn-outline-primary" href="{{ path('app_generated_contract_edit', {id: contract.id}) }}" title="Modifier" aria-label="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-outline-success" href="{{ path('app_generated_contract_download', {id: contract.id}) }}" title="Telecharger PDF" aria-label="Telecharger PDF">
                                <i class="bi bi-file-earmark-pdf"></i>
                            </a>
                            <button
                                class="btn btn-outline-danger"
                                type="button"
                                title="Supprimer"
                                aria-label="Supprimer"
                                data-confirm-url="{{ path('app_generated_contract_delete', {id: contract.id}) }}"
                                data-confirm-method="DELETE"
                                data-token="{{ csrf_token('delete_generated_contract_' ~ contract.id) }}"
                                data-confirm-message="Supprimer le contrat {{ contract.reference }} ?"
                            >
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center text-secondary py-5">Aucun contrat trouve.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {% if pagination.pages > 1 %}
        <div class="card-footer bg-white border-0 d-flex justify-content-center gap-2">
            <a class="btn btn-outline-secondary btn-sm {{ pagination.page <= 1 ? 'disabled' : '' }}" href="{{ path('app_generated_contract_index', filters|merge({page: pagination.page - 1})) }}">
                <i class="bi bi-chevron-left"></i>
            </a>
            <span class="btn btn-light btn-sm disabled">Page {{ pagination.page }} / {{ pagination.pages }}</span>
            <a class="btn btn-outline-secondary btn-sm {{ pagination.page >= pagination.pages ? 'disabled' : '' }}" href="{{ path('app_generated_contract_index', filters|merge({page: pagination.page + 1})) }}">
                <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
