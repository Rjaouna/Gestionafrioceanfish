{% extends 'base.html.twig' %}

{% block title %}{{ contract.reference }}{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
            <h1 class="h3 mb-0">{{ contract.reference }}</h1>
            <span class="badge {{ contract.statusBadgeClass }}">{{ contract.statusLabel }}</span>
        </div>
        <p class="text-secondary mb-0">{{ contract.contractTypeLabel }} - {{ contract.clientCompanyName }}</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="{{ path('app_generated_contract_index') }}">
            <i class="bi bi-arrow-left me-2"></i>Retour
        </a>
        <a class="btn btn-outline-primary" href="{{ path('app_generated_contract_edit', {id: contract.id}) }}">
            <i class="bi bi-pencil me-2"></i>Modifier
        </a>
        <a class="btn btn-primary" href="{{ path('app_generated_contract_download', {id: contract.id}) }}">
            <i class="bi bi-file-earmark-pdf me-2"></i>Telecharger PDF
        </a>
    </div>
</div>

<div class="row g-4 align-items-start">
    <div class="col-12 col-xl-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0">
                <h2 class="h5 mb-0">Informations du contrat</h2>
            </div>
            <div class="card-body">
                <dl class="row mb-0 g-3">
                    <dt class="col-5 text-secondary">Date</dt>
                    <dd class="col-7 text-end fw-semibold">{{ contract.contractDate|date('d/m/Y') }}</dd>
                    <dt class="col-5 text-secondary">Campagne</dt>
                    <dd class="col-7 text-end fw-semibold">{{ contract.campaign }}</dd>
                    <dt class="col-5 text-secondary">Ville</dt>
                    <dd class="col-7 text-end fw-semibold">{{ contract.signingCity }}</dd>
                    <dt class="col-5 text-secondary">Client</dt>
                    <dd class="col-7 text-end fw-semibold">{{ contract.clientCompanyName }}</dd>
                    <dt class="col-5 text-secondary">Representant</dt>
                    <dd class="col-7 text-end fw-semibold">{{ contract.representativeTitle }} {{ contract.representativeName }}</dd>
                    <dt class="col-5 text-secondary">CIN</dt>
                    <dd class="col-7 text-end fw-semibold">{{ contract.representativeIdNumber }}</dd>
                </dl>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="small text-secondary mb-1">Adresse client</div>
                <div class="fw-semibold mb-3">{{ contract.clientAddress|nl2br }}</div>
                <div class="small text-secondary mb-1">Cree par</div>
                <div>{{ contract.createdBy ? contract.createdBy.displayName : '-' }}</div>
                <div class="small text-secondary mt-3 mb-1">Derniere generation</div>
                <div>{{ contract.lastGeneratedAt ? contract.lastGeneratedAt|date('d/m/Y H:i') : 'Pas encore genere' }}</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Apercu PDF</h2>
                    <p class="text-secondary small mb-0">Document final avec en-tete et mentions legales.</p>
                </div>
                <a class="btn btn-outline-secondary btn-sm" href="{{ path('app_generated_contract_preview', {id: contract.id}) }}" target="_blank" rel="noopener">
                    <i class="bi bi-arrows-fullscreen me-2"></i>Ouvrir
                </a>
            </div>
            <iframe
                src="{{ path('app_generated_contract_preview', {id: contract.id}) }}"
                title="Apercu du contrat {{ contract.reference }}"
                style="width:100%;height:760px;border:0;background:#eef2f6;"
            ></iframe>
        </div>
    </div>
</div>
{% endblock %}
