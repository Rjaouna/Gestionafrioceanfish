{% extends 'base.html.twig' %}

{% block title %}Contrats de maintenance{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Contrats de maintenance</h1>
        <p class="text-secondary mb-0">{{ contracts|length }} contrat{{ contracts|length > 1 ? 's' : '' }} visible{{ contracts|length > 1 ? 's' : '' }}.</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createMaintenanceContractModal">
        <i class="bi bi-file-earmark-check me-2"></i>Nouveau contrat
    </button>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <div class="row align-items-center g-3">
            <div class="col-lg">
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-primary"></i>
                    </span>
                    <input
                        type="search"
                        class="form-control border-start-0"
                        placeholder="Rechercher par référence, intervenant, type, email ou téléphone..."
                        aria-label="Rechercher un contrat"
                        data-maintenance-search
                        data-maintenance-search-url="{{ path('app_maintenance_contract_search') }}"
                        data-maintenance-target="maintenanceContractGrid"
                        data-maintenance-status-selector="#maintenanceContractStatusFilter"
                    >
                    <button class="btn btn-outline-secondary d-none" type="button" data-maintenance-clear-search aria-label="Effacer la recherche">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
            <div class="col-lg-3">
                <select class="form-select form-select-lg" id="maintenanceContractStatusFilter" data-maintenance-filter>
                    <option value="">Tous les statuts</option>
                    <option value="brouillon" {{ selected_status == 'brouillon' ? 'selected' : '' }}>Brouillon</option>
                    <option value="actif" {{ selected_status == 'actif' ? 'selected' : '' }}>Actif</option>
                    <option value="suspendu" {{ selected_status == 'suspendu' ? 'selected' : '' }}>Suspendu</option>
                    <option value="expire" {{ selected_status == 'expire' ? 'selected' : '' }}>Expiré</option>
                    <option value="resilie" {{ selected_status == 'resilie' ? 'selected' : '' }}>Résilié</option>
                </select>
            </div>
            <div class="col-lg-auto">
                <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis px-3 py-2">
                    <i class="bi bi-file-earmark-check me-1"></i>
                    <span data-maintenance-search-count>{{ contracts|length }}</span>
                    <span data-maintenance-search-label>résultat{{ contracts|length > 1 ? 's' : '' }}</span>
                </span>
            </div>
        </div>
    </div>
</div>

<div id="maintenanceContractGrid">
    {% include 'maintenance/contract/_grid.html.twig' with {contracts: contracts} %}
</div>

<div class="modal fade" id="createMaintenanceContractModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
        <div class="modal-content">
            {% include 'maintenance/contract/_form_modal.html.twig' with {form: create_form, title: 'Créer un contrat de maintenance', submit_label: 'Créer', available_intervenants: available_intervenants, contract_type_suggestions: contract_type_suggestions} %}
        </div>
    </div>
</div>
{% endblock %}
