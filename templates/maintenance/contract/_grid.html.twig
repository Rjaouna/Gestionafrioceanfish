<div class="row g-4">
    {% for contract in contracts %}
        {% include 'maintenance/contract/_card.html.twig' with {contract: contract} %}
    {% else %}
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary-subtle text-secondary fs-2 empty-state-mark">
                        <i class="bi bi-file-earmark-check"></i>
                    </span>
                    <h2 class="h5 mt-3">Aucun contrat trouvé</h2>
                    <p class="text-secondary mb-0">Ajoutez un contrat ou ajustez votre recherche.</p>
                </div>
            </div>
        </div>
    {% endfor %}
</div>
