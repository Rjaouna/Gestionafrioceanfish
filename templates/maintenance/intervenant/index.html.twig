{% extends 'base.html.twig' %}

{% block title %}Intervenants{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Intervenants</h1>
        <p class="text-secondary mb-0">{{ intervenants|length }} intervenant{{ intervenants|length > 1 ? 's' : '' }} visible{{ intervenants|length > 1 ? 's' : '' }}.</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createIntervenantModal">
        <i class="bi bi-person-gear me-2"></i>Nouvel intervenant
    </button>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <div class="row align-items-center g-3">
            <div class="col-lg">
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-primary"></i>
                    </span>
                    <input
                        type="search"
                        class="form-control border-start-0"
                        placeholder="Rechercher par boite, nom, type, spécialité, email ou téléphone..."
                        aria-label="Rechercher un intervenant"
                        data-maintenance-search
                        data-maintenance-search-url="{{ path('app_maintenance_intervenant_search') }}"
                        data-maintenance-target="intervenantGrid"
                    >
                    <button class="btn btn-outline-secondary d-none" type="button" data-maintenance-clear-search aria-label="Effacer la recherche">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
            <div class="col-lg-auto">
                <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis px-3 py-2">
                    <i class="bi bi-person-gear me-1"></i>
                    <span data-maintenance-search-count>{{ intervenants|length }}</span>
                    <span data-maintenance-search-label>résultat{{ intervenants|length > 1 ? 's' : '' }}</span>
                </span>
            </div>
        </div>
    </div>
</div>

<div id="intervenantGrid">
    {% include 'maintenance/intervenant/_grid.html.twig' with {intervenants: intervenants, maintenance_share_counts: maintenance_share_counts} %}
</div>

<div class="modal fade" id="createIntervenantModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
        <div class="modal-content">
            {% include 'maintenance/intervenant/_form_modal.html.twig' with {form: create_form, title: 'Créer un intervenant', submit_label: 'Créer'} %}
        </div>
    </div>
</div>
{% endblock %}
