<form data-share-form action="{{ path('app_maintenance_share_save', {type: item_type, id: item_id}) }}" data-token="{{ csrf_token('share_maintenance_' ~ item_type ~ '_' ~ item_id) }}">
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">Partager "{{ item_title }}"</h2>
            <p class="text-secondary small mb-0">Choisissez les utilisateurs qui peuvent consulter {{ item_label }}.</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="input-group mb-4">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="search" class="form-control" placeholder="Rechercher un nom ou un e-mail" data-user-search>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Utilisateur</th>
                        <th>E-mail</th>
                        <th class="text-center">Acces autorise</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in share_matrix %}
                        <tr data-share-row data-search-value="{{ (row.user.displayName ~ ' ' ~ row.user.email)|lower }}">
                            <td class="fw-semibold">{{ row.user.displayName }}</td>
                            <td>{{ row.user.email }}</td>
                            <td class="text-center">
                                <input class="form-check-input fs-5" type="checkbox" data-share-view data-user-id="{{ row.user.id }}" {{ row.canView ? 'checked' : '' }} aria-label="Autoriser l'acces">
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="text-center text-secondary py-5">Aucun utilisateur actif disponible.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-people me-1"></i>Enregistrer les partages
        </button>
    </div>
</form>
