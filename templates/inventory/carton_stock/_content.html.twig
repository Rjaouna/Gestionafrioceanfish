<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Stocks cartons</h1>
        <p class="text-secondary mb-0">{{ stocks|length }} stock{{ stocks|length > 1 ? 's' : '' }} carton{{ stocks|length > 1 ? 's' : '' }} gere{{ stocks|length > 1 ? 's' : '' }} dans l inventaire.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-outline-primary" data-remote-modal="{{ path('app_inventory_carton_line_new') }}">
            <i class="bi bi-plus-circle me-2"></i>Ajouter une ligne
        </button>
        <button type="button" class="btn btn-primary" data-remote-modal="{{ path('app_inventory_carton_stock_new') }}">
            <i class="bi bi-folder-plus me-2"></i>Nouveau stock
        </button>
    </div>
</div>

{% if stocks is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-secondary py-5">
            <i class="bi bi-box-seam fs-1 d-block mb-2"></i>
            Aucun stock carton trouve.
        </div>
    </div>
{% endif %}

<div class="vstack gap-4">
    {% for stock in stocks %}
        {% set summary = summaries[stock.id]|default({quantity: 0, amount: 0, amountLabel: '0', lines: 0}) %}
        <section class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <h2 class="h5 mb-0">
                            <button type="button" class="btn btn-link p-0 h5 mb-0 text-decoration-none text-start" data-remote-modal="{{ path('app_inventory_carton_stock_quick_form', {id: stock.id, field: 'name'}) }}" title="Modifier le nom du stock">
                                {{ stock.name }}
                            </button>
                        </h2>
                        {% if not stock.active %}
                            <span class="badge text-bg-secondary">Inactif</span>
                        {% endif %}
                        <button type="button" class="btn btn-sm btn-outline-secondary py-0" data-remote-modal="{{ path('app_inventory_carton_stock_quick_form', {id: stock.id, field: 'isActive'}) }}" title="Changer le statut actif">
                            <i class="bi bi-toggle-on"></i>
                        </button>
                    </div>
                    <div class="text-secondary small">
                        <button type="button" class="btn btn-link btn-sm p-0 text-secondary text-decoration-none" data-remote-modal="{{ path('app_inventory_carton_stock_quick_form', {id: stock.id, field: 'sourceSheet'}) }}" title="Modifier la source">
                            {{ stock.sourceSheet ?: 'Source non renseignee' }}
                        </button>
                        <span> - </span>
                        <button type="button" class="btn btn-link btn-sm p-0 text-secondary text-decoration-none text-start" data-remote-modal="{{ path('app_inventory_carton_stock_quick_form', {id: stock.id, field: 'description'}) }}" title="Modifier la description">
                            {{ stock.description ?: 'Description non renseignee' }}
                        </button>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2 align-items-center justify-content-end">
                    <span class="badge text-bg-light border">{{ summary.lines }} ligne{{ summary.lines > 1 ? 's' : '' }}</span>
                    <span class="badge text-bg-light border">{{ summary.quantity }} unites</span>
                    {% if summary.amount > 0 %}
                        <span class="badge text-bg-light border">{{ summary.amountLabel }} DH</span>
                    {% endif %}
                    <button type="button" class="btn btn-sm btn-outline-primary" data-remote-modal="{{ path('app_inventory_carton_line_new', {stock: stock.id}) }}">
                        <i class="bi bi-plus-lg me-1"></i>Ligne
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-remote-modal="{{ path('app_inventory_carton_stock_form', {id: stock.id}) }}" title="Modifier">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button
                        type="button"
                        class="btn btn-sm btn-outline-danger"
                        data-confirm-url="{{ path('app_inventory_carton_stock_delete', {id: stock.id}) }}"
                        data-confirm-method="DELETE"
                        data-token="{{ csrf_token('delete_inventory_carton_stock_' ~ stock.id) }}"
                        data-confirm-message="Supprimer ce stock carton et toutes ses lignes ?"
                        title="Supprimer"
                    >
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Groupe</th>
                            <th>Reference</th>
                            <th>Type</th>
                            <th class="text-end">Quantite</th>
                            <th class="text-end">Prix</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for line in stock.lines %}
                            <tr class="{{ line.summary ? 'table-light fw-semibold' : '' }}">
                                <td>
                                    <button type="button" class="btn btn-link btn-sm p-0 text-start text-decoration-none" data-remote-modal="{{ path('app_inventory_carton_line_quick_form', {id: line.id, field: 'groupName'}) }}" title="Modifier le groupe">
                                        {{ line.groupName ?: 'General' }}
                                    </button>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-link btn-sm p-0 text-start text-decoration-none fw-semibold" data-remote-modal="{{ path('app_inventory_carton_line_quick_form', {id: line.id, field: 'reference'}) }}" title="Modifier la reference">
                                        {{ line.reference }}
                                    </button>
                                    <div>
                                        <button type="button" class="btn btn-link btn-sm p-0 text-start text-secondary text-decoration-none" data-remote-modal="{{ path('app_inventory_carton_line_quick_form', {id: line.id, field: 'notes'}) }}" title="Modifier les notes">
                                            {{ line.notes ?: 'Aucune note' }}
                                        </button>
                                    </div>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" data-remote-modal="{{ path('app_inventory_carton_line_quick_form', {id: line.id, field: 'lineType'}) }}" title="Modifier le type">
                                        <span class="badge {{ line.summary ? 'text-bg-secondary' : (line.transport ? 'text-bg-warning' : 'text-bg-primary') }}">
                                            {{ line.lineTypeLabel }}
                                        </span>
                                    </button>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" data-remote-modal="{{ path('app_inventory_carton_line_quick_form', {id: line.id, field: 'quantity'}) }}" title="Modifier la quantite">
                                        {{ line.quantity is not null ? line.quantity : '-' }}
                                    </button>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" data-remote-modal="{{ path('app_inventory_carton_line_quick_form', {id: line.id, field: 'unitPrice'}) }}" title="Modifier le prix unitaire">
                                        {{ line.unitPriceLabel ? line.unitPriceLabel ~ ' DH' : '-' }}
                                    </button>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" data-remote-modal="{{ path('app_inventory_carton_line_quick_form', {id: line.id, field: 'totalAmount'}) }}" title="Modifier le total">
                                        {{ line.totalAmountLabel ? line.totalAmountLabel ~ ' DH' : '-' }}
                                    </button>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <button type="button" class="btn btn-outline-primary" data-remote-modal="{{ path('app_inventory_carton_line_form', {id: line.id}) }}" title="Modifier">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button
                                            type="button"
                                            class="btn btn-outline-danger"
                                            data-confirm-url="{{ path('app_inventory_carton_line_delete', {id: line.id}) }}"
                                            data-confirm-method="DELETE"
                                            data-token="{{ csrf_token('delete_inventory_carton_line_' ~ line.id) }}"
                                            data-confirm-message="Supprimer cette ligne de stock ?"
                                            title="Supprimer"
                                        >
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center text-secondary py-4">Aucune ligne dans ce stock.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% endfor %}
</div>
