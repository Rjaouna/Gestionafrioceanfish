{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <h2 class="modal-title fs-5">{{ title }}</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.stock) }}</div>
            <div class="col-md-3">{{ form_row(form.lineType) }}</div>
            <div class="col-md-3">{{ form_row(form.quantity) }}</div>
            <div class="col-md-6">{{ form_row(form.groupName) }}</div>
            <div class="col-md-6">{{ form_row(form.reference) }}</div>
            <div class="col-md-6">{{ form_row(form.unitPrice) }}</div>
            <div class="col-md-6">{{ form_row(form.totalAmount) }}</div>
            <div class="col-12">{{ form_row(form.notes) }}</div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>{{ submit_label }}
        </button>
    </div>
{{ form_end(form) }}
