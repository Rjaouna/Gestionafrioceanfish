{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <h2 class="modal-title fs-5">{{ title }}</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        {% if source_movement|default(null) %}
            <div class="alert alert-warning">
                Cette correction créera un nouveau mouvement sans modifier l historique du mouvement #{{ source_movement.id }}.
                Vérifiez le type et la quantité proposés avant de valider.
            </div>
        {% else %}
            <div class="alert alert-info">
                Les mouvements conservent l historique. Pour corriger une quantite apres inventaire physique, utilisez le type Ajustement.
            </div>
        {% endif %}
        <div class="row g-3">
            <div class="col-md-8">{{ form_row(form.item) }}</div>
            <div class="col-md-4">{{ form_row(form.movementType) }}</div>
            <div class="col-md-4">{{ form_row(form.quantity) }}</div>
            <div class="col-md-4">{{ form_row(form.toSite) }}</div>
            <div class="col-md-4">{{ form_row(form.toLocation) }}</div>
            <div class="col-md-6">{{ form_row(form.responsibleUser) }}</div>
            <div class="col-md-6">{{ form_row(form.movementDate) }}</div>
            <div class="col-12">{{ form_row(form.reason) }}</div>
            <div class="col-12">{{ form_row(form.notes) }}</div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>{{ submit_label }}</button>
    </div>
{{ form_end(form) }}
