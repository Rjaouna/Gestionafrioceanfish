<form method="post" action="{{ path('app_inventory_request_validate', {id: request.id}) }}" data-ajax-form>
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">Valider la demande #{{ request.id }}</h2>
            <div class="small text-secondary">{{ request.typeLabel }} - {{ request.item.reference }} - {{ request.item.name }}</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <input type="hidden" name="token" value="{{ csrf_token('validate_inventory_request_' ~ request.id) }}">

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="small text-secondary">Quantité actuelle</div>
                    <div class="fw-semibold">{{ request.item.quantity }} {{ request.item.unit }}</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="small text-secondary">Site actuel</div>
                    <div class="fw-semibold">{{ request.item.site.name|default('Non renseigné') }}</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="small text-secondary">Emplacement actuel</div>
                    <div class="fw-semibold">{{ request.item.location ? request.item.location.name : 'Non renseigné' }}</div>
                </div>
            </div>
        </div>

        {% if request.transfer %}
            {% set will_split = request.requestedQuantity < request.item.quantity %}
            <div class="alert {{ will_split ? 'alert-warning' : 'alert-info' }}">
                {% if will_split %}
                    Validation partielle : la ligne actuelle gardera {{ request.item.quantity - request.requestedQuantity }} {{ request.item.unit }}
                    et une nouvelle ligne sera créée avec {{ request.requestedQuantity }} {{ request.item.unit }} à destination.
                {% else %}
                    Validation complète : le site et l’emplacement du matériel seront mis à jour sur la ligne actuelle.
                {% endif %}
            </div>
            <dl class="row mb-0">
                <dt class="col-sm-4">Quantité à transporter</dt>
                <dd class="col-sm-8">{{ request.requestedQuantity }} {{ request.item.unit }}</dd>
                <dt class="col-sm-4">Départ demandé</dt>
                <dd class="col-sm-8">{{ request.fromLocation ? request.fromLocation.displayName : request.fromSite.name|default('Non renseigné') }}</dd>
                <dt class="col-sm-4">Destination</dt>
                <dd class="col-sm-8">{{ request.toLocation ? request.toLocation.displayName : request.toSite.name|default('Non renseigné') }}</dd>
            </dl>
        {% else %}
            <div class="alert alert-info">
                Entrez la quantité constatée. Si elle est différente de la quantité actuelle, un mouvement d’ajustement sera créé automatiquement.
            </div>
            <label class="form-label fw-semibold" for="inventory-counted-quantity">Quantité constatée</label>
            <input
                id="inventory-counted-quantity"
                class="form-control"
                type="number"
                name="countedQuantity"
                min="0"
                value="{{ request.countedQuantity is not null ? request.countedQuantity : request.item.quantity }}"
                required
                autofocus
            >
        {% endif %}

        {% if request.notes %}
            <div class="border rounded p-3 mt-3">
                <div class="small text-secondary">Commentaire de la demande</div>
                <div>{{ request.notes }}</div>
            </div>
        {% endif %}

        <label class="form-label fw-semibold mt-3" for="inventory-resolution-note">Note de validation</label>
        <textarea id="inventory-resolution-note" class="form-control" name="resolutionNote" rows="3" placeholder="Facultatif"></textarea>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check2-circle me-1"></i>Valider la demande
        </button>
    </div>
</form>
