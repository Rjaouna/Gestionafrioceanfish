{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <h2 class="modal-title fs-5">{{ title }}</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <datalist id="inventory-category-suggestions">
            {% for category in category_suggestions|default([]) %}
                <option value="{{ category }}"></option>
            {% endfor %}
        </datalist>
        <div class="alert alert-light border d-flex justify-content-between align-items-center">
            <div>
                <span class="text-secondary small d-block">Reference</span>
                <strong>{{ form.vars.data.reference ?: 'Generee automatiquement' }}</strong>
            </div>
            <i class="bi bi-lock text-secondary"></i>
        </div>
        <div class="vstack gap-4">
            <section class="border rounded p-3">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-clipboard-data text-primary"></i>
                    <h3 class="h6 mb-0">Informations principales</h3>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.name) }}</div>
                    <div class="col-md-3">{{ form_row(form.categoryName) }}</div>
                    <div class="col-md-3">{{ form_row(form.quantity) }}</div>
                    <div class="col-md-3">{{ form_row(form.availableQuantity) }}</div>
                    <div class="col-md-3">{{ form_row(form.unit) }}</div>
                    <div class="col-md-3">{{ form_row(form.dimensions) }}</div>
                    <div class="col-md-3">{{ form_row(form.color) }}</div>
                    <div class="col-md-6">{{ form_row(form.site) }}</div>
                    <div class="col-md-6">{{ form_row(form.location) }}</div>
                    <div class="col-12">{{ form_row(form.logisticsStatus) }}</div>
                </div>
            </section>

            <section class="border rounded p-3">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-info-circle text-primary"></i>
                    <h3 class="h6 mb-0">Identification et etat</h3>
                </div>
                <div class="row g-3">
                    <div class="col-md-3">{{ form_row(form.status) }}</div>
                    <div class="col-md-3">{{ form_row(form.condition) }}</div>
                    <div class="col-md-3">{{ form_row(form.brand) }}</div>
                    <div class="col-md-3">{{ form_row(form.model) }}</div>
                    <div class="col-md-4">{{ form_row(form.serialNumber) }}</div>
                    <div class="col-md-4">{{ form_row(form.responsibleUser) }}</div>
                    <div class="col-md-4">{{ form_row(form.acquisitionValue) }}</div>
                </div>
            </section>

            <section class="border rounded p-3">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-three-dots text-primary"></i>
                    <h3 class="h6 mb-0">Informations optionnelles</h3>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">{{ form_row(form.ownershipType) }}</div>
                    <div class="col-md-4">{{ form_row(form.ownerName) }}</div>
                    <div class="col-md-4">{{ form_row(form.acquisitionDate) }}</div>
                    <div class="col-md-4">{{ form_row(form.entryDate) }}</div>
                    <div class="col-md-4">{{ form_row(form.file) }}</div>
                    <div class="col-md-4">{{ form_row(form.attachmentType) }}</div>
                    <div class="col-md-6">{{ form_row(form.description) }}</div>
                    <div class="col-md-6">{{ form_row(form.notes) }}</div>
                </div>
            </section>
        </div>
        {% if item and item.attachments|length > 0 %}
            <div class="border-top mt-4 pt-3">
                <h3 class="h6">Pieces jointes</h3>
                <div class="list-group list-group-flush">
                    {% for attachment in item.attachments %}
                        <div class="list-group-item px-0 d-flex justify-content-between align-items-center gap-3">
                            <div class="text-truncate">
                                <i class="bi {{ attachment.image ? 'bi-file-earmark-image' : 'bi-file-earmark-text' }} me-2"></i>
                                <a href="{{ path('app_inventory_attachment_view', {id: attachment.id}) }}" target="_blank" rel="noopener">{{ attachment.originalFileName }}</a>
                                <span class="text-secondary small ms-2">{{ attachment.typeLabel }}</span>
                            </div>
                            <button
                                type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-confirm-url="{{ path('app_inventory_attachment_delete', {id: attachment.id}) }}"
                                data-confirm-method="DELETE"
                                data-token="{{ csrf_token('delete_inventory_attachment_' ~ attachment.id) }}"
                                data-confirm-message="Supprimer cette piece jointe ?"
                            >
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>{{ submit_label }}
        </button>
    </div>
{{ form_end(form) }}
