<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Référence</th>
                    <th>Matériel</th>
                    <th>Suivi</th>
                    <th>Site / emplacement</th>
                    <th class="text-end">Quantités</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for item in result.items %}
                    <tr class="inventory-logistics-row" style="--inventory-logistics-color: {{ item.logisticsColor }}">
                        <td>
                            <span class="inventory-reference-badge" style="--inventory-logistics-color: {{ item.logisticsColor }}">{{ item.reference }}</span>
                            {% if not item.isActive %}
                                <span class="badge text-bg-secondary ms-1">Archivé</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="fw-semibold">{{ item.name }}</div>
                            <div class="small text-secondary">
                                {{ item.category.name|default('Non classé') }}
                                {% if item.dimensions %} · {{ item.dimensions }}{% endif %}
                            </div>
                        </td>
                        <td>
                            {% if is_granted('INVENTORY_ITEM_EDIT', item) %}
                                <button
                                    type="button"
                                    class="btn btn-sm inventory-logistics-badge"
                                    style="--inventory-logistics-color: {{ item.logisticsColor }}"
                                    data-remote-modal="{{ path('app_inventory_item_quick_form', {id: item.id, field: 'logistics'}) }}"
                                    title="Changer le suivi logistique"
                                >
                                    <span class="inventory-logistics-dot"></span>{{ item.logisticsStatusLabel }}
                                </button>
                            {% else %}
                                <span class="inventory-logistics-badge" style="--inventory-logistics-color: {{ item.logisticsColor }}">
                                    <span class="inventory-logistics-dot"></span>{{ item.logisticsStatusLabel }}
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {% if is_granted('INVENTORY_ITEM_EDIT', item) %}
                                <button type="button" class="btn btn-link btn-sm p-0 text-start text-decoration-none" data-remote-modal="{{ path('app_inventory_item_quick_form', {id: item.id, field: 'site'}) }}" title="Demander un changement de site">
                                    <i class="bi bi-building me-1"></i>{{ item.site.name|default('Site non renseigné') }}
                                </button>
                                <div>
                                    <button type="button" class="btn btn-link btn-sm p-0 text-start text-secondary text-decoration-none" data-remote-modal="{{ path('app_inventory_item_quick_form', {id: item.id, field: 'location'}) }}" title="Demander un changement d’emplacement">
                                        <i class="bi bi-geo-alt me-1"></i>{{ item.location ? item.location.name : 'Emplacement non renseigné' }}
                                    </button>
                                </div>
                            {% else %}
                                <div><i class="bi bi-building me-1"></i>{{ item.site.name|default('Site non renseigné') }}</div>
                                <div class="small text-secondary"><i class="bi bi-geo-alt me-1"></i>{{ item.location ? item.location.name : 'Emplacement non renseigné' }}</div>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            {% if is_granted('INVENTORY_ITEM_EDIT', item) %}
                                <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" data-remote-modal="{{ path('app_inventory_item_quick_form', {id: item.id, field: 'quantity'}) }}" title="Ajuster la quantité">
                                    <span class="fw-semibold">{{ item.availableQuantity }}</span>
                                    <span class="text-secondary">/ {{ item.quantity }} {{ item.unit }}</span>
                                    <i class="bi bi-pencil-square ms-1"></i>
                                </button>
                            {% else %}
                                <span class="fw-semibold">{{ item.availableQuantity }}</span>
                                <span class="text-secondary">/ {{ item.quantity }} {{ item.unit }}</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button type="button" class="btn btn-outline-secondary" data-remote-modal="{{ path('app_inventory_item_view', {id: item.id}) }}" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" data-remote-modal="{{ path('app_inventory_item_movement_history', {id: item.id}) }}" title="Historique des mouvements" aria-label="Historique des mouvements">
                                    <i class="bi bi-clock-history"></i>
                                </button>
                                {% if is_granted('INVENTORY_ITEM_EDIT', item) %}
                                    <button type="button" class="btn btn-outline-primary" data-remote-modal="{{ path('app_inventory_item_quick_form', {id: item.id, field: 'move'}) }}" title="Demander un transport">
                                        <i class="bi bi-truck"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-info" data-remote-modal="{{ path('app_inventory_item_quick_form', {id: item.id, field: 'inventory'}) }}" title="Demander un inventaire">
                                        <i class="bi bi-clipboard-check"></i>
                                    </button>
                                {% endif %}
                                <button type="button" class="btn btn-outline-success" data-remote-modal="{{ path('app_inventory_item_whatsapp_form', {id: item.id}) }}" title="Envoyer une consigne WhatsApp">
                                    <i class="bi bi-whatsapp"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-5">
                            <i class="bi bi-box-seam fs-1 d-block mb-2"></i>
                            Aucun matériel trouvé.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% if result.pages > 1 %}
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <span class="small text-secondary">Page {{ result.page }} / {{ result.pages }}</span>
            <div class="btn-group btn-group-sm">
                <a class="btn btn-outline-secondary {{ result.page <= 1 ? 'disabled' : '' }}" href="{{ path('app_inventory_item_index', filters|merge({page: result.page - 1})) }}" data-ajax-region-page="inventory-items" data-page="{{ result.page - 1 }}">Précédent</a>
                <a class="btn btn-outline-secondary {{ result.page >= result.pages ? 'disabled' : '' }}" href="{{ path('app_inventory_item_index', filters|merge({page: result.page + 1})) }}" data-ajax-region-page="inventory-items" data-page="{{ result.page + 1 }}">Suivant</a>
            </div>
        </div>
    {% endif %}
</div>
