<div class="modal-header">
    <div>
        <h2 class="modal-title fs-5">Historique des mouvements</h2>
        <div class="small text-secondary">{{ item.reference }} - {{ item.name }}</div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
</div>
<div class="modal-body p-0">
    {% if movements is empty %}
        <div class="text-center text-secondary py-5 px-3">
            <i class="bi bi-clock-history fs-1 d-block mb-2"></i>
            Aucun mouvement enregistre pour ce materiel.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th class="text-end">Quantite</th>
                        <th>Origine</th>
                        <th>Destination</th>
                        <th>Motif</th>
                        <th>Enregistre par</th>
                    </tr>
                </thead>
                <tbody>
                    {% for movement in movements %}
                        <tr>
                            <td class="text-nowrap">
                                <div>{{ movement.movementDate|date('d/m/Y') }}</div>
                                <div class="small text-secondary">{{ movement.movementDate|date('H:i') }}</div>
                            </td>
                            <td><span class="badge text-bg-light border">{{ movement.typeLabel }}</span></td>
                            <td class="text-end fw-semibold">{{ movement.quantity }}</td>
                            <td>{{ movement.fromLocation ? movement.fromLocation.displayName : movement.fromSite.name|default('Non renseignee') }}</td>
                            <td>{{ movement.toLocation ? movement.toLocation.displayName : movement.toSite.name|default('Inchangee') }}</td>
                            <td>
                                <div>{{ movement.reason ?: 'Sans motif' }}</div>
                                {% if movement.notes %}
                                    <div class="small text-secondary">{{ movement.notes }}</div>
                                {% endif %}
                            </td>
                            <td>{{ movement.createdBy ? movement.createdBy.displayName : 'Non renseigne' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
</div>
