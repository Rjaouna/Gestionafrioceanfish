{% extends 'base.html.twig' %}

{% block title %}{{ item.name }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">{{ item.name }}</h1>
        <p class="text-secondary mb-0">{{ item.reference }}</p>
    </div>
    <a class="btn btn-outline-secondary" href="{{ path('app_inventory_item_index') }}">
        <i class="bi bi-arrow-left me-2"></i>Retour
    </a>
</div>
<div class="card border-0 shadow-sm">
    {% include 'inventory/item/_details_modal.html.twig' with {item: item} %}
</div>
{% endblock %}
