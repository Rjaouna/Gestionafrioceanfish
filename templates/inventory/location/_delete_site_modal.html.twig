<form method="post" action="{{ path('app_inventory_site_delete', {id: site.id}) }}" data-ajax-form>
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">Supprimer le site {{ site.name }}</h2>
            <div class="small text-secondary">{{ item_count }} materiel{{ item_count > 1 ? 's' : '' }} attache{{ item_count > 1 ? 's' : '' }}</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <input type="hidden" name="token" value="{{ csrf_token('delete_inventory_site_' ~ site.id) }}">

        <div class="alert {{ item_count > 0 ? 'alert-warning' : 'alert-danger' }}">
            <div class="fw-semibold">Cette action supprimera aussi les emplacements de ce site.</div>
            {% if item_count > 0 %}
                Le site est utilise par du materiel. Choisissez un site de destination, ou laissez vide pour detacher le materiel du site.
            {% else %}
                Aucun materiel n est attache a ce site, il peut etre supprime directement.
            {% endif %}
        </div>

        {% if item_count > 0 %}
            <label class="form-label fw-semibold" for="inventory-site-destination">Rattacher le materiel vers</label>
            <select id="inventory-site-destination" class="form-select" name="destinationSite">
                <option value="">Detacher le materiel du site</option>
                {% for destination in destination_sites %}
                    <option value="{{ destination.id }}">{{ destination.name }}</option>
                {% endfor %}
            </select>

            <div class="border rounded p-3 mt-3">
                <div class="fw-semibold mb-2">Materiel concerne</div>
                <div class="list-group list-group-flush">
                    {% for item in items %}
                        <div class="list-group-item px-0 d-flex justify-content-between gap-3">
                            <span>{{ item.name }}</span>
                            <span class="text-secondary small">{{ item.reference }}</span>
                        </div>
                    {% endfor %}
                </div>
                {% if item_count > items|length %}
                    <div class="small text-secondary mt-2">+ {{ item_count - items|length }} autre{{ item_count - items|length > 1 ? 's' : '' }} materiel{{ item_count - items|length > 1 ? 's' : '' }}.</div>
                {% endif %}
            </div>
        {% endif %}
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>Supprimer le site
        </button>
    </div>
</form>
