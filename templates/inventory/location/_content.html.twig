<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Sites et emplacements</h1>
        <p class="text-secondary mb-0">Organisation physique du materiel.</p>
    </div>
    <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#createInventorySiteModal">
        <i class="bi bi-building-add me-2"></i>Nouveau site
    </button>
</div>

<div class="vstack gap-4">
    {% for site in sites %}
        {% set site_materials = site_item_counts[site.id]|default(0) %}
        <section class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <h2 class="h5 mb-0">{{ site.name }}</h2>
                        <span class="badge text-bg-primary">{{ site_materials }} materiel{{ site_materials > 1 ? 's' : '' }}</span>
                        <span class="badge text-bg-light border">{{ site.locations|length }} emplacement{{ site.locations|length > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="text-secondary small mt-1">{{ site.description ?: 'Aucune description' }}</div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="btn btn-sm btn-primary" data-remote-modal="{{ path('app_inventory_location_new', {site: site.id}) }}">
                        <i class="bi bi-pin-map me-1"></i>Nouvel emplacement
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger" data-remote-modal="{{ path('app_inventory_site_delete_form', {id: site.id}) }}">
                        <i class="bi bi-trash me-1"></i>Supprimer
                    </button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Emplacement</th>
                            <th>Description</th>
                            <th class="text-end">Materiel</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for location in site.locations %}
                            {% set location_materials = location_item_counts[location.id]|default(0) %}
                            <tr>
                                <td class="fw-semibold">{{ location.name }}</td>
                                <td class="text-secondary">{{ location.description ?: 'Aucune description' }}</td>
                                <td class="text-end">
                                    <span class="badge {{ location_materials > 0 ? 'text-bg-primary' : 'text-bg-light border' }}">
                                        {{ location_materials }} materiel{{ location_materials > 1 ? 's' : '' }}
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-remote-modal="{{ path('app_inventory_location_delete_form', {id: location.id}) }}" title="Supprimer l emplacement">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-secondary py-4">
                                    Aucun emplacement pour ce site.
                                    <button type="button" class="btn btn-link btn-sm p-0 ms-1" data-remote-modal="{{ path('app_inventory_location_new', {site: site.id}) }}">En ajouter un</button>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% else %}
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-secondary py-5">
                <i class="bi bi-building fs-1 d-block mb-2"></i>
                Aucun site pour le moment.
            </div>
        </div>
    {% endfor %}
</div>

<div class="modal fade" id="createInventorySiteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            {{ form_start(site_form, {attr: {'data-ajax-form': 'true'}}) }}
                <div class="modal-header"><h2 class="modal-title fs-5">Nouveau site</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button></div>
                <div class="modal-body">{{ form_widget(site_form) }}</div>
                <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button><button type="submit" class="btn btn-primary">Creer</button></div>
            {{ form_end(site_form) }}
        </div>
    </div>
</div>
