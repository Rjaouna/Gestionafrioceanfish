{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">Nouvel emplacement</h2>
            {% if site %}
                <div class="small text-secondary">Site : {{ site.name }}</div>
            {% endif %}
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        {% if site %}
            <div class="alert alert-light border">
                L’emplacement sera créé directement dans <strong>{{ site.name }}</strong>.
            </div>
        {% endif %}
        {{ form_widget(form) }}
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>Créer
        </button>
    </div>
{{ form_end(form) }}
