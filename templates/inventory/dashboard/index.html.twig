{% extends 'base.html.twig' %}

{% block title %}Inventaire du matériel{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Inventaire du matériel</h1>
        <p class="text-secondary mb-0">Vue d’ensemble du parc, des mouvements et des contrôles physiques.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-primary" href="{{ path('app_inventory_request_index') }}">
            <i class="bi bi-inbox me-2"></i>Demandes à valider
        </a>
        <a class="btn btn-outline-primary" href="{{ path('app_inventory_carton_stock_index') }}">
            <i class="bi bi-boxes me-2"></i>Stocks cartons
        </a>
        <a class="btn btn-outline-primary" href="{{ path('app_inventory_consumable_stock_index') }}">
            <i class="bi bi-basket me-2"></i>Stock consommables
        </a>
        <a class="btn btn-primary" href="{{ path('app_inventory_item_new') }}">
            <i class="bi bi-plus-circle me-2"></i>Ajouter un matériel
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    {% for card in dashboard.cards %}
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-{{ card.tone }}-subtle text-{{ card.tone }} fs-4" style="width: 48px; height: 48px;">
                        <i class="bi {{ card.icon }}"></i>
                    </span>
                    <div>
                        <div class="text-secondary small">{{ card.label }}</div>
                        <div class="h3 mb-0">{{ card.value }}</div>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                {% include 'components/_dashboard_chart.html.twig' with {
                    title: 'Répartition par statut',
                    chart: dashboard.status_chart,
                    chart_type: 'bars',
                    tone: 'primary'
                } %}
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                {% include 'components/_dashboard_chart.html.twig' with {
                    title: 'Répartition par catégorie',
                    chart: dashboard.category_chart,
                    chart_type: 'bars',
                    tone: 'success'
                } %}
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="h5 mb-0">Derniers materiels ajoutes</h2>
                    <p class="text-secondary small mb-0">Elements les plus recents du parc visible.</p>
                </div>
                <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_inventory_item_index') }}">Tout voir</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Référence</th>
                            <th>Matériel</th>
                            <th>Statut</th>
                            <th>Site</th>
                            <th class="text-end">Dispo</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in dashboard.recent_items %}
                            <tr>
                                <td class="text-secondary small">{{ item.reference }}</td>
                                <td>
                                    <div class="fw-semibold">{{ item.name }}</div>
                                    <div class="small text-secondary">{% if item.dimensions %}{{ item.dimensions }}{% endif %}{% if item.color %}{{ item.dimensions ? ' · ' : '' }}{{ item.color }}{% endif %}</div>
                                </td>
                                <td><span class="badge text-bg-light border">{{ item.statusLabel }}</span></td>
                                <td class="text-secondary">{{ item.location ? item.location.displayName : item.site.name|default('Non renseigné') }}</td>
                                <td class="text-end">{{ item.availableQuantity }}/{{ item.quantity }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="text-center text-secondary py-4">Aucun matériel pour le moment.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="h5 mb-0">Mouvements recents</h2>
                    <p class="text-secondary small mb-0">Historique operationnel du parc.</p>
                </div>
            </div>
            <div class="list-group list-group-flush">
                {% for movement in dashboard.recent_movements %}
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between gap-3">
                            <div>
                                <div class="fw-semibold">{{ movement.typeLabel }} - {{ movement.item.name }}</div>
                                <div class="small text-secondary">{{ movement.item.reference }} · {{ movement.reason ?: 'Sans motif' }}</div>
                            </div>
                            <div class="text-end small text-secondary">{{ movement.movementDate|date('d/m/Y H:i') }}</div>
                        </div>
                    </div>
                {% else %}
                    <div class="list-group-item text-center text-secondary py-4">Aucun mouvement enregistré.</div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
