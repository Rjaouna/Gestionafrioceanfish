<form method="post" action="{{ path('app_inventory_consumable_stock_movement_delete', {id: movement.id}) }}" data-ajax-form>
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">
                {{ movement.movementType == 'inventory' ? "Supprimer l'inventaire" : 'Supprimer le mouvement' }}
            </h2>
            <div class="small text-secondary">{{ item.name }} - {{ movement.movementDate|date('d/m/Y H:i') }}</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <input type="hidden" name="token" value="{{ csrf_token('delete_consumable_stock_movement_' ~ movement.id) }}">

        <div class="alert alert-warning">
            Le mouvement sera supprime et le stock de l'article sera recalcule automatiquement.
        </div>

        <dl class="row small mb-3">
            <dt class="col-sm-4 text-secondary">Type</dt>
            <dd class="col-sm-8 fw-semibold">{{ movement.movementTypeLabel }}</dd>
            <dt class="col-sm-4 text-secondary">Quantite</dt>
            <dd class="col-sm-8 fw-semibold">{{ movement.quantityDisplay }} {{ item.unitLabel }}</dd>
            <dt class="col-sm-4 text-secondary">Avant / apres</dt>
            <dd class="col-sm-8 fw-semibold">{{ movement.previousQuantityDisplay }} -> {{ movement.newQuantityDisplay }} {{ item.unitLabel }}</dd>
            {% if movement.reason %}
                <dt class="col-sm-4 text-secondary">Motif</dt>
                <dd class="col-sm-8">{{ movement.reason }}</dd>
            {% endif %}
        </dl>

        <label class="form-label fw-semibold" for="delete-consumable-movement-password">Mot de passe de confirmation</label>
        <input id="delete-consumable-movement-password" class="form-control" type="password" name="confirmationPassword" required autocomplete="off">
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>Supprimer
        </button>
    </div>
</form>
