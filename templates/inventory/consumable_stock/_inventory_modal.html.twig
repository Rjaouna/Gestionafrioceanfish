{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">Inventaire physique</h2>
            <p class="text-secondary small mb-0">{{ item.name }} · stock systeme {{ item.quantityDisplay }} {{ item.unitLabel }}</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-info">Saisissez la quantite comptee. Le systeme creera un mouvement d'ecart si besoin.</div>
        <div class="row g-3">
            <div class="col-md-5">{{ form_row(form.countedQuantity) }}</div>
            <div class="col-md-7">{{ form_row(form.movementDate) }}</div>
            <div class="col-12">{{ form_row(form.reason) }}</div>
        </div>
        {{ form_rest(form) }}
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-clipboard-check me-1"></i>Valider le comptage</button>
    </div>
{{ form_end(form) }}
