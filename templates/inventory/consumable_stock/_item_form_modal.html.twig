{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <h2 class="modal-title fs-5">{{ title }}</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="row g-3">
            {% if form.reference is defined %}
                <div class="col-md-4">{{ form_row(form.reference) }}</div>
            {% endif %}
            <div class="col-md-8">{{ form_row(form.name) }}</div>
            <div class="col-md-4">{{ form_row(form.category) }}</div>
            <div class="col-md-4">{{ form_row(form.unit) }}</div>
            {% if form.initialQuantity is defined %}
                <div class="col-md-4">{{ form_row(form.initialQuantity) }}</div>
            {% endif %}
            <div class="col-md-4">{{ form_row(form.minimumQuantity) }}</div>
            <div class="col-md-4">{{ form_row(form.storageLocation) }}</div>
            <div class="col-md-4">{{ form_row(form.preferredSupplier) }}</div>
            <div class="col-md-4">{{ form_row(form.supplierPhone) }}</div>
            <div class="col-12">{{ form_row(form.notes) }}</div>
            <div class="col-12">{{ form_row(form.isActive) }}</div>
        </div>
        {{ form_rest(form) }}
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>{{ submit_label }}</button>
    </div>
{{ form_end(form) }}
