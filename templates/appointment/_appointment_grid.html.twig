<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Reference</th>
                    <th>Rendez-vous</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Statut</th>
                    <th>Priorite</th>
                    <th>Participants</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for appointment in appointments %}
                    {% include 'appointment/_appointment_row.html.twig' with {appointment: appointment} %}
                {% else %}
                    <tr>
                        <td colspan="8">
                            <div class="dashboard-empty">
                                <div>
                                    <i class="bi bi-calendar-x"></i>
                                    <p class="mb-0 mt-2">Aucun rendez-vous trouve.</p>
                                </div>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% if pagination.pages|default(1) > 1 %}
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <button class="btn btn-outline-secondary btn-sm" type="button" data-appointment-page="{{ pagination.page - 1 }}" {{ pagination.page <= 1 ? 'disabled' : '' }}>
                <i class="bi bi-chevron-left me-1"></i>Precedent
            </button>
            <span class="small text-secondary">Page {{ pagination.page }} / {{ pagination.pages }}</span>
            <button class="btn btn-outline-secondary btn-sm" type="button" data-appointment-page="{{ pagination.page + 1 }}" {{ pagination.page >= pagination.pages ? 'disabled' : '' }}>
                Suivant<i class="bi bi-chevron-right ms-1"></i>
            </button>
        </div>
    {% endif %}
</div>
