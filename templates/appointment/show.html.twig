{% extends 'base.html.twig' %}

{% block title %}{{ appointment.reference }}{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">{{ appointment.title }}</h1>
        <p class="text-secondary mb-0">{{ appointment.reference }} · {{ appointment.startAt ? appointment.startAt|date('d/m/Y H:i') : '-' }}</p>
    </div>
    <a href="{{ path('app_appointment_calendar') }}" class="btn btn-outline-secondary">
        <i class="bi bi-calendar3 me-2"></i>Calendrier
    </a>
</div>

<div class="modal-content position-static">
    {% include 'appointment/_details_modal.html.twig' with {appointment: appointment, history: history} %}
</div>
{% endblock %}
