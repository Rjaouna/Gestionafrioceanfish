{% set status_tone = {
    planned: 'primary',
    confirmed: 'success',
    pending: 'warning',
    completed: 'info',
    cancelled: 'danger',
    postponed: 'secondary'
} %}
{% set priority_tone = {
    low: 'secondary',
    normal: 'primary',
    high: 'warning',
    urgent: 'danger'
} %}

<div class="modal-header">
    <div class="min-w-0">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis">{{ appointment.reference }}</span>
            <span class="badge rounded-pill text-bg-{{ status_tone[appointment.status]|default('secondary') }}">{{ appointment.statusLabel }}</span>
            <span class="badge rounded-pill text-bg-{{ priority_tone[appointment.priority]|default('secondary') }}">{{ appointment.priorityLabel }}</span>
        </div>
        <h2 class="modal-title h5 mb-0 text-truncate">{{ appointment.title }}</h2>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
</div>

<div class="modal-body">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="h6 mb-3"><i class="bi bi-calendar-event text-primary me-2"></i>Details du rendez-vous</h3>
                    <div class="appointment-detail-grid">
                        <div>
                            <span>Date</span>
                            <strong>{{ appointment.startAt ? appointment.startAt|date('d/m/Y') : '-' }}</strong>
                        </div>
                        <div>
                            <span>Horaire</span>
                            <strong>{{ appointment.startAt ? appointment.startAt|date('H:i') : '-' }} - {{ appointment.endAt ? appointment.endAt|date('H:i') : '-' }}</strong>
                        </div>
                        <div>
                            <span>Type</span>
                            <strong>{{ appointment.appointmentTypeLabel }}</strong>
                        </div>
                        <div>
                            <span>Lieu</span>
                            <strong>{{ appointment.location ?: '-' }}</strong>
                        </div>
                        <div>
                            <span>Client</span>
                            <strong>{{ appointment.customerName ?: '-' }}</strong>
                        </div>
                        <div>
                            <span>Contact</span>
                            <strong>{{ appointment.customerEmail ?: appointment.customerPhone ?: '-' }}</strong>
                        </div>
                    </div>
                    {% if appointment.description %}
                        <div class="border-top pt-3 mt-3">
                            <div class="small text-secondary fw-semibold text-uppercase mb-1">Note</div>
                            <p class="mb-0">{{ appointment.description|nl2br }}</p>
                        </div>
                    {% endif %}
                    {% if appointment.meetingLink %}
                        <a class="btn btn-outline-primary btn-sm mt-3" href="{{ appointment.meetingLink }}" target="_blank" rel="noopener">
                            <i class="bi bi-camera-video me-2"></i>Ouvrir le lien visio
                        </a>
                    {% endif %}
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
                        <h3 class="h6 mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Historique</h3>
                    </div>
                    {% include 'appointment/_history.html.twig' with {history: history} %}
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
                        <h3 class="h6 mb-0"><i class="bi bi-people text-primary me-2"></i>Participants</h3>
                        {% if is_granted('APPOINTMENT_ASSIGN_USER', appointment) %}
                            <button class="btn btn-outline-primary btn-sm" type="button" data-remote-modal="{{ path('app_appointment_participants_modal', {id: appointment.id}) }}">
                                <i class="bi bi-person-plus me-1"></i>Ajouter
                            </button>
                        {% endif %}
                    </div>
                    <div class="list-group list-group-flush">
                        {% for participant in appointment.participants|filter(p => p.active) %}
                            <div class="list-group-item px-0 d-flex justify-content-between gap-3">
                                <div class="min-w-0">
                                    <div class="fw-semibold text-truncate">{{ participant.user.displayName }}</div>
                                    <div class="small text-secondary">{{ participant.roleLabel }} · {{ participant.responseLabel }}</div>
                                </div>
                                {% if is_granted('APPOINTMENT_ASSIGN_USER', appointment) %}
                                    <button class="btn btn-outline-danger btn-sm" type="button" title="Retirer" aria-label="Retirer" data-confirm-url="{{ path('app_appointment_participant_remove', {id: appointment.id, participantId: participant.id}) }}" data-confirm-method="DELETE" data-token="{{ csrf_token('participant_appointment_' ~ appointment.id) }}" data-confirm-message="Retirer ce participant ?">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                {% endif %}
                            </div>
                        {% else %}
                            <div class="text-secondary small">Aucun participant affecte.</div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {% if appointment.cancellationReason %}
                <div class="alert alert-warning">
                    <div class="fw-semibold mb-1">Motif d'annulation</div>
                    {{ appointment.cancellationReason }}
                </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="modal-footer">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
    {% if is_granted('APPOINTMENT_EDIT', appointment) %}
        <button type="button" class="btn btn-primary" data-remote-modal="{{ path('app_appointment_form', {id: appointment.id}) }}">
            <i class="bi bi-pencil me-2"></i>Modifier
        </button>
    {% endif %}
    {% if is_granted('APPOINTMENT_CANCEL', appointment) and appointment.status != 'cancelled' %}
        <button type="button" class="btn btn-warning" data-appointment-cancel-url="{{ path('app_appointment_cancel', {id: appointment.id}) }}" data-token="{{ csrf_token('appointment_calendar') }}">
            <i class="bi bi-calendar-x me-2"></i>Annuler
        </button>
    {% endif %}
    {% if is_granted('APPOINTMENT_DELETE', appointment) %}
        <button type="button" class="btn btn-outline-danger" data-confirm-url="{{ path('app_appointment_delete', {id: appointment.id}) }}" data-confirm-method="DELETE" data-token="{{ csrf_token('appointment_calendar') }}" data-confirm-message="Supprimer ce rendez-vous ?">
            <i class="bi bi-trash me-2"></i>Supprimer
        </button>
    {% endif %}
</div>
