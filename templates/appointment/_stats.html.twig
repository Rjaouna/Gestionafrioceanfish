{% set cards = [
    {label: "Aujourd’hui", value: stats.today|default(0), icon: 'bi-calendar-day', tone: 'primary'},
    {label: 'Cette semaine', value: stats.week|default(0), icon: 'bi-calendar-week', tone: 'success'},
    {label: 'Ce mois', value: stats.month|default(0), icon: 'bi-calendar3', tone: 'info'},
    {label: 'En attente', value: stats.pending|default(0), icon: 'bi-hourglass-split', tone: 'warning'},
    {label: 'Urgents', value: stats.urgent|default(0), icon: 'bi-exclamation-triangle', tone: 'danger'},
    {label: 'Annulés', value: stats.cancelled|default(0), icon: 'bi-x-circle', tone: 'secondary'}
] %}

<div class="dashboard-kpi-strip mb-4">
    {% for card in cards %}
        <div class="dashboard-kpi-card dashboard-kpi-card-{{ card.tone }}">
            <div class="dashboard-kpi-head">
                <span class="dashboard-kpi-title">{{ card.label }}</span>
                <span class="dashboard-kpi-icon text-bg-{{ card.tone }}"><i class="bi {{ card.icon }}"></i></span>
            </div>
            <div class="dashboard-kpi-value">{{ card.value }}</div>
            <div class="dashboard-kpi-hint">Rendez-vous visibles</div>
        </div>
    {% endfor %}
</div>
