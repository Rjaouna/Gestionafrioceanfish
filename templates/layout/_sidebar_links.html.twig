{% macro business_module(module, current_route) %}
    {% set module_active = module.slug == 'maintenance' ? current_route starts with 'app_maintenance' : current_route starts with module.routeName|replace({'_index': ''}) %}

    {% if module.slug == 'maintenance' %}
        <section class="sidebar-open-section {{ module_active ? 'active' : '' }}">
            <div class="sidebar-open-body">
                <a class="sidebar-sub-link {{ module_active ? 'active' : '' }}" href="{{ path('app_maintenance_intervention_index') }}">
                    <i class="bi bi-tools"></i>
                    <span>Maintenance</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_maintenance_intervention' ? 'active' : '' }}" href="{{ path('app_maintenance_intervention_index') }}">
                    <i class="bi bi-wrench-adjustable"></i>
                    <span>Interventions</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_maintenance_intervenant' ? 'active' : '' }}" href="{{ path('app_maintenance_intervenant_index') }}">
                    <i class="bi bi-person-gear"></i>
                    <span>Intervenants</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_maintenance_contract' ? 'active' : '' }}" href="{{ path('app_maintenance_contract_index') }}">
                    <i class="bi bi-file-earmark-check"></i>
                    <span>Contrats</span>
                </a>
            </div>
        </section>
    {% elseif module.slug == 'expenses' %}
        <section class="sidebar-open-section {{ module_active ? 'active' : '' }}">
            <div class="sidebar-open-body">
                <a class="sidebar-sub-link {{ module_active ? 'active' : '' }}" href="{{ path('app_expense_index') }}">
                    <i class="bi bi-cash-coin"></i>
                    <span>Depenses</span>
                </a>
                <a
                    class="sidebar-sub-link ps-4"
                    href="{{ path('app_expense_index') }}#nouvelle-depense"
                    data-navigation-modal="#createExpenseModal"
                >
                    <i class="bi bi-plus-circle"></i>
                    <span>Nouvelle depense</span>
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_expense_cash_fund' ? 'active' : '' }}" href="{{ path('app_expense_cash_fund_index') }}">
                        <i class="bi bi-wallet2"></i>
                        <span>Cagnotte</span>
                    </a>
                {% endif %}
                {% if is_granted('EXPENSE_MANAGE_CATEGORIES') %}
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_expense_category' ? 'active' : '' }}" href="{{ path('app_expense_category_index') }}">
                        <i class="bi bi-tags"></i>
                        <span>Catégories</span>
                    </a>
                {% endif %}
            </div>
        </section>
    {% elseif module.slug == 'cout-revient' %}
        {% set cout_active = module_active or current_route starts with 'app_fish_yield_study' %}
        <section class="sidebar-open-section {{ cout_active ? 'active' : '' }}">
            <div class="sidebar-open-body">
                <a class="sidebar-sub-link {{ module_active ? 'active' : '' }}" href="{{ path('app_cout_revient_index') }}">
                    <i class="bi bi-calculator"></i>
                    <span>Cout de revient</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_cout_revient_dashboard' ? 'active' : '' }}" href="{{ path('app_cout_revient_dashboard') }}">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_cout_revient_new' ? 'active' : '' }}" href="{{ path('app_cout_revient_new') }}">
                    <i class="bi bi-plus-circle"></i>
                    <span>Nouveau lot</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_cout_revient_charge' ? 'active' : '' }}" href="{{ path('app_cout_revient_charge_index') }}">
                    <i class="bi bi-sliders"></i>
                    <span>Charges production</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_cout_revient_estimation' ? 'active' : '' }}" href="{{ path('app_cout_revient_estimation') }}">
                    <i class="bi bi-clipboard-data"></i>
                    <span>Estimation des couts</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_fish_yield_study' ? 'active' : '' }}" href="{{ path('app_fish_yield_study_index') }}">
                    <i class="bi bi-clipboard2-pulse"></i>
                    <span>Etudes rendement poisson</span>
                </a>
            </div>
        </section>
    {% elseif module.slug == 'contracts' %}
        <section class="sidebar-open-section {{ module_active ? 'active' : '' }}">
            <div class="sidebar-open-body">
                <a class="sidebar-sub-link {{ current_route == 'app_generated_contract_index' ? 'active' : '' }}" href="{{ path('app_generated_contract_index') }}">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Liste des contrats</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_generated_contract_conditioning' ? 'active' : '' }}" href="{{ path('app_generated_contract_conditioning_new') }}">
                    <i class="bi bi-box-seam"></i>
                    <span>Contrat de conditionnement</span>
                </a>
            </div>
        </section>
    {% elseif module.slug == 'receptions' %}
        <section class="sidebar-open-section {{ module_active ? 'active' : '' }}">
            <div class="sidebar-open-body">
                <a class="sidebar-sub-link {{ current_route == 'app_fish_reception_index' ? 'active' : '' }}" href="{{ path('app_fish_reception_index') }}">
                    <i class="bi bi-clipboard2-check"></i>
                    <span>Liste réceptions</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_fish_reception_new' ? 'active' : '' }}" href="{{ path('app_fish_reception_new') }}">
                    <i class="bi bi-plus-circle"></i>
                    <span>Nouvelle réception</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_fish_reception_stage' and app.request.attributes.get('stage') == 'traitement' ? 'active' : '' }}" href="{{ path('app_fish_reception_stage', {stage: 'traitement'}) }}">
                    <i class="bi bi-arrow-repeat"></i>
                    <span>Traitement / Production</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_fish_reception_stage' and app.request.attributes.get('stage') == 'congelation' ? 'active' : '' }}" href="{{ path('app_fish_reception_stage', {stage: 'congelation'}) }}">
                    <i class="bi bi-snow"></i>
                    <span>Congelation</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_fish_reception_stage' and app.request.attributes.get('stage') == 'stockage' ? 'active' : '' }}" href="{{ path('app_fish_reception_stage', {stage: 'stockage'}) }}">
                    <i class="bi bi-box-seam"></i>
                    <span>Cristallisation</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_fish_reception_stage' and app.request.attributes.get('stage') == 'emballage' ? 'active' : '' }}" href="{{ path('app_fish_reception_stage', {stage: 'emballage'}) }}">
                    <i class="bi bi-box"></i>
                    <span>Emballage</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_fish_reception_stage' and app.request.attributes.get('stage') == 'expedition' ? 'active' : '' }}" href="{{ path('app_fish_reception_stage', {stage: 'expedition'}) }}">
                    <i class="bi bi-truck"></i>
                    <span>Expédition</span>
                </a>
                <a class="sidebar-sub-link ps-4 {{ current_route == 'app_fish_reception_statistics' ? 'active' : '' }}" href="{{ path('app_fish_reception_statistics') }}">
                    <i class="bi bi-graph-up-arrow"></i>
                    <span>Statistiques</span>
                </a>
            </div>
        </section>
    {% else %}
        {% set label = module.slug == 'interimaires' ? 'Fiche intérimaire' : (module.slug == 'contacts' ? 'Carnet de contacts' : module.name) %}
        <section class="sidebar-open-section {{ module_active ? 'active' : '' }}">
            <div class="sidebar-open-body">
                <a class="sidebar-sub-link {{ module_active ? 'active' : '' }}" href="{{ path(module.routeName) }}">
                    <i class="bi {{ module.icon }}"></i>
                    <span>{{ label }}</span>
                </a>

                {% if module.slug == 'contacts' %}
                    <a
                        class="sidebar-sub-link ps-4"
                        href="{{ path(module.routeName) }}#nouveau-contact"
                        data-navigation-modal="#createContactModal"
                    >
                        <i class="bi bi-person-plus"></i>
                        <span>Ajouter un contact</span>
                    </a>
                {% endif %}

                {% if module.slug == 'documents' %}
                    <a
                        class="sidebar-sub-link ps-4"
                        href="{{ path(module.routeName) }}#nouveau-document"
                        data-navigation-modal="#createDocumentModal"
                    >
                        <i class="bi bi-file-earmark-plus"></i>
                        <span>Ajouter un document</span>
                    </a>
                {% endif %}

                {% if module.slug == 'interimaires' %}
                    {% if is_granted('MODULE_ACCESS', 'pointage-personnel') %}
                        <a class="sidebar-sub-link ps-4 {{ current_route == 'app_interim_attendance_details' ? 'active' : '' }}" href="{{ path('app_interim_attendance_details') }}">
                            <i class="bi bi-clipboard-data"></i>
                            <span>Details pointage</span>
                        </a>
                    {% endif %}
                    <a
                        class="sidebar-sub-link ps-4"
                        href="{{ path(module.routeName) }}#nouvel-intérimaire"
                        data-navigation-modal="#createInterimWorkerModal"
                    >
                        <i class="bi bi-person-plus"></i>
                        <span>Ajouter un intérimaire</span>
                    </a>
                {% endif %}

                {% if module.slug == 'pointage-personnel' %}
                    <a class="sidebar-sub-link ps-4 {{ current_route == 'app_interim_attendance_details' ? 'active' : '' }}" href="{{ path('app_interim_attendance_details') }}">
                        <i class="bi bi-clipboard-data"></i>
                        <span>Details pointage</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_interim_payment' ? 'active' : '' }}" href="{{ path('app_interim_payment_index') }}">
                        <i class="bi bi-wallet2"></i>
                        <span>Paiements</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_interim_attendance_rate' ? 'active' : '' }}" href="{{ path('app_interim_attendance_rate_index') }}">
                        <i class="bi bi-cash-coin"></i>
                        <span>Tarifs pointage</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route == 'app_interim_attendance_sheet' ? 'active' : '' }}" href="{{ path('app_interim_attendance_sheet') }}">
                        <i class="bi bi-printer"></i>
                        <span>Feuille de pointage</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route == 'app_interim_attendance_internal_sheet' ? 'active' : '' }}" href="{{ path('app_interim_attendance_internal_sheet') }}">
                        <i class="bi bi-clock-history"></i>
                        <span>Feuille internes</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_interim_attendance_journal' ? 'active' : '' }}" href="{{ path('app_interim_attendance_journal') }}">
                        <i class="bi bi-file-earmark-pdf"></i>
                        <span>Export journal</span>
                    </a>
                {% endif %}
            </div>
        </section>
    {% endif %}
{% endmacro %}

{% import _self as menu %}

{% set current_route = app.request.attributes.get('_route')|default('') %}
{% set password_modules = modules|filter(module => module.slug == 'passwords') %}
{% set user_modules = modules|filter(module => module.slug == 'users') %}
{% set module_admin_modules = modules|filter(module => module.slug == 'modules') %}
{% set agenda_modules = modules|filter(module => module.slug == 'agenda') %}
{% set inventory_modules = modules|filter(module => module.slug == 'inventory') %}
{% set factory_modules = modules|filter(module => module.slug == 'factory') %}
{% set business_modules = modules|filter(module => module.slug not in ['passwords', 'users', 'modules', 'agenda', 'inventory', 'factory', 'etudes-rendement-poisson']) %}
{% set can_manage_users = user_modules|length > 0 and is_granted('ROLE_ADMIN') %}
{% set can_manage_modules = module_admin_modules|length > 0 and is_granted('ROLE_SUPER_ADMIN') %}
{% set security_active = current_route starts with 'app_password' %}
{% set users_active = current_route starts with 'app_user' %}
{% set agenda_active = current_route starts with 'app_appointment' %}
{% set inventory_active = current_route starts with 'app_inventory' %}
{% set inventory_locations_active = current_route starts with 'app_inventory_location' or current_route starts with 'app_inventory_site' %}
{% set configuration_active = current_route starts with 'app_module' %}
{% set trash_active = current_route starts with 'app_trash' %}
{% set deleted_items_count = is_granted('ROLE_SUPER_ADMIN') ? trash_deleted_count(app.user) : 0 %}
{% set primary_business_slugs = ['receptions', 'cout-revient', 'ventes-dechets', 'interimaires', 'pointage-personnel', 'expenses', 'contacts', 'contracts'] %}
{% set secondary_business_slugs = ['documents', 'maintenance'] %}
{% set ordered_business_slugs = primary_business_slugs|merge(secondary_business_slugs) %}

<div class="sidebar-navigation">
    <a class="sidebar-brand-panel" href="{{ path('app_dashboard') }}" aria-label="AFRIOCEAN FISH">
        <img
            class="sidebar-brand-logo"
            src="{{ asset('images/logo-afriocean-fish.svg') }}"
            alt="AFRIOCEAN FISH"
            width="168"
            height="45"
            style="display:block;width:10.5rem;max-width:100%;height:auto;"
        >
    </a>

    <div class="sidebar-menu-search" data-sidebar-search>
        <label class="visually-hidden" for="{{ item_prefix }}MenuSearch">Rechercher dans le menu</label>
        <div class="input-group input-group-sm">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input
                id="{{ item_prefix }}MenuSearch"
                class="form-control"
                type="search"
                placeholder="Rechercher..."
                autocomplete="off"
                data-sidebar-search-input
            >
            <button class="btn btn-outline-secondary d-none" type="button" aria-label="Effacer la recherche" data-sidebar-search-clear>
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="sidebar-search-empty d-none" data-sidebar-search-empty>Aucun resultat.</div>
    </div>

    <div class="sidebar-primary">
        <a class="sidebar-home-link {{ current_route == 'app_dashboard' ? 'active' : '' }}" href="{{ path('app_dashboard') }}">
            <span class="sidebar-link-icon"><i class="bi bi-speedometer2"></i></span>
            <span>
                <strong>Tableau de bord</strong>
                <small>Accueil</small>
            </span>
        </a>

        {% for slug in primary_business_slugs %}
            {% for module in business_modules %}
                {% if module.slug == slug %}
                    {{ menu.business_module(module, current_route) }}
                {% endif %}
            {% endfor %}
        {% endfor %}

        {% if inventory_modules|length > 0 %}
            <section class="sidebar-open-section {{ inventory_active ? 'active' : '' }}">
                <div class="sidebar-open-body">
                    <a class="sidebar-sub-link {{ inventory_active ? 'active' : '' }}" href="{{ path('app_inventory_dashboard') }}">
                        <i class="bi bi-box-seam"></i>
                        <span>Inventaire</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_inventory_request' ? 'active' : '' }}" href="{{ path('app_inventory_request_index') }}">
                        <i class="bi bi-inbox"></i>
                        <span>Demandes a valider</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_inventory_item' ? 'active' : '' }}" href="{{ path('app_inventory_item_index') }}">
                        <i class="bi bi-box-seam"></i>
                        <span>Materiel</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_inventory_carton' ? 'active' : '' }}" href="{{ path('app_inventory_carton_stock_index') }}">
                        <i class="bi bi-boxes"></i>
                        <span>Stocks cartons</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route starts with 'app_inventory_consumable_stock' ? 'active' : '' }}" href="{{ path('app_inventory_consumable_stock_index') }}">
                        <i class="bi bi-basket"></i>
                        <span>Stock consommables</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ inventory_locations_active ? 'active' : '' }}" href="{{ path('app_inventory_location_index') }}">
                        <i class="bi bi-pin-map"></i>
                        <span>Sites et emplacements</span>
                    </a>
                </div>
            </section>
        {% endif %}

        {% for slug in secondary_business_slugs %}
            {% for module in business_modules %}
                {% if module.slug == slug %}
                    {{ menu.business_module(module, current_route) }}
                {% endif %}
            {% endfor %}
        {% endfor %}

        {% if agenda_modules|length > 0 %}
            <section class="sidebar-open-section {{ agenda_active ? 'active' : '' }}">
                <div class="sidebar-open-body">
                    <a class="sidebar-sub-link {{ agenda_active ? 'active' : '' }}" href="{{ path('app_appointment_calendar') }}">
                        <i class="bi bi-calendar-check"></i>
                        <span>Agenda</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route == 'app_appointment_index' ? 'active' : '' }}" href="{{ path('app_appointment_index') }}">
                        <i class="bi bi-list-task"></i>
                        <span>Liste des rendez-vous</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route == 'app_appointment_new' ? 'active' : '' }}" href="{{ path('app_appointment_new') }}">
                        <i class="bi bi-calendar-plus"></i>
                        <span>Nouveau rendez-vous</span>
                    </a>
                    <a class="sidebar-sub-link ps-4 {{ current_route == 'app_appointment_my' ? 'active' : '' }}" href="{{ path('app_appointment_my') }}">
                        <i class="bi bi-person-check"></i>
                        <span>Mes rendez-vous</span>
                    </a>
                </div>
            </section>
        {% endif %}

        {% for module in business_modules %}
            {% if module.slug not in ordered_business_slugs %}
                {{ menu.business_module(module, current_route) }}
            {% endif %}
        {% endfor %}

        {% if password_modules|length > 0 %}
            <section class="sidebar-open-section {{ security_active ? 'active' : '' }}">
                <div class="sidebar-open-body">
                    <a class="sidebar-sub-link {{ security_active ? 'active' : '' }}" href="{{ path('app_password_index') }}">
                        <i class="bi bi-shield-lock"></i>
                        <span>Securite</span>
                    </a>
                    <a
                        class="sidebar-sub-link ps-4"
                        href="{{ path('app_password_index') }}#nouveau-mot-de-passe"
                        data-navigation-modal="#createPasswordModal"
                    >
                        <i class="bi bi-plus-circle"></i>
                        <span>Ajouter un mot de passe</span>
                    </a>
                </div>
            </section>
        {% endif %}

        {% if can_manage_users %}
            <section class="sidebar-open-section {{ users_active ? 'active' : '' }}">
                <div class="sidebar-open-body">
                    <a class="sidebar-sub-link {{ current_route starts with 'app_user' ? 'active' : '' }}" href="{{ path('app_user_index') }}">
                        <i class="bi bi-people"></i>
                        <span>Utilisateurs</span>
                    </a>
                    <a
                        class="sidebar-sub-link ps-4"
                        href="{{ path('app_user_index') }}#nouvel-utilisateur"
                        data-navigation-modal="#createUserModal"
                    >
                        <i class="bi bi-person-plus"></i>
                        <span>Ajouter un utilisateur</span>
                    </a>
                </div>
            </section>
        {% endif %}

        {% if modules is empty %}
            <div class="small text-secondary px-2 py-3">Aucun module attribue.</div>
        {% endif %}
    </div>

    <div class="sidebar-bottom-zone">
        {% if is_granted('ROLE_SUPER_ADMIN') %}
            <div class="sidebar-configuration">
                <section class="sidebar-open-section {{ trash_active ? 'active' : '' }}">
                    <div class="sidebar-open-body">
                        <a class="sidebar-sub-link {{ trash_active ? 'active' : '' }}" href="{{ path('app_trash_index') }}">
                            <i class="bi bi-trash3"></i>
                            <span>Corbeille</span>
                            {% if deleted_items_count > 0 %}
                                <span class="sidebar-trash-count ms-auto">{{ deleted_items_count }}</span>
                            {% endif %}
                        </a>
                    </div>
                </section>
            </div>
        {% endif %}

        {% if can_manage_modules %}
            <div class="sidebar-configuration">
                <section class="sidebar-open-section {{ configuration_active ? 'active' : '' }}">
                    <div class="sidebar-open-body">
                        <a class="sidebar-sub-link {{ current_route starts with 'app_module' ? 'active' : '' }}" href="{{ path('app_module_index') }}">
                            <i class="bi bi-sliders"></i>
                            <span>Modules</span>
                        </a>
                    </div>
                </section>
            </div>
        {% endif %}

        {% if factory_modules|length > 0 %}
            <div class="sidebar-configuration">
                {% for module in factory_modules %}
                    {{ menu.business_module(module, current_route) }}
                {% endfor %}
            </div>
        {% endif %}

        <a class="sidebar-logout-button" href="{{ path('app_logout') }}">
            <span class="sidebar-logout-icon"><i class="bi bi-box-arrow-right"></i></span>
            <span>Deconnexion</span>
        </a>
    </div>
</div>
