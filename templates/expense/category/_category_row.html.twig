<div class="d-flex justify-content-between align-items-center gap-3 border rounded-3 p-3">
    <div>
        <div class="fw-semibold">{{ category.name }}</div>
        <div class="small text-secondary">{{ category.slug }}</div>
    </div>
    <span class="badge {{ category.active ? 'text-bg-success' : 'text-bg-secondary' }}">
        {{ category.active ? 'Active' : 'Inactive' }}
    </span>
</div>
