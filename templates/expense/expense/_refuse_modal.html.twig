{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header border-0 pb-0">
        <div>
            <h2 class="modal-title h4">Refuser la dépense</h2>
            <p class="text-secondary mb-0">{{ expense.reference }} · {{ expense.title }}</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-warning">
            Le motif sera conservé sur la fiche de dépense.
        </div>
        {{ form_row(form.reason) }}
        {{ form_rest(form) }}
    </div>
    <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-x-lg me-2"></i>Refuser
        </button>
    </div>
{{ form_end(form) }}
