<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-secondary small">Dépenses du mois</div>
                        <div class="h4 mb-0">{{ stats.month_total|number_format(2, ',', ' ') }} dh</div>
                    </div>
                    <span class="rounded-3 bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center fs-4 module-mark">
                        <i class="bi bi-calendar2-month"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-secondary small">En attente</div>
                        <div class="h4 mb-0">{{ stats.pending_count }}</div>
                    </div>
                    <span class="rounded-3 bg-warning-subtle text-warning d-inline-flex align-items-center justify-content-center fs-4 module-mark">
                        <i class="bi bi-hourglass-split"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-secondary small">Total payé</div>
                        <div class="h4 mb-0">{{ stats.paid_total|number_format(2, ',', ' ') }} dh</div>
                    </div>
                    <span class="rounded-3 bg-success-subtle text-success d-inline-flex align-items-center justify-content-center fs-4 module-mark">
                        <i class="bi bi-check2-circle"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-secondary small">Validées / refusées</div>
                        <div class="h4 mb-0">{{ stats.validated_count }} / {{ stats.refused_count }}</div>
                    </div>
                    <span class="rounded-3 bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center fs-4 module-mark">
                        <i class="bi bi-clipboard-check"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
