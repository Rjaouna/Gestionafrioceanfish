{% set total = stats.totalAmount|default(0) %}
{% set total_weight = stats.totalWeight|default(0) %}
<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between gap-3">
                <div>
                    <div class="small text-secondary">Total selection</div>
                    <div class="h4 mb-0">{{ total|number_format(2, ',', ' ') }} dh</div>
                    <div class="small text-secondary mt-1">{{ total_weight|number_format(3, ',', ' ')|replace({',000': ''}) }} kg vendus</div>
                </div>
                <span class="rounded-3 bg-success-subtle text-success d-inline-flex align-items-center justify-content-center fs-4 module-mark"><i class="bi bi-cash-stack"></i></span>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between gap-3">
                <div>
                    <div class="small text-secondary">Aujourd hui</div>
                    <div class="h4 mb-0">{{ stats.today.amount|default(0)|number_format(2, ',', ' ') }} dh</div>
                    <div class="small text-secondary mt-1">{{ stats.today.weight|default(0)|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</div>
                </div>
                <span class="rounded-3 bg-info-subtle text-info d-inline-flex align-items-center justify-content-center fs-4 module-mark"><i class="bi bi-calendar-day"></i></span>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between gap-3">
                <div>
                    <div class="small text-secondary">Cette semaine</div>
                    <div class="h4 mb-0">{{ stats.week.amount|default(0)|number_format(2, ',', ' ') }} dh</div>
                    <div class="small text-secondary mt-1">{{ stats.week.weight|default(0)|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</div>
                </div>
                <span class="rounded-3 bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center fs-4 module-mark"><i class="bi bi-calendar-week"></i></span>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between gap-3">
                <div>
                    <div class="small text-secondary">Ce mois</div>
                    <div class="h4 mb-0">{{ stats.month.amount|default(0)|number_format(2, ',', ' ') }} dh</div>
                    <div class="small text-secondary mt-1">{{ stats.month.weight|default(0)|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</div>
                </div>
                <span class="rounded-3 bg-warning-subtle text-warning d-inline-flex align-items-center justify-content-center fs-4 module-mark"><i class="bi bi-calendar3"></i></span>
            </div>
        </div>
    </div>
</div>
