{% set max_day = 0 %}
{% for row in stats.byDay|default([])|slice(0, 8) %}
    {% set max_day = max(max_day, row.amount) %}
{% endfor %}

<div class="d-grid gap-4">
    <section class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pb-0">
            <h2 class="h5 mb-1">Detail par jour</h2>
        </div>
        <div class="card-body">
            <div class="d-grid gap-3">
                {% for row in stats.byDay|default([])|slice(0, 8) %}
                    {% set percent = max_day > 0 ? (row.amount / max_day * 100) : 0 %}
                    <div>
                        <div class="d-flex justify-content-between gap-2 small">
                            <span>{{ row.label }}</span>
                            <strong>{{ row.amount|number_format(2, ',', ' ') }} dh</strong>
                        </div>
                        <div class="progress mt-1" style="height: .55rem;">
                            <div class="progress-bar bg-success" style="width: {{ percent|round(2, 'floor') }}%"></div>
                        </div>
                        <div class="small text-secondary mt-1">{{ row.weight|number_format(3, ',', ' ')|replace({',000': ''}) }} kg - {{ row.count }} vente{{ row.count > 1 ? 's' : '' }}</div>
                    </div>
                {% else %}
                    <div class="text-secondary small">Aucune vente sur la selection.</div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pb-0">
            <h2 class="h5 mb-1">Details semaine / mois</h2>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <h3 class="h6">Par semaine</h3>
                    <div class="list-group list-group-flush">
                        {% for row in stats.byWeek|default([])|slice(0, 6) %}
                            <div class="list-group-item px-0 d-flex justify-content-between gap-3">
                                <span>{{ row.label }}<span class="d-block small text-secondary">{{ row.weight|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</span></span>
                                <strong class="text-nowrap">{{ row.amount|number_format(2, ',', ' ') }} dh</strong>
                            </div>
                        {% else %}
                            <div class="text-secondary small">Aucune semaine.</div>
                        {% endfor %}
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="h6">Par mois</h3>
                    <div class="list-group list-group-flush">
                        {% for row in stats.byMonth|default([])|slice(0, 6) %}
                            <div class="list-group-item px-0 d-flex justify-content-between gap-3">
                                <span>{{ row.label }}<span class="d-block small text-secondary">{{ row.weight|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</span></span>
                                <strong class="text-nowrap">{{ row.amount|number_format(2, ',', ' ') }} dh</strong>
                            </div>
                        {% else %}
                            <div class="text-secondary small">Aucun mois.</div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pb-0">
            <h2 class="h5 mb-1">Modes de paiement</h2>
        </div>
        <div class="card-body">
            <div class="d-grid gap-2">
                {% for row in stats.paymentMethods|default([]) %}
                    <div class="d-flex justify-content-between gap-3 border rounded-3 p-2">
                        <span>{{ row.label }}<span class="d-block small text-secondary">{{ row.count }} vente{{ row.count > 1 ? 's' : '' }}</span></span>
                        <strong class="text-nowrap">{{ row.amount|number_format(2, ',', ' ') }} dh</strong>
                    </div>
                {% else %}
                    <div class="text-secondary small">Aucun paiement dans la selection.</div>
                {% endfor %}
            </div>
        </div>
    </section>
</div>
