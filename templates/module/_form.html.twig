{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <h2 class="modal-title fs-5">{{ title }}</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.name) }}</div>
            <div class="col-md-6">{{ form_row(form.slug) }}</div>
            <div class="col-md-6">{{ form_row(form.icon) }}</div>
            <div class="col-md-6">{{ form_row(form.routeName) }}</div>
            <div class="col-12">{{ form_row(form.description) }}</div>
            <div class="col-12">{{ form_row(form.isActive) }}</div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">{{ submit_label }}</button>
    </div>
{{ form_end(form) }}
