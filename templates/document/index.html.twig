{% extends 'base.html.twig' %}

{% set active_filters = active_filters|default({category: '', issuer: '', language: '', status: ''}) %}
{% set document_filters = document_filters|default({categories: [], issuers: [], languages: [], statuses: {}}) %}

{% block title %}Gestion des documents{% endblock %}

{% block body %}
<div class="document-page-head d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Tous les fichiers</h1>
        <p class="text-secondary mb-0">Stockage privé, partage sécurisé et téléchargement contrôlé.</p>
    </div>
    <button class="btn btn-primary document-new-button" data-bs-toggle="modal" data-bs-target="#createDocumentModal">
        <i class="bi bi-file-earmark-plus me-2"></i>Nouveau document
    </button>
</div>

<div class="document-toolbar mb-4">
    <div class="document-search-box">
        <i class="bi bi-search text-secondary"></i>
        <input
            type="search"
            class="form-control"
            placeholder="Rechercher fichiers et dossiers"
            aria-label="Rechercher un document"
            data-document-search
            data-document-search-url="{{ path('app_document_search') }}"
            data-document-target="documentGrid"
        >
        <button class="btn btn-link text-secondary d-none" type="button" data-document-clear-search aria-label="Effacer la recherche et les filtres">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <span class="document-result-count">
        <i class="bi bi-folder2-open me-1"></i>
        <span data-document-search-count>{{ pagination.total }}</span>
        <span data-document-search-label>résultat{{ pagination.total > 1 ? 's' : '' }}</span>
    </span>

    <div class="document-filter-row">
        <select id="documentCategoryFilter" class="form-select" data-document-filter="category" aria-label="Filtrer par catégorie">
            <option value="">Toutes les catégories</option>
            {% for category in document_filters.categories %}
                <option value="{{ category }}" {{ active_filters.category == category ? 'selected' : '' }}>{{ category }}</option>
            {% endfor %}
        </select>

        <select id="documentIssuerFilter" class="form-select" data-document-filter="issuer" aria-label="Filtrer par émetteur">
            <option value="">Tous les émetteurs</option>
            {% for issuer in document_filters.issuers %}
                <option value="{{ issuer }}" {{ active_filters.issuer == issuer ? 'selected' : '' }}>{{ issuer }}</option>
            {% endfor %}
        </select>

        <select id="documentLanguageFilter" class="form-select" data-document-filter="language" aria-label="Filtrer par langue">
            <option value="">Toutes les langues</option>
            {% for language in document_filters.languages %}
                <option value="{{ language }}" {{ active_filters.language == language ? 'selected' : '' }}>{{ language }}</option>
            {% endfor %}
        </select>

        <select id="documentStatusFilter" class="form-select" data-document-filter="status" aria-label="Filtrer par statut">
            <option value="">Tous les statuts</option>
            {% for status, label in document_filters.statuses %}
                <option value="{{ status }}" {{ active_filters.status == status ? 'selected' : '' }}>{{ label }}</option>
            {% endfor %}
        </select>
    </div>
</div>

<div id="documentGrid" data-document-grid>
    {% include 'document/_document_grid.html.twig' with {documents: documents, pagination: pagination} %}
</div>

<div class="modal fade" id="createDocumentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
        <div class="modal-content">
            {% include 'document/_form_modal.html.twig' with {form: create_form, title: 'Ajouter un document', submit_label: 'Ajouter'} %}
        </div>
    </div>
</div>
{% endblock %}
