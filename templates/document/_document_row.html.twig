{% set archived_status = constant('App\\Entity\\Document::STATUS_ARCHIVED') %}
{% set expired_status = constant('App\\Entity\\Document::STATUS_EXPIRED') %}
{% set review_status = constant('App\\Entity\\Document::STATUS_TO_REVIEW') %}
{% set status_icon = 'bi-check-circle' %}
{% if document.status == archived_status %}
    {% set status_icon = 'bi-archive' %}
{% elseif document.status == expired_status %}
    {% set status_icon = 'bi-exclamation-octagon' %}
{% elseif document.status == review_status %}
    {% set status_icon = 'bi-exclamation-triangle' %}
{% endif %}

<div
    class="col-12 col-md-4 col-xl-3"
    data-search-item
    data-search-value="{{ (document.name ~ ' ' ~ document.description ~ ' ' ~ document.category ~ ' ' ~ document.internalReference ~ ' ' ~ document.issuer ~ ' ' ~ document.language ~ ' ' ~ document.status ~ ' ' ~ document.tags ~ ' ' ~ document.confidentialityLevel ~ ' ' ~ document.version ~ ' ' ~ document.mimeType ~ ' ' ~ document.originalFileName ~ ' ' ~ document.createdBy.displayName|default(''))|lower }}"
>
    {% embed 'components/_entity_card.html.twig' with {
        title: document.name,
        title_remote_url: is_granted('DOCUMENT_VIEW', document) ? path('app_document_view', {id: document.id}) : null,
        subtitle: document.originalFileName,
        icon: 'bi-file-earmark-text',
        icon_container_class: 'rounded-3 bg-primary-subtle text-primary fs-3 module-mark',
        status_label: document.statusLabel,
        status_class: document.statusBadgeClass,
        status_icon: status_icon,
        muted: not document.active or document.status == archived_status,
        compact: false,
        created_at: document.createdAt,
        updated_at: document.updatedAt
    } %}
        {% block top_actions %}
            {% if is_granted('DOCUMENT_EDIT', document) %}
                <button class="btn btn-outline-primary btn-sm" title="Modifier" aria-label="Modifier" data-remote-modal="{{ path('app_document_form', {id: document.id}) }}">
                    <i class="bi bi-pencil"></i>
                </button>
            {% endif %}
            {% if is_granted('DOCUMENT_DELETE', document) %}
                <button class="btn btn-outline-danger btn-sm" title="Supprimer" aria-label="Supprimer" data-confirm-url="{{ path('app_document_delete', {id: document.id}) }}" data-confirm-method="DELETE" data-token="{{ csrf_token('delete_document_' ~ document.id) }}" data-confirm-message="Supprimer définitivement ce document et son fichier ?">
                    <i class="bi bi-trash"></i>
                </button>
            {% endif %}
        {% endblock %}

        {% block body %}
            <div class="d-grid gap-2 small">
                {% if document.category %}
                    <div class="app-card-info-row">
                        <span class="text-secondary"><i class="bi bi-tag me-1"></i>Catégorie</span>
                        <span class="text-end">{{ document.category }}</span>
                    </div>
                {% endif %}
                {% if document.internalReference %}
                    <div class="app-card-info-row">
                        <span class="text-secondary"><i class="bi bi-hash me-1"></i>Référence</span>
                        <span class="text-end">{{ document.internalReference }}</span>
                    </div>
                {% endif %}
                {% if document.documentDate %}
                    <div class="app-card-info-row">
                        <span class="text-secondary"><i class="bi bi-calendar-event me-1"></i>Date</span>
                        <span>{{ document.documentDate|date('d/m/Y') }}</span>
                    </div>
                {% endif %}
                {% if document.issuer %}
                    <div class="app-card-info-row">
                        <span class="text-secondary"><i class="bi bi-building me-1"></i>Émetteur</span>
                        <span class="text-end">{{ document.issuer }}</span>
                    </div>
                {% endif %}
                {% if document.language or document.version %}
                    <div class="app-card-info-row">
                        <span class="text-secondary"><i class="bi bi-translate me-1"></i>Langue / version</span>
                        <span class="text-end">{{ [document.language, document.version]|filter(v => v is not empty)|join(' · ') }}</span>
                    </div>
                {% endif %}
                {% if document.expiresAt %}
                    <div class="app-card-info-row">
                        <span class="text-secondary"><i class="bi bi-hourglass-split me-1"></i>Expiration</span>
                        <span>{{ document.expiresAt|date('d/m/Y') }}</span>
                    </div>
                {% endif %}
                {% if document.confidentialityLabel %}
                    <div>
                        <span class="badge {{ document.confidentialityBadgeClass }}">{{ document.confidentialityLabel }}</span>
                    </div>
                {% endif %}
                {% if document.tagList is not empty %}
                    <div class="d-flex flex-wrap gap-1">
                        {% for tag in document.tagList|slice(0, 5) %}
                            <span class="badge rounded-pill text-bg-light border">{{ tag }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endblock %}

        {% block actions %}
            <div class="app-card-actions-row">
                {% if is_granted('DOCUMENT_DOWNLOAD', document) %}
                    <a class="btn btn-primary btn-sm flex-grow-1" href="{{ path('app_document_download', {id: document.id}) }}">
                        <i class="bi bi-download me-1"></i>Télécharger
                    </a>
                {% endif %}
                {% if is_granted('DOCUMENT_EMAIL', document) %}
                    <button class="btn btn-outline-primary btn-sm" title="Envoyer par e-mail" aria-label="Envoyer par e-mail" data-remote-modal="{{ path('app_document_email_modal', {id: document.id}) }}">
                        <i class="bi bi-envelope"></i>
                    </button>
                {% endif %}
                {% if is_granted('DOCUMENT_SHARE', document) %}
                    <button class="btn btn-outline-success btn-sm" title="Partager" aria-label="Partager" data-remote-modal="{{ path('app_document_share_modal', {id: document.id}) }}">
                        <i class="bi bi-share"></i>
                    </button>
                {% endif %}
                {% if is_granted('DOCUMENT_ARCHIVE', document) %}
                    <button class="btn btn-outline-secondary btn-sm" title="{{ document.active ? 'Archiver' : 'Désarchiver' }}" aria-label="{{ document.active ? 'Archiver' : 'Désarchiver' }}" data-confirm-url="{{ path('app_document_archive', {id: document.id}) }}" data-confirm-method="POST" data-token="{{ csrf_token('archive_document_' ~ document.id) }}" data-confirm-message="{{ document.active ? 'Archiver ce document ?' : 'Désarchiver ce document ?' }}">
                        <i class="bi {{ document.active ? 'bi-archive' : 'bi-arrow-counterclockwise' }}"></i>
                    </button>
                {% endif %}
            </div>
        {% endblock %}
    {% endembed %}
</div>
