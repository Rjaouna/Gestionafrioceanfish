<section class="document-browser" aria-label="Liste des documents">
    <div class="document-browser-head">
        <div class="document-browser-col-name">Nom</div>
        <div class="document-browser-col-updated">Mis à jour</div>
        <div class="document-browser-col-size">Taille</div>
        <div class="document-browser-col-status">Statut</div>
        <div class="document-browser-col-actions" aria-label="Actions"></div>
    </div>

    <div class="document-browser-list">
        {% for document in documents %}
            {% include 'document/_document_row.html.twig' with {document: document} %}
        {% else %}
            <div class="document-browser-empty">
                <span class="document-file-list-icon document-file-list-icon-secondary">
                    <i class="bi bi-folder2-open"></i>
                </span>
                <div>
                    <h2 class="h6 mb-1">Aucun document trouvé</h2>
                    <p class="text-secondary mb-0">Ajoutez un document ou ajustez votre recherche.</p>
                </div>
            </div>
        {% endfor %}
    </div>
</section>

{% if pagination.pages > 1 %}
    <nav class="d-flex justify-content-center mt-4" aria-label="Pagination des documents">
        <div class="btn-group shadow-sm">
            <button class="btn btn-outline-primary" type="button" data-document-page="{{ pagination.page - 1 }}" {{ pagination.page <= 1 ? 'disabled' : '' }}>
                <i class="bi bi-chevron-left"></i>
            </button>
            <button class="btn btn-primary" type="button" disabled>
                Page {{ pagination.page }} / {{ pagination.pages }}
            </button>
            <button class="btn btn-outline-primary" type="button" data-document-page="{{ pagination.page + 1 }}" {{ pagination.page >= pagination.pages ? 'disabled' : '' }}>
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </nav>
{% endif %}
