{% set file_name = document.originalFileName|default('') %}
{% set file_name_lower = file_name|lower %}
{% set mime = document.mimeType|default('')|lower %}
{% set has_file = document.fileName is not empty and file_name is not empty %}
{% set file_icon = 'bi-file-earmark' %}
{% set file_tone = 'secondary' %}
{% set file_kind = 'Aucune pièce jointe' %}
{% if has_file %}
    {% set file_kind = 'Fichier' %}
    {% if mime == 'application/pdf' or file_name_lower ends with '.pdf' %}
        {% set file_icon = 'bi-file-earmark-pdf-fill' %}
        {% set file_tone = 'danger' %}
        {% set file_kind = 'PDF' %}
    {% elseif 'spreadsheet' in mime or 'excel' in mime or file_name_lower ends with '.xls' or file_name_lower ends with '.xlsx' or file_name_lower ends with '.csv' %}
        {% set file_icon = 'bi-file-earmark-excel-fill' %}
        {% set file_tone = 'success' %}
        {% set file_kind = 'Excel' %}
    {% elseif 'word' in mime or file_name_lower ends with '.doc' or file_name_lower ends with '.docx' %}
        {% set file_icon = 'bi-file-earmark-word-fill' %}
        {% set file_tone = 'primary' %}
        {% set file_kind = 'Word' %}
    {% endif %}
{% endif %}

<div class="modal-header">
    <div class="d-flex align-items-center gap-3 min-w-0">
        <span class="document-file-icon document-file-icon-{{ file_tone }}">
            <i class="bi {{ file_icon }}"></i>
        </span>
        <div class="min-w-0">
            <h2 class="modal-title fs-5 text-truncate">{{ document.name }}</h2>
            <p class="text-secondary small mb-0 text-truncate">{{ has_file ? file_name : 'Aucune pièce jointe associée' }}</p>
        </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
</div>
<div class="modal-body">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-uppercase text-secondary fw-semibold mb-2">Description</div>
                    <p class="mb-0">{{ document.description ?: 'Aucun descriptif renseigné.' }}</p>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-uppercase text-secondary fw-semibold mb-3">Informations</div>
                    <div class="d-grid gap-3">
                        {% if document.category %}
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-secondary">Catégorie</span>
                                <span class="fw-semibold text-end">{{ document.category }}</span>
                            </div>
                        {% endif %}
                        {% if document.internalReference %}
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-secondary">Référence interne</span>
                                <span class="fw-semibold text-end">{{ document.internalReference }}</span>
                            </div>
                        {% endif %}
                        {% if document.documentDate %}
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-secondary">Date du document</span>
                                <span class="fw-semibold">{{ document.documentDate|date('d/m/Y') }}</span>
                            </div>
                        {% endif %}
                        {% if document.issuer %}
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-secondary">Émetteur</span>
                                <span class="fw-semibold text-end">{{ document.issuer }}</span>
                            </div>
                        {% endif %}
                        {% if document.language %}
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-secondary">Langue</span>
                                <span class="fw-semibold text-end">{{ document.language }}</span>
                            </div>
                        {% endif %}
                        {% if document.version %}
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-secondary">Version</span>
                                <span class="fw-semibold text-end">{{ document.version }}</span>
                            </div>
                        {% endif %}
                        {% if document.expiresAt %}
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-secondary">Expiration</span>
                                <span class="fw-semibold">{{ document.expiresAt|date('d/m/Y') }}</span>
                            </div>
                        {% endif %}
                        <div class="d-flex justify-content-between gap-3">
                            <span class="text-secondary">Statut</span>
                            <span class="badge {{ document.statusBadgeClass }}">{{ document.statusLabel }}</span>
                        </div>
                        {% if document.confidentialityLabel %}
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-secondary">Confidentialité</span>
                                <span class="badge {{ document.confidentialityBadgeClass }}">{{ document.confidentialityLabel }}</span>
                            </div>
                        {% endif %}
                        {% if document.tagList is not empty %}
                            <div>
                                <span class="text-secondary d-block mb-2">Tags</span>
                                <div class="d-flex flex-wrap gap-1">
                                    {% for tag in document.tagList %}
                                        <span class="badge rounded-pill text-bg-light border">{{ tag }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="row g-3 small">
                        <div class="col-md-3">
                            <span class="text-secondary d-block">Type MIME</span>
                            <span class="fw-semibold">{{ has_file ? document.mimeType : file_kind }}</span>
                        </div>
                        <div class="col-md-3">
                            <span class="text-secondary d-block">Taille</span>
                            <span class="fw-semibold">{{ has_file ? (document.fileSize / 1024)|number_format(1, ',', ' ') ~ ' Ko' : '-' }}</span>
                        </div>
                        <div class="col-md-3">
                            <span class="text-secondary d-block">Créateur</span>
                            <span class="fw-semibold">{{ document.createdBy ? document.createdBy.displayName : 'Système' }}</span>
                        </div>
                        <div class="col-md-3">
                            <span class="text-secondary d-block">Ajouté le</span>
                            <span class="fw-semibold">{{ document.createdAt ? document.createdAt|date('d/m/Y H:i') : '-' }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
    {% if has_file and is_granted('DOCUMENT_EMAIL', document) %}
        <button class="btn btn-outline-primary" data-remote-modal="{{ path('app_document_email_modal', {id: document.id}) }}">
            <i class="bi bi-envelope me-1"></i>Envoyer par e-mail
        </button>
    {% endif %}
    {% if has_file and is_granted('DOCUMENT_DOWNLOAD', document) %}
        <a class="btn btn-primary" href="{{ path('app_document_download', {id: document.id}) }}">
            <i class="bi bi-download me-1"></i>Télécharger
        </a>
    {% endif %}
</div>
