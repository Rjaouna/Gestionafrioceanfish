{% set document = form.vars.data %}
{% set file_name = document.originalFileName|default('') %}
{% set file_name_lower = file_name|lower %}
{% set mime = document.mimeType|default('')|lower %}
{% set has_existing_file = document.id and document.fileName is not empty and file_name is not empty %}
{% set show_file_field = form.file.vars.required or not has_existing_file or form.file.vars.errors|length > 0 %}
{% set file_icon = 'bi-file-earmark' %}
{% set file_tone = 'secondary' %}
{% set file_kind = 'Fichier' %}
{% if has_existing_file %}
    {% if mime == 'application/pdf' or file_name_lower ends with '.pdf' %}
        {% set file_icon = 'bi-file-earmark-pdf-fill' %}
        {% set file_tone = 'danger' %}
        {% set file_kind = 'PDF' %}
    {% elseif 'spreadsheet' in mime or 'excel' in mime or file_name_lower ends with '.xls' or file_name_lower ends with '.xlsx' or file_name_lower ends with '.csv' %}
        {% set file_icon = 'bi-file-earmark-excel-fill' %}
        {% set file_tone = 'success' %}
        {% set file_kind = 'Excel' %}
    {% elseif 'word' in mime or file_name_lower ends with '.doc' or file_name_lower ends with '.docx' %}
        {% set file_icon = 'bi-file-earmark-word-fill' %}
        {% set file_tone = 'primary' %}
        {% set file_kind = 'Word' %}
    {% elseif 'powerpoint' in mime or file_name_lower ends with '.ppt' or file_name_lower ends with '.pptx' %}
        {% set file_icon = 'bi-file-earmark-ppt-fill' %}
        {% set file_tone = 'warning' %}
        {% set file_kind = 'PowerPoint' %}
    {% elseif mime starts with 'image/' %}
        {% set file_icon = 'bi-file-earmark-image-fill' %}
        {% set file_tone = 'info' %}
        {% set file_kind = 'Image' %}
    {% elseif mime starts with 'text/' %}
        {% set file_icon = 'bi-file-earmark-text-fill' %}
        {% set file_tone = 'secondary' %}
        {% set file_kind = 'Texte' %}
    {% endif %}
{% endif %}
{% set file_size_label = has_existing_file ? (document.fileSize >= 1048576 ? (document.fileSize / 1048576)|number_format(1, ',', ' ') ~ ' Mo' : (document.fileSize / 1024)|number_format(1, ',', ' ') ~ ' Ko') : 'Aucune pièce jointe' %}

{{ form_start(form, {attr: {'data-ajax-form': 'true'}}) }}
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">{{ title }}</h2>
            <p class="text-secondary small mb-0">Les fichiers sont stockés dans un espace privé, hors dossier public.</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        <div class="d-grid gap-4">
            <section>
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis">1</span>
                    <h3 class="h6 mb-0">Informations principales</h3>
                </div>
                <div class="row g-3">
                    <div class="col-lg-6">{{ form_row(form.name) }}</div>
                    <div class="col-lg-6">
                        <div data-document-file-panel>
                            {% if has_existing_file %}
                                <div class="document-current-file {{ show_file_field ? 'd-none' : '' }}" data-document-current-file>
                                    <span class="document-file-icon document-file-icon-{{ file_tone }}">
                                        <i class="bi {{ file_icon }}"></i>
                                    </span>
                                    <div class="min-w-0 flex-grow-1">
                                        <span class="document-current-file-label">Pièce jointe actuelle</span>
                                        <strong title="{{ file_name }}">{{ file_name }}</strong>
                                        <small>{{ file_kind }} · {{ file_size_label }}</small>
                                    </div>
                                    <button class="btn btn-outline-danger btn-sm" type="button" data-document-replace-file>
                                        <i class="bi bi-trash me-1"></i>Supprimer pour remplacer
                                    </button>
                                </div>
                                <div class="{{ show_file_field ? '' : 'd-none' }}" data-document-file-field>
                                    {{ form_row(form.file) }}
                                </div>
                            {% elseif document.id %}
                                <div class="document-current-file document-current-file-missing mb-2">
                                    <span class="document-file-icon document-file-icon-secondary">
                                        <i class="bi bi-file-earmark"></i>
                                    </span>
                                    <div class="min-w-0">
                                        <span class="document-current-file-label">Pièce jointe</span>
                                        <strong>Aucun fichier associé</strong>
                                        <small>Ajoutez un fichier pour compléter ce document.</small>
                                    </div>
                                </div>
                                {{ form_row(form.file) }}
                            {% else %}
                                {{ form_row(form.file) }}
                            {% endif %}
                        </div>
                    </div>
                    <div class="col-12">{{ form_row(form.description) }}</div>
                </div>
            </section>

            <section>
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis">2</span>
                    <h3 class="h6 mb-0">Classement</h3>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <div class="alert alert-light border small mb-0">
                            <i class="bi bi-magic text-primary me-1"></i>
                            La référence interne est générée automatiquement.
                            La date du document correspond à la date de création.
                            {% if document.internalReference %}
                                <span class="d-block mt-1 text-secondary">Référence actuelle : {{ document.internalReference }}</span>
                            {% endif %}
                            {% if document.documentDate %}
                                <span class="d-block text-secondary">Date actuelle : {{ document.documentDate|date('d/m/Y') }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-4">{{ form_row(form.category) }}</div>
                    <div class="col-md-6 col-xl-4">{{ form_row(form.issuer) }}</div>
                    <div class="col-md-6 col-xl-4">{{ form_row(form.language) }}</div>
                    <div class="col-12">{{ form_row(form.tags) }}</div>
                </div>
            </section>

            <section>
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis">3</span>
                    <h3 class="h6 mb-0">Gestion</h3>
                </div>
                <div class="row g-3">
                    <div class="col-md-6 col-xl-3">{{ form_row(form.status) }}</div>
                    <div class="col-md-6 col-xl-3">{{ form_row(form.expiresAt) }}</div>
                    <div class="col-md-6 col-xl-3">{{ form_row(form.confidentialityLevel) }}</div>
                    <div class="col-md-6 col-xl-3">{{ form_row(form.version) }}</div>
                </div>
            </section>
        </div>

        <datalist id="document-category-suggestions">
            <option value="Contrat">
            <option value="Facture">
            <option value="Administratif">
            <option value="Juridique">
            <option value="Technique">
            <option value="RH">
            <option value="Client">
            <option value="Fournisseur">
            <option value="Autre">
        </datalist>
        <datalist id="document-language-suggestions">
            <option value="Français">
            <option value="Anglais">
            <option value="Arabe">
            <option value="Portugais">
            <option value="Espagnol">
        </datalist>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>{{ submit_label }}
        </button>
    </div>
{{ form_end(form) }}
