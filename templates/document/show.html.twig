{% extends 'base.html.twig' %}

{% block title %}{{ document.name }} · Documents{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <a href="{{ path('app_document_index') }}" class="btn btn-link text-decoration-none px-0 mb-2">
            <i class="bi bi-arrow-left me-1"></i>Retour aux documents
        </a>
        <h1 class="h3 mb-1">{{ document.name }}</h1>
        <p class="text-secondary mb-0">{{ document.originalFileName }}</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        {% if is_granted('DOCUMENT_DOWNLOAD', document) %}
            <a class="btn btn-primary" href="{{ path('app_document_download', {id: document.id}) }}">
                <i class="bi bi-download me-1"></i>Télécharger
            </a>
        {% endif %}
        {% if is_granted('DOCUMENT_EMAIL', document) %}
            <button class="btn btn-outline-primary" data-remote-modal="{{ path('app_document_email_modal', {id: document.id}) }}">
                <i class="bi bi-envelope me-1"></i>Envoyer par e-mail
            </button>
        {% endif %}
        {% if is_granted('DOCUMENT_SHARE', document) %}
            <button class="btn btn-outline-success" data-remote-modal="{{ path('app_document_share_modal', {id: document.id}) }}">
                <i class="bi bi-share me-1"></i>Partager
            </button>
        {% endif %}
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="small text-uppercase text-secondary fw-semibold mb-2">Description</div>
                <p class="mb-0">{{ document.description ?: 'Aucun descriptif renseigné.' }}</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-grid gap-3">
                    <div class="d-flex justify-content-between gap-3">
                        <span class="text-secondary">Type</span>
                        <span class="fw-semibold text-end">{{ document.mimeType }}</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3">
                        <span class="text-secondary">Taille</span>
                        <span class="fw-semibold">{{ (document.fileSize / 1024)|number_format(1, ',', ' ') }} Ko</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3">
                        <span class="text-secondary">Créateur</span>
                        <span class="fw-semibold text-end">{{ document.createdBy ? document.createdBy.displayName : 'Système' }}</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3">
                        <span class="text-secondary">Créé le</span>
                        <span class="fw-semibold">{{ document.createdAt ? document.createdAt|date('d/m/Y H:i') : '-' }}</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3">
                        <span class="text-secondary">Statut</span>
                        <span class="badge {{ document.active ? 'text-bg-success' : 'text-bg-secondary' }}">{{ document.active ? 'Actif' : 'Archivé' }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
