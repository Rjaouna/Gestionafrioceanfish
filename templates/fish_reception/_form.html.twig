<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">{{ title }}</h1>
        <p class="text-secondary mb-0">Création et contrôle de la réception matière première.</p>
    </div>
    <a class="btn btn-outline-secondary" href="{{ path('app_fish_reception_index') }}">
        <i class="bi bi-arrow-left me-2"></i>Retour
    </a>
</div>

{{ form_start(form, {attr: {'data-ajax-form': 'true', 'data-fish-reception-excel-form': 'true', 'data-fish-reception-cost-form': 'true'}}) }}
    {% include 'fish_reception/_excel_import_toolbar.html.twig' %}
    <section class="card border-0 shadow-sm mb-4 fish-reception-operation-panel">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-5">
                    {{ form_row(form.operationType, {attr: form.operationType.vars.attr|merge({'data-fish-reception-operation': 'true'})}) }}
                </div>
                <div class="col-12 col-lg-7">
                    <div class="fish-reception-operation-summary">
                        <span class="fish-reception-operation-icon"><i class="bi bi-cash-coin"></i></span>
                        <div>
                            <strong data-fish-reception-operation-badge>{{ item.operationTypeLabel }}</strong>
                            <small data-fish-reception-operation-note></small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4 align-items-start">
        <div class="col-12 col-xl-8">
            <section class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">1. Reception</h2>
                    <p class="text-secondary small mb-0">Donnees du bon de livraison, fournisseur, produit et controle a l'arrivee.</p>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">{{ form_row(form.dateReception) }}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.heureDebutReception) }}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.heureFinReception) }}</div>
                        <div class="col-12 col-md-4">{% include 'fish_reception/_smart_choice_field.html.twig' with {form: form, field: form.fournisseur} %}</div>
                        <div class="col-12 col-md-4">{% include 'fish_reception/_smart_choice_field.html.twig' with {form: form, field: form.provenance} %}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.numeroBonLivraison) }}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.matriculeVehicule) }}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.chauffeur) }}</div>
                        <div class="col-12 col-md-4">{% include 'fish_reception/_smart_choice_field.html.twig' with {form: form, field: form.especePoisson} %}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.nomScientifique) }}</div>
                        <div class="col-12 col-md-4">{% include 'fish_reception/_smart_choice_field.html.twig' with {form: form, field: form.presentationProduit} %}</div>
                        <div class="col-12 col-md-4">{% include 'fish_reception/_smart_choice_field.html.twig' with {form: form, field: form.etatProduit} %}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.quantiteIndiqueeBl) }}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.quantiteReceptionnee) }}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.nombreCaissesReception) }}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.temperaturePoissonReception) }}</div>
                        <div class="col-12 col-md-4">{% include 'fish_reception/_smart_choice_field.html.twig' with {form: form, field: form.categorieFraicheur} %}</div>
                        <div class="col-12 col-md-4">{{ form_row(form.presenceGlace) }}</div>
                    </div>
                </div>
            </section>

            <section class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">2. Coûts d'entrée</h2>
                    <p class="text-secondary small mb-0">Base de calcul réutilisée ensuite dans le coût de revient.</p>
                </div>
                <div class="card-body">
                    <div class="fish-reception-cost-summary mb-3">
                        <div>
                            <span>Achat matière</span>
                            <strong><span data-fish-reception-cost-output="purchase">0,00</span> <span data-fish-reception-cost-currency>{{ item.receptionDevise }}</span></strong>
                        </div>
                        <div>
                            <span>Frais directs</span>
                            <strong><span data-fish-reception-cost-output="fees">0,00</span> <span data-fish-reception-cost-currency>{{ item.receptionDevise }}</span></strong>
                        </div>
                        <div>
                            <span>Coût réception</span>
                            <strong><span data-fish-reception-cost-output="total">0,00</span> <span data-fish-reception-cost-currency>{{ item.receptionDevise }}</span></strong>
                        </div>
                        <div>
                            <span>Coût / kg recu</span>
                            <strong><span data-fish-reception-cost-output="kg">0,00</span> <span data-fish-reception-cost-currency>{{ item.receptionDevise }}</span></strong>
                        </div>
                    </div>

                    <div class="fish-reception-cost-block mb-3" data-fish-reception-purchase-section>
                        <div class="fish-reception-cost-heading">
                            <span><i class="bi bi-basket2"></i></span>
                            <div>
                                <h3>Achat matière première</h3>
                                <p>Prix d'achat calculé avec la quantité réceptionnée.</p>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionPrixAchatKg, {attr: form.receptionPrixAchatKg.vars.attr|merge({'data-fish-reception-purchase-unit': 'true'})}) }}</div>
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionMontantAchatTotal, {attr: form.receptionMontantAchatTotal.vars.attr|merge({'data-fish-reception-purchase-total': 'true'})}) }}</div>
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionReferenceFacture) }}</div>
                        </div>
                    </div>

                    <div class="fish-reception-cost-block">
                        <div class="fish-reception-cost-heading">
                            <span><i class="bi bi-receipt"></i></span>
                            <div>
                                <h3>Frais directs reception</h3>
                                <p>Transport, manutention, glace, controle et autres frais.</p>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionFraisTransport, {attr: form.receptionFraisTransport.vars.attr|merge({'data-fish-reception-fee': 'true'})}) }}</div>
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionFraisDechargement, {attr: form.receptionFraisDechargement.vars.attr|merge({'data-fish-reception-fee': 'true'})}) }}</div>
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionFraisGlaceConsommables, {attr: form.receptionFraisGlaceConsommables.vars.attr|merge({'data-fish-reception-fee': 'true'})}) }}</div>
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionFraisControleQualite, {attr: form.receptionFraisControleQualite.vars.attr|merge({'data-fish-reception-fee': 'true'})}) }}</div>
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionAutresFrais, {attr: form.receptionAutresFrais.vars.attr|merge({'data-fish-reception-fee': 'true'})}) }}</div>
                            <div class="col-12 col-lg-4">{{ form_row(form.receptionDevise, {attr: form.receptionDevise.vars.attr|merge({'data-fish-reception-currency-input': 'true'})}) }}</div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-1">Observations et responsable</h2>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">{{ form_row(form.responsableProduction) }}</div>
                        <div class="col-12 col-md-6">{{ form_row(form.signatureResponsable) }}</div>
                        <div class="col-12">{{ form_row(form.observations) }}</div>
                    </div>
                </div>
            </section>
        </div>

        <aside class="col-12 col-xl-4">
            <div class="position-sticky" style="top: 1rem;">
                <section class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white border-0 pb-0">
                        <h2 class="h5 mb-1">Suivi automatique</h2>
                        <p class="text-secondary small mb-0">Numéros générés et état du stock réception.</p>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-6 text-secondary">Reception</dt>
                            <dd class="col-6 text-end fw-semibold">{{ item.numeroReception ?: 'Auto' }}</dd>
                            <dt class="col-6 text-secondary">Lot interne</dt>
                            <dd class="col-6 text-end fw-semibold">{{ item.numeroLot ?: 'Auto' }}</dd>
                            <dt class="col-6 text-secondary">Statut</dt>
                            <dd class="col-6 text-end"><span class="badge {{ item.statutBadgeClass }}">{{ item.statutLabel }}</span></dd>
                            <dt class="col-6 text-secondary">Envoye traitement</dt>
                            <dd class="col-6 text-end">{{ item.quantiteTotalePreparee|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                            <dt class="col-6 text-secondary">Reste à stocker</dt>
                            <dd class="col-6 text-end fw-semibold">{{ item.quantiteDisponibleReceptionValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                            <dt class="col-6 text-secondary">Reserve cout</dt>
                            <dd class="col-6 text-end">{{ item.quantiteUtiliseeProduction|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                            <dt class="col-6 text-secondary">Coût réception</dt>
                            <dd class="col-6 text-end fw-semibold"><span data-fish-reception-cost-output="total">{{ item.coutTotalReceptionValue|number_format(2, ',', ' ') }}</span> <span data-fish-reception-cost-currency>{{ item.receptionDevise }}</span></dd>
                            <dt class="col-6 text-secondary">Coût / kg</dt>
                            <dd class="col-6 text-end"><span data-fish-reception-cost-output="kg">{{ item.coutKgReceptionValue|number_format(2, ',', ' ') }}</span> <span data-fish-reception-cost-currency>{{ item.receptionDevise }}</span></dd>
                        </dl>
                        {% if item.locked %}
                            <div class="alert alert-warning small mb-0 mt-3">Cette réception est verrouillée.</div>
                        {% else %}
                            <div class="alert alert-info small mb-0 mt-3">Les numéros seront générés automatiquement à l'enregistrement.</div>
                        {% endif %}
                    </div>
                </section>

                <div class="d-grid gap-2">
                    <button class="btn btn-primary" type="submit">
                        <i class="bi bi-save me-2"></i>{{ submit_label }}
                    </button>
                </div>
            </div>
        </aside>
    </div>
    {{ form_rest(form) }}
{{ form_end(form) }}
