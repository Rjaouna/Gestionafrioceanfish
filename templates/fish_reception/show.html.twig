{% extends 'base.html.twig' %}

{% block title %}Reception {{ item.numeroReception }}{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Reception {{ item.numeroReception }}</h1>
        <p class="text-secondary mb-0">{{ item.fournisseur }} - {{ item.especePoisson }}</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="{{ path('app_fish_reception_index') }}">
            <i class="bi bi-arrow-left me-2"></i>Retour
        </a>
        {% include 'fish_reception/_actions.html.twig' with {item: item, size: ''} %}
    </div>
</div>

{% include 'fish_reception/_details_content.html.twig' with {item: item} %}
{% endblock %}
