{% extends 'base.html.twig' %}

{% import _self as ui %}

{% macro kg(value) %}{{ value|number_format(3, ',', ' ')|replace({',000': ''}) }} kg{% endmacro %}
{% macro temp(value) %}{{ value is not null ? value|number_format(2, ',', ' ') ~ ' C' : '-' }}{% endmacro %}
{% macro date(value) %}{{ value ? value|date('d/m/Y') : '-' }}{% endmacro %}
{% macro time(value) %}{{ value ? value|date('H:i') : '-' }}{% endmacro %}
{% macro datetime(value) %}{{ value ? value|date('d/m/Y H:i') : '-' }}{% endmacro %}
{% macro text(value) %}{{ value ?: '-' }}{% endmacro %}
{% macro row(label, value, class = '') %}
    <div class="reception-info-row">
        <span>{{ label }}</span>
        <strong class="{{ class }}">{{ value }}</strong>
    </div>
{% endmacro %}
{% macro metric(label, value, icon, tone = 'primary', detail = null) %}
    <div class="reception-metric">
        <span class="reception-metric-icon reception-tone-{{ tone }}"><i class="bi {{ icon }}"></i></span>
        <span class="reception-metric-copy">
            <span>{{ label }}</span>
            <strong>{{ value }}</strong>
            {% if detail %}<small>{{ detail }}</small>{% endif %}
        </span>
    </div>
{% endmacro %}

{% block title %}Reception {{ item.numeroReception }}{% endblock %}

{% block body %}
<div data-ajax-region="fishReceptionShow" data-refresh-url="{{ path('app_fish_reception_view_fragment', {id: item.id}) }}">
    {{ block('reception_show_content') }}
</div>
{% endblock %}

{% block reception_show_content %}
{% import _self as ui %}
{% set receivedWeight = item.quantiteReceptionneeValue %}
{% set initialStorageRate = receivedWeight > 0 ? (item.quantiteStockInitialEntreeValue / receivedWeight * 100) : 0 %}
{% set treatmentRate = receivedWeight > 0 ? (item.quantiteTotalePrepareeValue / receivedWeight * 100) : 0 %}
{% set frozenRate = item.quantiteEnTraitementValue > 0 ? (item.quantiteCongeleeValue / item.quantiteEnTraitementValue * 100) : 0 %}
{% set storedRate = item.quantiteCongeleeValue > 0 ? (item.quantiteStockeeValue / item.quantiteCongeleeValue * 100) : 0 %}
{% set packagedRate = item.quantiteStockeeValue > 0 ? (item.quantiteConditionneeValue / item.quantiteStockeeValue * 100) : 0 %}
{% set shippedRate = item.quantiteRemiseEnChambreValue > 0 ? (item.quantiteTotaleExpedieeValue / item.quantiteRemiseEnChambreValue * 100) : 0 %}
{% set workflow = [
    {label: 'Reception', icon: 'bi-clipboard2-check', done: item.receivedAt or item.statut != 'brouillon', detail: item.receivedAt ? item.receivedAt|date('d/m H:i') : item.statutLabel},
    {label: 'Stock initial', icon: 'bi-inboxes', done: item.quantiteStockInitialEntreeValue > 0.001, detail: ui.kg(item.quantiteStockInitialEntreeValue)},
    {label: 'Traitement', icon: 'bi-arrow-repeat', done: item.quantiteTotalePrepareeValue > 0.001, detail: ui.kg(item.quantiteTotalePreparee)},
    {label: 'Congelation', icon: 'bi-snow', done: item.quantiteCongeleeValue > 0.001, detail: ui.kg(item.quantiteCongelee)},
    {label: 'Cristallisation', icon: 'bi-box-seam', done: item.quantiteStockeeValue > 0.001, detail: ui.kg(item.quantiteStockee)},
    {label: 'Emballage + chambre', icon: 'bi-box-arrow-in-down', done: item.quantiteRemiseEnChambreValue > 0.001, detail: ui.kg(item.quantiteRemiseEnChambre)},
    {label: 'Expedition', icon: 'bi-truck', done: item.quantiteTotaleExpedieeValue > 0.001 or item.expeditedAt, detail: ui.kg(item.quantiteTotaleExpediee)}
] %}

<div class="reception-show">
    <section class="reception-show-hero">
        <div class="reception-show-hero-main">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <span class="badge text-bg-light border">Fiche réception</span>
                <span class="badge {{ item.statutBadgeClass }}">{{ item.statutLabel }}</span>
                {% if item.locked %}
                    <span class="badge text-bg-dark"><i class="bi bi-lock me-1"></i>Verrouillée</span>
                {% endif %}
            </div>
            <h1>Reception {{ item.numeroReception }}</h1>
            <div class="reception-show-subtitle">
                <span>{{ item.numeroLot }}</span>
                <span>{{ item.fournisseur }}</span>
                <span>{{ item.especePoisson }}</span>
            </div>
            <div class="reception-show-chips">
                <span><i class="bi bi-calendar3"></i>{{ ui.date(item.dateReception) }}</span>
                <span><i class="bi bi-geo-alt"></i>{{ item.provenance ?: 'Provenance non renseignée' }}</span>
                <span><i class="bi bi-truck-front"></i>{{ item.matriculeVehicule ?: 'Camion non renseigné' }}</span>
            </div>
        </div>
        <div class="reception-show-actions">
            <a class="btn btn-light" href="{{ path('app_fish_reception_index') }}">
                <i class="bi bi-arrow-left me-2"></i>Liste réceptions
            </a>
            {% include 'fish_reception/_actions.html.twig' with {item: item, size: ''} %}
        </div>
    </section>

    {% if item.statut == 'bloquee' %}
        <div class="alert alert-danger d-flex gap-3 align-items-start">
            <i class="bi bi-slash-circle fs-4"></i>
            <div>
                <strong>Reception bloquee</strong>
                <div>{{ item.blockReason ?: 'Réception bloquée.' }}</div>
            </div>
        </div>
    {% endif %}

    <section class="reception-metric-grid">
        {{ ui.metric('Stock initial', ui.kg(item.quantiteStockInitialEntreeValue), 'bi-inboxes', 'success', initialStorageRate|number_format(1, ',', ' ') ~ ' % stocke') }}
        {{ ui.metric('Quantité reçue', ui.kg(item.quantiteReceptionnee), 'bi-basket2', 'primary', item.nombreCaissesReception ~ ' caisses') }}
        {{ ui.metric('Préparée', ui.kg(item.quantiteTotalePreparee), 'bi-arrow-repeat', 'info', treatmentRate|number_format(1, ',', ' ') ~ ' % traitement') }}
        {{ ui.metric('Congelee', ui.kg(item.quantiteCongelee), 'bi-snow', 'primary', frozenRate|number_format(1, ',', ' ') ~ ' % tunnel') }}
        {{ ui.metric('Cristallisee', ui.kg(item.quantiteStockee), 'bi-box-seam', 'success', storedRate|number_format(1, ',', ' ') ~ ' % cristallisation') }}
        {{ ui.metric('Emballee en chambre', ui.kg(item.quantiteRemiseEnChambre), 'bi-box-arrow-in-down', 'success', packagedRate|number_format(1, ',', ' ') ~ ' % emballage') }}
        {{ ui.metric('Expediee', ui.kg(item.quantiteTotaleExpediee), 'bi-truck', 'dark', shippedRate|number_format(1, ',', ' ') ~ ' % expedition') }}
        {{ ui.metric('Coût réception/kg', item.coutKgReceptionValue|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise, 'bi-cash-coin', 'primary', item.operationTypeLabel) }}
    </section>

    <section class="reception-workflow">
        {% for step in workflow %}
            <div class="reception-step {{ step.done ? 'done' : 'pending' }}">
                <span class="reception-step-icon"><i class="bi {{ step.icon }}"></i></span>
                <span class="reception-step-copy">
                    <strong>{{ step.label }}</strong>
                    <small>{{ step.done ? step.detail : 'En attente' }}</small>
                </span>
            </div>
        {% endfor %}
    </section>

    <div class="reception-show-layout">
        <div class="reception-show-main">
            <section class="reception-panel">
                <div class="reception-panel-heading">
                    <span><i class="bi bi-clipboard2-pulse"></i></span>
                    <div>
                        <h2>Réception matière première</h2>
                        <p>Contrôle fournisseur, transport, quantité BL et qualité à l'arrivée.</p>
                    </div>
                </div>
                <div class="reception-info-grid">
                    {{ ui.row('Fournisseur', ui.text(item.fournisseur)) }}
                    {{ ui.row('Provenance', ui.text(item.provenance)) }}
                    {{ ui.row('Chauffeur', ui.text(item.chauffeur)) }}
                    {{ ui.row('Matricule camion', ui.text(item.matriculeVehicule)) }}
                    {{ ui.row('BL fournisseur', ui.text(item.numeroBonLivraison)) }}
                    {{ ui.row('Quantité BL', ui.kg(item.quantiteIndiqueeBl)) }}
                    {{ ui.row('Quantité réceptionnée', ui.kg(item.quantiteReceptionnee), 'text-primary') }}
                    {{ ui.row('Écart BL / réception', ui.kg(item.ecartBlReceptionValue), item.ecartBlReceptionValue < 0 ? 'text-danger' : 'text-success') }}
                    {{ ui.row('Espèce poisson', ui.text(item.especePoisson)) }}
                    {{ ui.row('Nom scientifique', ui.text(item.nomScientifique)) }}
                    {{ ui.row('Présentation', ui.text(item.presentationProduit)) }}
                    {{ ui.row('État produit', ui.text(item.etatProduit)) }}
                    {{ ui.row('Catégorie fraîcheur', ui.text(item.categorieFraicheur)) }}
                    {{ ui.row('Présence glace', item.presenceGlace ? 'Oui' : 'Non') }}
                    {{ ui.row('Température poisson', ui.temp(item.temperaturePoissonReception)) }}
                    {{ ui.row('Heure réception', ui.time(item.heureDebutReception) ~ ' - ' ~ ui.time(item.heureFinReception)) }}
                </div>
            </section>

            <section class="reception-panel">
                <div class="reception-panel-heading">
                    <span><i class="bi bi-inboxes"></i></span>
                    <div>
                        <h2>Stockage initial avant traitement</h2>
                        <p>Dispatch de la reception dans les chambres avant lancement en production.</p>
                    </div>
                </div>
                <div class="reception-info-grid mb-3">
                    {{ ui.row('Stocke initial', ui.kg(item.quantiteStockInitialEntreeValue), 'text-success') }}
                    {{ ui.row('Sorti vers traitement', ui.kg(item.quantiteStockInitialSortieValue), 'text-primary') }}
                    {{ ui.row('Retour annulation', ui.kg(item.quantiteStockInitialRetourValue), 'text-warning') }}
                    {{ ui.row('Reste stock initial', ui.kg(item.quantiteDisponibleTraitementSourceValue), 'text-warning') }}
                    {{ ui.row('Reste a stocker', ui.kg(item.quantiteDisponibleReceptionValue), 'text-warning') }}
                </div>
                {% if item.stockInitialDisponibleParEmplacement|length > 0 %}
                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Chambre / zone</th>
                                    <th class="text-end">Disponible</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for location, quantity in item.stockInitialDisponibleParEmplacement %}
                                <tr>
                                    <td>{{ location }}</td>
                                    <td class="text-end fw-semibold">{{ ui.kg(quantity) }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
                {% if item.storageMovements|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Action</th>
                                    <th>Chambre / zone</th>
                                    <th class="text-end">Quantite</th>
                                    <th>Temperature</th>
                                    <th>Par</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for movement in item.storageMovements %}
                                <tr>
                                    <td class="text-nowrap">{{ ui.date(movement.movementDate) }} {{ ui.time(movement.movementTime) }}</td>
                                    <td><span class="badge {{ movement.entryMovement ? 'text-bg-success' : 'text-bg-primary' }}">{{ movement.movementTypeLabel }}</span></td>
                                    <td>{{ movement.location }}</td>
                                    <td class="text-end fw-semibold {{ movement.entryMovement ? 'text-success' : 'text-primary' }}">{{ movement.entryMovement ? '+' : '-' }}{{ ui.kg(movement.absoluteQuantityKgValue) }}</td>
                                    <td>{{ ui.temp(movement.temperatureChamber) }} / {{ ui.temp(movement.temperatureProduct) }}</td>
                                    <td>{{ movement.createdBy ? movement.createdBy.displayName : '-' }}</td>
                                </tr>
                                {% if movement.note %}
                                    <tr>
                                        <td></td>
                                        <td colspan="5" class="small text-secondary">{{ movement.note }}</td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="text-secondary mb-0">Aucun stockage initial n'a encore ete enregistre.</p>
                {% endif %}
            </section>

            <section class="reception-panel">
                <div class="reception-panel-heading">
                    <span><i class="bi bi-cash-coin"></i></span>
                    <div>
                        <h2>Coûts d'entrée reception</h2>
                        <p>Achat matière et frais directs rattaches a la reception.</p>
                    </div>
                </div>
                <div class="reception-info-grid">
                    {{ ui.row('Type opération', item.operationTypeLabel) }}
                    {{ ui.row('Prix achat / kg', item.receptionPrixAchatKg|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise) }}
                    {{ ui.row('Montant achat total', item.coutAchatReceptionValue|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise, 'text-primary') }}
                    {{ ui.row('Frais transport', item.receptionFraisTransport|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise) }}
                    {{ ui.row('Déchargement / manutention', item.receptionFraisDechargement|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise) }}
                    {{ ui.row('Glace / consommables', item.receptionFraisGlaceConsommables|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise) }}
                    {{ ui.row('Contrôle qualité', item.receptionFraisControleQualite|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise) }}
                    {{ ui.row('Autres frais', item.receptionAutresFrais|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise) }}
                    {{ ui.row('Total frais réception', item.coutFraisReceptionValue|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise) }}
                    {{ ui.row('Coût total réception', item.coutTotalReceptionValue|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise, 'text-primary') }}
                    {{ ui.row('Coût réception / kg', item.coutKgReceptionValue|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise, 'text-success') }}
                    {{ ui.row('Référence facture', ui.text(item.receptionReferenceFacture)) }}
                </div>
            </section>

            <section class="reception-panel">
                <div class="reception-panel-heading">
                    <span><i class="bi bi-arrow-repeat"></i></span>
                    <div>
                        <h2>Traitement / Production</h2>
                        <p>Suivi des quantités préparées avant conditionnement.</p>
                    </div>
                </div>
                <div class="reception-progress-list">
                    <div>
                        <div class="d-flex justify-content-between gap-3 small mb-1"><span>Taux traitement</span><strong>{{ treatmentRate|number_format(2, ',', ' ') }} %</strong></div>
                        <div class="progress"><div class="progress-bar" style="width: {{ treatmentRate > 100 ? 100 : treatmentRate }}%"></div></div>
                    </div>
                </div>
                <div class="reception-info-grid mt-3">
                    {{ ui.row('Date traitement', item.dateDebutTraitement ? item.dateDebutTraitement|date('d/m/Y') : '-') }}
                    {{ ui.row('Heure début', ui.time(item.heureDebutTraitement)) }}
                    {{ ui.row('Température eau glacée', ui.temp(item.temperatureEauGlacee)) }}
                    {{ ui.row('Caisses après traitement', item.nombreCaissesApresTraitement) }}
                    {{ ui.row('Poids moyen caisse', ui.kg(item.poidsMoyenParCaisse)) }}
                    {{ ui.row('Moules', item.nombreMoules) }}
                    {{ ui.row('Caisses / palette', item.nombreCaissesParPalette) }}
                    {{ ui.row('Palettes', item.nombreTotalPalettes) }}
                    {{ ui.row('Quantite en traitement', ui.kg(item.quantiteEnTraitementValue), 'text-primary') }}
                    {{ ui.row('Reste a stocker initial', ui.kg(item.quantiteDisponibleReceptionValue), 'text-warning') }}
                    {{ ui.row('Reste a congeler', ui.kg(item.quantiteDisponibleTraitementValue), 'text-warning') }}
                </div>
            </section>

            <section class="reception-panel">
                <div class="reception-panel-heading">
                    <span><i class="bi bi-snow"></i></span>
                    <div>
                        <h2>Congelation et cristallisation</h2>
                        <p>Entree tunnel, sortie tunnel puis entree en chambre positive.</p>
                    </div>
                </div>
                <div class="reception-info-grid">
                    {{ ui.row('Tunnel', ui.text(item.tunnel)) }}
                    {{ ui.row('Date entree tunnel', ui.date(item.dateEntreeTunnel)) }}
                    {{ ui.row('Heure entree tunnel', ui.time(item.heureEntreeTunnel)) }}
                    {{ ui.row('Date sortie tunnel', ui.date(item.dateSortieTunnel)) }}
                    {{ ui.row('Heure sortie tunnel', ui.time(item.heureSortieTunnel)) }}
                    {{ ui.row('Duree tunnel', item.dureeTunnelHeuresValue|number_format(2, ',', ' ') ~ ' h') }}
                    {{ ui.row('Temperature tunnel', ui.temp(item.temperatureTunnel)) }}
                    {{ ui.row('Temperature coeur produit', ui.temp(item.temperatureCoeurProduit)) }}
                    {{ ui.row('Quantite congelee', ui.kg(item.quantiteCongelee), 'text-primary') }}
                    {{ ui.row('Reste a cristalliser', ui.kg(item.quantiteDisponibleCongelationValue), 'text-warning') }}
                    {{ ui.row('Chambre positive cristallisation', ui.text(item.chambreFroide)) }}
                    {{ ui.row('Date entree chambre', ui.date(item.dateEntreeStockage)) }}
                    {{ ui.row('Heure entree chambre', ui.time(item.heureEntreeStockage)) }}
                    {{ ui.row('Temperature chambre', ui.temp(item.temperatureChambre)) }}
                    {{ ui.row('Temperature produit cristallise', ui.temp(item.temperatureStockage)) }}
                    {{ ui.row('Quantite en cristallisation', ui.kg(item.quantiteStockee), 'text-success') }}
                    {{ ui.row('Duree cristallisation', item.dureeCristallisationHeuresValue|number_format(2, ',', ' ') ~ ' h') }}
                    {{ ui.row('Reste a emballer', ui.kg(item.quantiteDisponibleCristallisationValue), 'text-warning') }}
                </div>
            </section>

            <section class="reception-panel">
                <div class="reception-panel-heading">
                    <span><i class="bi bi-box"></i></span>
                    <div>
                        <h2>Emballage et expedition</h2>
                        <p>Emballage apres cristallisation avec retour immediat en chambre avant sortie client.</p>
                    </div>
                </div>
                <div class="reception-info-grid">
                    {{ ui.row('Date emballage', ui.date(item.dateConditionnement)) }}
                    {{ ui.row('Heure emballage', ui.time(item.heureDebutConditionnement) ~ ' - ' ~ ui.time(item.heureFinConditionnement)) }}
                    {{ ui.row('Produit conditionne', ui.text(item.produitConditionne)) }}
                    {{ ui.row('Quantite emballee', ui.kg(item.quantiteConditionnee), 'text-primary') }}
                    {{ ui.row('Poids net', ui.kg(item.poidsNet)) }}
                    {{ ui.row('Dechets emballage', ui.kg(item.poidsDechetsEmballage)) }}
                    {{ ui.row('Pertes emballage', ui.kg(item.poidsPertesEmballage)) }}
                    {{ ui.row('Ecart emballage', ui.kg(item.ecartEmballageValue), ((item.ecartEmballageValue > 1) or (item.ecartEmballageValue < -1)) ? 'text-danger' : 'text-success') }}
                    {{ ui.row('Duree emballage', item.dureeConditionnementHeuresValue|number_format(2, ',', ' ') ~ ' h') }}
                    {{ ui.row('Cout emballage', item.coutEmballageValue|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise, 'text-primary') }}
                    {{ ui.row('Cout emballage / kg net', item.coutKgEmballageValue|number_format(2, ',', ' ') ~ ' ' ~ item.receptionDevise) }}
                    {{ ui.row('Reste a emballer', ui.kg(item.quantiteDisponibleCristallisationValue), 'text-warning') }}
                    {{ ui.row('Chambre positive retour', ui.text(item.chambreRemiseEnChambre)) }}
                    {{ ui.row('Date retour chambre', ui.date(item.dateRemiseEnChambre)) }}
                    {{ ui.row('Heure retour chambre', ui.time(item.heureRemiseEnChambre)) }}
                    {{ ui.row('Temperature chambre retour', ui.temp(item.temperatureChambreRemise)) }}
                    {{ ui.row('Temperature produit retour', ui.temp(item.temperatureProduitRemise)) }}
                    {{ ui.row('Quantite en chambre apres emballage', ui.kg(item.quantiteRemiseEnChambre), 'text-success') }}
                    {{ ui.row('Duree chambre avant expedition', item.dureeRemiseChambreAvantExpeditionHeuresValue|number_format(2, ',', ' ') ~ ' h') }}
                    {{ ui.row('Reste a expedier', ui.kg(item.quantiteDisponibleStockageValue), 'text-warning') }}
                    {{ ui.row('Destination', ui.text(item.destinationFinaleClient)) }}
                    {{ ui.row('Date depart', ui.date(item.expeditionDateDepart)) }}
                    {{ ui.row('Heure depart', ui.time(item.expeditionHeureDepart)) }}
                    {{ ui.row('Camion expedition', ui.text(item.expeditionMatriculeVehicule)) }}
                    {{ ui.row('Chauffeur expedition', ui.text(item.expeditionChauffeur)) }}
                    {{ ui.row('Responsable chargement', ui.text(item.expeditionResponsableChargement)) }}
                    {{ ui.row('Temperature chargement', ui.temp(item.expeditionTemperatureProduit)) }}
                    {{ ui.row('Plomb / scelle', ui.text(item.expeditionNumeroPlomb)) }}
                    {{ ui.row('Quantite expediee', ui.kg(item.quantiteTotaleExpediee), 'text-primary') }}
                </div>
                {% if item.expeditionObservations %}
                    <div class="reception-note mt-3">
                        <span>Observation expédition</span>
                        <p>{{ item.expeditionObservations }}</p>
                    </div>
                {% endif %}
            </section>
        </div>

        <aside class="reception-show-side">
            <section class="reception-panel">
                <div class="reception-panel-heading compact">
                    <span><i class="bi bi-shield-check"></i></span>
                    <h2>État du lot</h2>
                </div>
                <div class="reception-status-stack">
                    <div>
                        <span>Statut</span>
                        <strong><span class="badge {{ item.statutBadgeClass }}">{{ item.statutLabel }}</span></strong>
                    </div>
                    <div>
                        <span>Utilisation</span>
                        <strong><span class="badge {{ item.usageBadgeClass }}">{{ item.usageLabel }}</span></strong>
                    </div>
                    <div>
                        <span>Lot verrouillé</span>
                        <strong>{{ item.locked ? 'Oui' : 'Non' }}</strong>
                    </div>
                    <div>
                        <span>Créé par</span>
                        <strong>{{ item.createdBy ? item.createdBy.displayName : '-' }}</strong>
                    </div>
                    <div>
                        <span>Dernière mise à jour</span>
                        <strong>{{ ui.datetime(item.updatedAt) }}</strong>
                    </div>
                </div>
            </section>

            <section class="reception-panel">
                <div class="reception-panel-heading compact">
                    <span><i class="bi bi-clock-history"></i></span>
                    <h2>Traçabilité actions</h2>
                </div>
                <div class="reception-timeline">
                    <div class="{{ item.quantiteStockInitialEntreeValue > 0.001 ? 'done' : '' }}"><span></span><strong>Stockage initial</strong><small>{{ ui.kg(item.quantiteStockInitialEntreeValue) }} stockes avant traitement</small></div>
                    <div class="{{ item.receivedAt ? 'done' : '' }}"><span></span><strong>Reception validée</strong><small>{{ ui.datetime(item.receivedAt) }}{% if item.receivedBy %} par {{ item.receivedBy.displayName }}{% endif %}</small></div>
                    <div class="{{ item.treatmentStartedAt ? 'done' : '' }}"><span></span><strong>Traitement lancé</strong><small>{{ ui.datetime(item.treatmentStartedAt) }}{% if item.treatmentStartedBy %} par {{ item.treatmentStartedBy.displayName }}{% endif %}</small></div>
                    <div class="{{ item.storedAt ? 'done' : '' }}"><span></span><strong>Cristallisation validee</strong><small>{{ ui.datetime(item.storedAt) }}{% if item.storedBy %} par {{ item.storedBy.displayName }}{% endif %}</small></div>
                    <div class="{{ item.remiseEnChambreAt ? 'done' : '' }}"><span></span><strong>Emballage + chambre valide</strong><small>{{ ui.datetime(item.remiseEnChambreAt) }}{% if item.remiseEnChambreBy %} par {{ item.remiseEnChambreBy.displayName }}{% endif %}</small></div>
                    <div class="{{ item.expeditedAt ? 'done' : '' }}"><span></span><strong>Expedition validee</strong><small>{{ ui.datetime(item.expeditedAt) }}{% if item.expeditedBy %} par {{ item.expeditedBy.displayName }}{% endif %}</small></div>
                    <div class="{{ item.closedAt ? 'done' : '' }}"><span></span><strong>Clôture</strong><small>{{ ui.datetime(item.closedAt) }}{% if item.closedBy %} par {{ item.closedBy.displayName }}{% endif %}</small></div>
                </div>
            </section>

            <section class="reception-panel">
                <div class="reception-panel-heading compact">
                    <span><i class="bi bi-person-badge"></i></span>
                    <h2>Responsables</h2>
                </div>
                <div class="reception-info-grid one-col">
                    {{ ui.row('Responsable production', ui.text(item.responsableProduction)) }}
                    {{ ui.row('Signature responsable', ui.text(item.signatureResponsable)) }}
                </div>
            </section>

            <section class="reception-panel">
                <div class="reception-panel-heading compact">
                    <span><i class="bi bi-chat-left-text"></i></span>
                    <h2>Observations</h2>
                </div>
                <div class="reception-note">
                    <p>{{ item.observations ?: 'Aucune observation.' }}</p>
                </div>
            </section>
        </aside>
    </div>

    <section class="reception-panel">
        <div class="reception-panel-heading">
            <span><i class="bi bi-calculator"></i></span>
            <div>
                <h2>Lots de production liés</h2>
                <p>Utilisation de cette réception dans les coûts de revient.</p>
            </div>
        </div>
        {% if item.coutRevients|length > 0 %}
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Lot coût de revient</th>
                            <th>Produit</th>
                            <th class="text-end">Kg utilisés</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for lot in item.coutRevients %}
                        <tr>
                            <td>{{ ui.date(lot.dateProduction) }}</td>
                            <td><a href="{{ path('app_cout_revient_view', {id: lot.id}) }}">{{ lot.numeroLot }}</a></td>
                            <td>{{ lot.produit }}</td>
                            <td class="text-end">{{ ui.kg(lot.poidsMisEnProduction) }}</td>
                            <td><span class="badge {{ lot.statutBadgeClass }}">{{ lot.statutLabel }}</span></td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-secondary mb-0">Aucun lot de production n'utilise encore cette réception.</p>
        {% endif %}
    </section>
</div>
{% endblock %}
