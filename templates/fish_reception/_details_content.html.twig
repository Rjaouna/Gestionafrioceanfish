{% set prepared_display = item.quantiteTotalePreparee|number_format(3, ',', ' ')|replace({',000': ''}) ~ ' kg' %}
{% set treatment_step_detail = item.treatmentExitCount > 1 ? item.treatmentExitCount ~ ' sorties / ' ~ prepared_display : prepared_display %}

<div class="row g-3 mb-4">
    <div class="col-6 col-xl">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Quantité reçue</div>
                <div class="h5 mb-0">{{ item.quantiteReceptionnee|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Envoyee traitement</div>
                <div class="h5 mb-0">{{ treatment_step_detail }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Reste à stocker</div>
                <div class="h5 mb-0">{{ item.quantiteDisponibleReceptionValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Taux traitement</div>
                <div class="h5 mb-0">{{ item.tauxUtilisation|number_format(2, ',', ' ') }} %</div>
                <span class="badge {{ item.usageBadgeClass }} mt-2">{{ item.usageLabel }}</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-xl">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Statut</div>
                <div><span class="badge {{ item.statutBadgeClass }}">{{ item.statutLabel }}</span></div>
                {% if item.locked %}
                    <div class="small text-secondary mt-2">Reception verrouillée</div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% if item.statut == 'bloquee' %}
    <div class="alert alert-danger">
        <i class="bi bi-slash-circle me-2"></i>{{ item.blockReason ?: 'Réception bloquée.' }}
    </div>
{% endif %}

<div class="row g-4">
    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Identification</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-secondary">Numero reception</dt><dd class="col-7">{{ item.numeroReception }}</dd>
                    <dt class="col-5 text-secondary">Numéro lot</dt><dd class="col-7">{{ item.numeroLot }}</dd>
                    <dt class="col-5 text-secondary">Date reception</dt><dd class="col-7">{{ item.dateReception ? item.dateReception|date('d/m/Y') : '-' }}</dd>
                    <dt class="col-5 text-secondary">Heure début</dt><dd class="col-7">{{ item.heureDebutReception ? item.heureDebutReception|date('H:i') : '-' }}</dd>
                    <dt class="col-5 text-secondary">Heure fin</dt><dd class="col-7">{{ item.heureFinReception ? item.heureFinReception|date('H:i') : '-' }}</dd>
                    <dt class="col-5 text-secondary">Créé par</dt><dd class="col-7">{{ item.createdBy ? item.createdBy.displayName : '-' }}</dd>
                    <dt class="col-5 text-secondary">Mis a jour</dt><dd class="col-7">{{ item.updatedAt ? item.updatedAt|date('d/m/Y H:i') : '-' }}</dd>
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Reception</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary">Fournisseur</dt><dd class="col-6 text-end">{{ item.fournisseur }}</dd>
                    <dt class="col-6 text-secondary">Provenance</dt><dd class="col-6 text-end">{{ item.provenance ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Matricule vehicule</dt><dd class="col-6 text-end">{{ item.matriculeVehicule ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Chauffeur</dt><dd class="col-6 text-end">{{ item.chauffeur ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Espèce poisson</dt><dd class="col-6 text-end">{{ item.especePoisson }}</dd>
                    <dt class="col-6 text-secondary">Nom scientifique</dt><dd class="col-6 text-end">{{ item.nomScientifique ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Présentation</dt><dd class="col-6 text-end">{{ item.presentationProduit }}</dd>
                    <dt class="col-6 text-secondary">État produit</dt><dd class="col-6 text-end">{{ item.etatProduit }}</dd>
                    <dt class="col-6 text-secondary">BL</dt><dd class="col-6 text-end">{{ item.numeroBonLivraison ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Quantité BL</dt><dd class="col-6 text-end">{{ item.quantiteIndiqueeBl|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Ecart BL</dt><dd class="col-6 text-end {{ item.ecartBlReceptionValue < 0 ? 'text-danger' : '' }}">{{ item.ecartBlReceptionValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Caisses reception</dt><dd class="col-6 text-end">{{ item.nombreCaissesReception }}</dd>
                    <dt class="col-6 text-secondary">Temp. poisson</dt><dd class="col-6 text-end">{{ item.temperaturePoissonReception is not null ? item.temperaturePoissonReception|number_format(2, ',', ' ') ~ ' C' : '-' }}</dd>
                    <dt class="col-6 text-secondary">Fraicheur</dt><dd class="col-6 text-end">{{ item.categorieFraicheur }}</dd>
                    <dt class="col-6 text-secondary">Glace</dt><dd class="col-6 text-end">{{ item.presenceGlace ? 'Oui' : 'Non' }}</dd>
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Traitement / Production</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary">Date traitement</dt><dd class="col-6 text-end">{{ item.dateDebutTraitement ? item.dateDebutTraitement|date('d/m/Y') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Heure début</dt><dd class="col-6 text-end">{{ item.heureDebutTraitement ? item.heureDebutTraitement|date('H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Temp. eau glacee</dt><dd class="col-6 text-end">{{ item.temperatureEauGlacee is not null ? item.temperatureEauGlacee|number_format(2, ',', ' ') ~ ' C' : '-' }}</dd>
                    <dt class="col-6 text-secondary">Caisses après traitement</dt><dd class="col-6 text-end">{{ item.nombreCaissesApresTraitement }}</dd>
                    <dt class="col-6 text-secondary">Poids moyen caisse</dt><dd class="col-6 text-end">{{ item.poidsMoyenParCaisse|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Moules</dt><dd class="col-6 text-end">{{ item.nombreMoules }}</dd>
                    <dt class="col-6 text-secondary">Caisses / palette</dt><dd class="col-6 text-end">{{ item.nombreCaissesParPalette }}</dd>
                    <dt class="col-6 text-secondary">Palettes</dt><dd class="col-6 text-end">{{ item.nombreTotalPalettes }}</dd>
                    <dt class="col-6 text-secondary">Quantite en traitement</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteEnTraitementValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">PF envoye tunnel</dt><dd class="col-6 text-end">{{ item.quantiteCongelee|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Dechets traitement</dt><dd class="col-6 text-end">{{ item.poidsDechetsTraitement|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Pertes traitement</dt><dd class="col-6 text-end">{{ item.poidsPertesTraitement|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Ecart traitement</dt><dd class="col-6 text-end {{ item.ecartTraitementValue > 1 ? 'text-warning' : 'text-success' }}">{{ item.ecartTraitementValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Reste a classer</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteDisponibleTraitementValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                </dl>
                {% if item.treatmentExitRows|length > 0 %}
                    <div class="table-responsive mt-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date sortie</th>
                                    <th class="text-end">Sortie</th>
                                    <th class="text-end">PF</th>
                                    <th class="text-end">Dechets</th>
                                    <th class="text-end">Pertes</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for row in item.treatmentExitRows %}
                                {% set movement = row.movement %}
                                <tr>
                                    <td>{{ movement.movementDate ? movement.movementDate|date('d/m/Y') : '-' }} {{ movement.movementTime ? movement.movementTime|date('H:i') : '' }}</td>
                                    <td class="text-end fw-semibold">{{ movement.absoluteQuantityKgValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</td>
                                    <td class="text-end">{{ row.product is not null ? row.product|number_format(3, ',', ' ')|replace({',000': ''}) ~ ' kg' : '-' }}</td>
                                    <td class="text-end">{{ row.waste is not null ? row.waste|number_format(3, ',', ' ')|replace({',000': ''}) ~ ' kg' : '-' }}</td>
                                    <td class="text-end">{{ row.loss is not null ? row.loss|number_format(3, ',', ' ')|replace({',000': ''}) ~ ' kg' : '-' }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Coûts d'entrée reception</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary">Type opération</dt><dd class="col-6 text-end">{{ item.operationTypeLabel }}</dd>
                    <dt class="col-6 text-secondary">Prix achat / kg</dt><dd class="col-6 text-end">{{ item.receptionPrixAchatKg|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Achat total</dt><dd class="col-6 text-end">{{ item.coutAchatReceptionValue|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Transport</dt><dd class="col-6 text-end">{{ item.receptionFraisTransport|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Dechargement</dt><dd class="col-6 text-end">{{ item.receptionFraisDechargement|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Glace / consommables</dt><dd class="col-6 text-end">{{ item.receptionFraisGlaceConsommables|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Contrôle qualité</dt><dd class="col-6 text-end">{{ item.receptionFraisControleQualite|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Autres frais</dt><dd class="col-6 text-end">{{ item.receptionAutresFrais|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Coût total réception</dt><dd class="col-6 text-end fw-semibold">{{ item.coutTotalReceptionValue|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Coût / kg</dt><dd class="col-6 text-end fw-semibold">{{ item.coutKgReceptionValue|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Facture</dt><dd class="col-6 text-end">{{ item.receptionReferenceFacture ?: '-' }}</dd>
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Conditionnement / Emballage</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary">Date conditionnement</dt><dd class="col-6 text-end">{{ item.dateConditionnement ? item.dateConditionnement|date('d/m/Y') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Heure début</dt><dd class="col-6 text-end">{{ item.heureDebutConditionnement ? item.heureDebutConditionnement|date('H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Heure fin</dt><dd class="col-6 text-end">{{ item.heureFinConditionnement ? item.heureFinConditionnement|date('H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Produit</dt><dd class="col-6 text-end">{{ item.produitConditionne ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Quantité emballée</dt><dd class="col-6 text-end">{{ item.quantiteConditionnee|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Poids net</dt><dd class="col-6 text-end">{{ item.poidsNet|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Déchets emballage</dt><dd class="col-6 text-end">{{ item.poidsDechetsEmballage|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Pertes emballage</dt><dd class="col-6 text-end">{{ item.poidsPertesEmballage|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Écart emballage</dt><dd class="col-6 text-end {{ ((item.ecartEmballageValue > 1) or (item.ecartEmballageValue < -1)) ? 'text-danger' : 'text-success' }}">{{ item.ecartEmballageValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Durée emballage</dt><dd class="col-6 text-end">{{ item.dureeConditionnementHeuresValue|number_format(2, ',', ' ') }} h</dd>
                    <dt class="col-6 text-secondary">Coût emballage</dt><dd class="col-6 text-end fw-semibold">{{ item.coutEmballageValue|number_format(2, ',', ' ') }} {{ item.receptionDevise }}</dd>
                    <dt class="col-6 text-secondary">Reste a remettre chambre</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteDisponibleEmballageValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Congelation</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary">Tunnel</dt><dd class="col-6 text-end">{{ item.tunnel ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Date entree</dt><dd class="col-6 text-end">{{ item.dateEntreeTunnel ? item.dateEntreeTunnel|date('d/m/Y') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Heure entree</dt><dd class="col-6 text-end">{{ item.heureEntreeTunnel ? item.heureEntreeTunnel|date('H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Heure sortie</dt><dd class="col-6 text-end">{{ item.heureSortieTunnel ? item.heureSortieTunnel|date('H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Durée tunnel</dt><dd class="col-6 text-end">{{ item.dureeTunnelHeuresValue|number_format(2, ',', ' ') }} h</dd>
                    <dt class="col-6 text-secondary">Temp. tunnel</dt><dd class="col-6 text-end">{{ item.temperatureTunnel is not null ? item.temperatureTunnel|number_format(2, ',', ' ') ~ ' C' : '-' }}</dd>
                    <dt class="col-6 text-secondary">Jour congélation</dt><dd class="col-6 text-end">{{ item.dateSortieTunnel ? item.dateSortieTunnel|date('d/m/Y') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Temp. a coeur</dt><dd class="col-6 text-end">{{ item.temperatureCoeurProduit is not null ? item.temperatureCoeurProduit|number_format(2, ',', ' ') ~ ' C' : '-' }}</dd>
                    <dt class="col-6 text-secondary">Produit fini congele</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteCongelee|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Reste a cristalliser</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteDisponibleCongelationValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Cristallisation / emballage + chambre</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary">Chambre froide</dt><dd class="col-6 text-end">{{ item.chambreFroide ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Temp. chambre</dt><dd class="col-6 text-end">{{ item.temperatureChambre is not null ? item.temperatureChambre|number_format(2, ',', ' ') ~ ' C' : '-' }}</dd>
                    <dt class="col-6 text-secondary">Temp. produit stocke</dt><dd class="col-6 text-end">{{ item.temperatureStockage is not null ? item.temperatureStockage|number_format(2, ',', ' ') ~ ' C' : '-' }}</dd>
                    <dt class="col-6 text-secondary">Date entree</dt><dd class="col-6 text-end">{{ item.dateEntreeStockage ? item.dateEntreeStockage|date('d/m/Y') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Heure entree</dt><dd class="col-6 text-end">{{ item.heureEntreeStockage ? item.heureEntreeStockage|date('H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Quantité stockée</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteStockee|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Reste a emballer</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteDisponibleCristallisationValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Chambre retour</dt><dd class="col-6 text-end">{{ item.chambreRemiseEnChambre ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Date retour</dt><dd class="col-6 text-end">{{ item.dateRemiseEnChambre ? item.dateRemiseEnChambre|date('d/m/Y') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Heure retour</dt><dd class="col-6 text-end">{{ item.heureRemiseEnChambre ? item.heureRemiseEnChambre|date('H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Poids net en chambre</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteExpediableValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Reste à expédier</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteDisponibleStockageValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Expédition</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary">Derniere expedition</dt><dd class="col-6 text-end">{{ item.expeditedAt ? item.expeditedAt|date('d/m/Y H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Par</dt><dd class="col-6 text-end">{{ item.expeditedBy ? item.expeditedBy.displayName : '-' }}</dd>
                    <dt class="col-6 text-secondary">Quantité expédiée</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteTotaleExpediee|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Reste à expédier</dt><dd class="col-6 text-end fw-semibold">{{ item.quantiteDisponibleStockageValue|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</dd>
                    <dt class="col-6 text-secondary">Destination</dt><dd class="col-6 text-end">{{ item.destinationFinaleClient ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Date départ</dt><dd class="col-6 text-end">{{ item.expeditionDateDepart ? item.expeditionDateDepart|date('d/m/Y') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Heure départ</dt><dd class="col-6 text-end">{{ item.expeditionHeureDepart ? item.expeditionHeureDepart|date('H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Camion</dt><dd class="col-6 text-end">{{ item.expeditionMatriculeVehicule ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Chauffeur</dt><dd class="col-6 text-end">{{ item.expeditionChauffeur ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Responsable chargement</dt><dd class="col-6 text-end">{{ item.expeditionResponsableChargement ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Temp. chargement</dt><dd class="col-6 text-end">{{ item.expeditionTemperatureProduit is not null ? item.expeditionTemperatureProduit|number_format(2, ',', ' ') ~ ' C' : '-' }}</dd>
                    <dt class="col-6 text-secondary">Plomb / scellé</dt><dd class="col-6 text-end">{{ item.expeditionNumeroPlomb ?: '-' }}</dd>
                    {% if item.expeditionObservations %}
                        <dt class="col-12 text-secondary">Observation expédition</dt><dd class="col-12 mb-0 text-pre-wrap">{{ item.expeditionObservations }}</dd>
                    {% endif %}
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Actions et signatures</h2></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6 text-secondary">Reception validée</dt><dd class="col-6 text-end">{{ item.receivedAt ? item.receivedAt|date('d/m/Y H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Par</dt><dd class="col-6 text-end">{{ item.receivedBy ? item.receivedBy.displayName : '-' }}</dd>
                    <dt class="col-6 text-secondary">Traitement lancé</dt><dd class="col-6 text-end">{{ item.treatmentStartedAt ? item.treatmentStartedAt|date('d/m/Y H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Cristallisation validée</dt><dd class="col-6 text-end">{{ item.storedAt ? item.storedAt|date('d/m/Y H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Retour chambre apres emballage</dt><dd class="col-6 text-end">{{ item.remiseEnChambreAt ? item.remiseEnChambreAt|date('d/m/Y H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Expédition validée</dt><dd class="col-6 text-end">{{ item.expeditedAt ? item.expeditedAt|date('d/m/Y H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Clôturée</dt><dd class="col-6 text-end">{{ item.closedAt ? item.closedAt|date('d/m/Y H:i') : '-' }}</dd>
                    <dt class="col-6 text-secondary">Responsable</dt><dd class="col-6 text-end">{{ item.responsableProduction ?: '-' }}</dd>
                    <dt class="col-6 text-secondary">Signature</dt><dd class="col-6 text-end">{{ item.signatureResponsable ?: '-' }}</dd>
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Observations</h2></div>
            <div class="card-body">
                <p class="mb-0 text-pre-wrap">{{ item.observations ?: 'Aucune observation.' }}</p>
            </div>
        </section>
    </div>

    <div class="col-12">
        <section class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pb-0"><h2 class="h5 mb-0">Lots de production liés</h2></div>
            <div class="card-body">
                {% if item.coutRevients|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Lot coût de revient</th>
                                    <th>Produit</th>
                                    <th class="text-end">Kg utilisés</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for lot in item.coutRevients %}
                                <tr>
                                    <td>{{ lot.dateProduction ? lot.dateProduction|date('d/m/Y') : '-' }}</td>
                                    <td><a href="{{ path('app_cout_revient_view', {id: lot.id}) }}">{{ lot.numeroLot }}</a></td>
                                    <td>{{ lot.produit }}</td>
                                    <td class="text-end">{{ lot.poidsMisEnProduction|number_format(3, ',', ' ')|replace({',000': ''}) }} kg</td>
                                    <td><span class="badge {{ lot.statutBadgeClass }}">{{ lot.statutLabel }}</span></td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="text-secondary mb-0">Aucun lot de production n'utilise encore cette réception.</p>
                {% endif %}
            </div>
        </section>
    </div>
</div>
