{% set overview = factory_storage_overview|default({}) %}
{% set spaces = overview.spaces|default([]) %}

<section class="mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
        <div>
            <h2 class="h5 mb-1">Etat des espaces usine</h2>
            <div class="text-secondary small">Uniquement les espaces declares dans Composition usine.</div>
        </div>
        <span class="badge text-bg-light">{{ overview.total_stock_display|default('0 kg') }} en cours</span>
    </div>

    {% if spaces is empty %}
        <div class="card border-0 shadow-sm">
            <div class="card-body text-secondary small">
                Aucun espace usine declare. Ajoutez vos tunnels, chambres et zones dans Composition usine.
            </div>
        </div>
    {% else %}
        <div class="row g-2">
            {% for space in spaces %}
                <div class="col-6 col-md-4 col-xl-2">
                    <article class="card border-0 shadow-sm h-100">
                        <div class="card-body p-2 text-center">
                            <div class="d-flex justify-content-between align-items-start gap-1 mb-1">
                                <span class="badge text-bg-light factory-space-badge text-truncate" title="{{ space.load_display }} / {{ space.capacity_display }}">
                                    {{ space.load_display }} / {{ space.capacity_display }}
                                </span>
                                <span class="badge text-bg-light factory-space-badge text-truncate" title="Libre : {{ space.free_display }}">
                                    Libre {{ space.free_display }}
                                </span>
                            </div>

                            <div class="dashboard-pie-shell mx-auto mb-2 factory-space-pie">
                                <svg class="dashboard-pie factory-space-pie-svg" viewBox="0 0 44 44" role="img" aria-label="Remplissage {{ space.name }}">
                                    <circle class="dashboard-pie-bg" cx="22" cy="22" r="16"></circle>
                                    {% if space.progress > 0 %}
                                        <circle
                                            class="dashboard-pie-segment text-{{ space.tone }}"
                                            cx="22"
                                            cy="22"
                                            r="16"
                                            pathLength="100"
                                            stroke-dasharray="{{ space.progress }} {{ 100 - space.progress }}"
                                            stroke-dashoffset="0"
                                            style="stroke: currentColor;"
                                        ></circle>
                                    {% endif %}
                                </svg>
                                <div class="dashboard-pie-center">
                                    <strong>{{ space.percent_display }}</strong>
                                    <span>{{ space.state_label }}</span>
                                </div>
                            </div>

                            <div class="min-w-0">
                                <div class="small fw-semibold text-truncate" title="{{ space.name }}">{{ space.name }}</div>
                            </div>
                        </div>
                    </article>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</section>
