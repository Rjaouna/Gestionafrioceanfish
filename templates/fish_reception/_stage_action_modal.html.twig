{{ form_start(form, {attr: form.vars.attr|merge({'data-ajax-form': 'true'})}) }}
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">{{ title }}</h2>
            <p class="text-secondary small mb-0">{{ item.numeroReception }} - {{ item.fournisseur }} - {{ item.especePoisson }}</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        {% include 'fish_reception/_excel_import_toolbar.html.twig' %}
        <div class="alert alert-info small">
            <i class="bi {{ icon }} me-2"></i>{{ message }}
        </div>
        <div class="row g-3">
            {% for child in form %}
                {% if child.vars.name != '_token' %}
                    {% if child.vars.attr['data-reception-smart-select']|default(false) %}
                        <div class="col-md-6">
                            {% include 'fish_reception/_smart_choice_field.html.twig' with {form: form, field: child} %}
                        </div>
                    {% elseif not child.vars.attr['data-reception-smart-custom-input']|default(false) %}
                        <div class="{{ child.vars.name in ['quantity', 'reason'] ? 'col-12' : 'col-md-6' }}">
                            {{ form_row(child) }}
                        </div>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>
        {% if form.vars.attr['data-freezing-capacity-form']|default(false) or form.vars.attr['data-factory-capacity-form']|default(false) %}
            <div class="mt-3" data-freezing-capacity-feedback data-factory-capacity-feedback></div>
        {% endif %}
        {{ form_rest(form) }}
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn {{ button_class }}">
            <i class="bi {{ icon }} me-2"></i>Confirmer
        </button>
    </div>
{{ form_end(form) }}
