{% set is_packaging_form = form.vars.attr['data-fish-packaging-form']|default(false) %}
{% set is_freezing_form = form.vars.attr['data-fish-freezing-form']|default(false) %}
{% set field_col = is_packaging_form ? 'col-md-4' : 'col-md-6' %}
{{ form_start(form, {attr: form.vars.attr|merge({'data-ajax-form': 'true'})}) }}
    <div class="modal-header">
        <div>
            <h2 class="modal-title fs-5">{{ title }}</h2>
            <p class="text-secondary small mb-0">{{ item.numeroReception }} - {{ item.fournisseur }} - {{ item.especePoisson }}</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
    </div>
    <div class="modal-body">
        {% include 'fish_reception/_excel_import_toolbar.html.twig' %}
        <div class="alert alert-info small">
            <i class="bi {{ icon }} me-2"></i>{{ message }}
        </div>
        <div class="row g-3">
            {% for child in form %}
                {% if child.vars.name != '_token' %}
                    {% if child.vars.attr['data-reception-smart-select']|default(false) %}
                        <div class="{{ field_col }}">
                            {% include 'fish_reception/_smart_choice_field.html.twig' with {form: form, field: child} %}
                        </div>
                    {% elseif not child.vars.attr['data-reception-smart-custom-input']|default(false) %}
                        <div class="{{ child.vars.name in ['quantity', 'reason'] ? 'col-12' : field_col }}">
                            {{ form_row(child) }}
                        </div>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>
        {% if is_packaging_form %}
            <div class="mt-3 fish-packaging-balance" data-fish-packaging-summary data-currency="{{ item.receptionDevise|default('MAD') }}">
                <div class="row g-2">
                    <div class="col-6 col-lg-3">
                        <div class="border rounded-3 p-2 h-100 bg-white">
                            <span class="d-block small text-secondary">Durée</span>
                            <strong data-fish-packaging-output="duration">0,00 h</strong>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="border rounded-3 p-2 h-100 bg-white">
                            <span class="d-block small text-secondary">Net + déchets + pertes</span>
                            <strong data-fish-packaging-output="total">0 kg</strong>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="border rounded-3 p-2 h-100 bg-white">
                            <span class="d-block small text-secondary">Écart</span>
                            <strong data-fish-packaging-output="gap">0 kg</strong>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="border rounded-3 p-2 h-100 bg-white">
                            <span class="d-block small text-secondary">Coût emballage</span>
                            <strong data-fish-packaging-output="cost">0,00 MAD</strong>
                        </div>
                    </div>
                </div>
                <div class="alert alert-secondary small mb-0 mt-2" data-fish-packaging-status>
                    Saisissez les poids et les heures pour contrôler l'écart et le coût.
                </div>
            </div>
        {% endif %}
        {% if is_freezing_form %}
            <div class="mt-3 fish-freezing-balance" data-fish-freezing-summary>
                <div class="row g-2">
                    <div class="col-12 col-lg-4">
                        <div class="border rounded-3 p-2 h-100 bg-white">
                            <span class="d-block small text-secondary">Durée tunnel</span>
                            <strong data-fish-freezing-output="duration">0,00 h</strong>
                        </div>
                    </div>
                    <div class="col-12 col-lg-8">
                        <div class="alert alert-secondary small mb-0 h-100" data-fish-freezing-status>
                            Renseignez l'heure d'entrée et l'heure de sortie tunnel pour calculer la durée utilisée dans les charges horaires.
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
        {% if form.vars.attr['data-freezing-capacity-form']|default(false) or form.vars.attr['data-factory-capacity-form']|default(false) %}
            <div class="mt-3" data-freezing-capacity-feedback data-factory-capacity-feedback></div>
        {% endif %}
        {{ form_rest(form) }}
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn {{ button_class }}">
            <i class="bi {{ icon }} me-2"></i>Confirmer
        </button>
    </div>
{{ form_end(form) }}
