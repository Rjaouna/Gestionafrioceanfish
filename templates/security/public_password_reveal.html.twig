<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="color-scheme" content="light">
        <title>Mot de passe sécurisé · Afriocean fish Gestion</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2224%22 fill=%22%230d6efd%22/><path d=%22M37 58h54v48H37zM47 58V42a17 17 0 0134 0v16%22 fill=%22none%22 stroke=%22white%22 stroke-width=%2210%22/><circle cx=%2264%22 cy=%2280%22 r=%226%22 fill=%22white%22/></svg>">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet">
        {{ importmap('app') }}
    </head>
    <body>
        <div id="ajax-alerts" class="position-fixed top-0 end-0 p-3 ajax-alerts" aria-live="polite"></div>
        <main class="public-secret-shell">
            <div class="public-secret-card">
                <span class="d-inline-flex align-items-center justify-content-center rounded-4 bg-primary text-white fs-1 login-mark mb-3">
                    <i class="bi bi-shield-lock"></i>
                </span>

                {% if password %}
                    <p class="text-uppercase text-primary fw-semibold small mb-2">Lien ouvert avec succès</p>
                    <h1 class="h3 fw-bold mb-2">Mot de passe sécurisé</h1>
                    <p class="text-secondary mb-4">Ce lien vient d’être détruit. Copiez le mot de passe maintenant avant de fermer cette page.</p>

                    <div data-secret-field>
                        <label for="publicPasswordValue" class="form-label visually-hidden">Mot de passe</label>
                        <div class="input-group input-group-lg">
                            <input type="password" class="form-control secret-reveal-input" id="publicPasswordValue" value="{{ password }}" readonly data-secret-input autocomplete="off">
                            <button type="button" class="btn btn-outline-secondary secret-action" data-secret-toggle aria-label="Afficher le mot de passe pendant 2 secondes" title="Afficher pendant 2 secondes">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button type="button" class="btn btn-primary secret-action" data-secret-copy aria-label="Copier le mot de passe" title="Copier">
                                <i class="bi bi-copy"></i>
                            </button>
                        </div>
                    </div>
                {% else %}
                    <p class="text-uppercase text-danger fw-semibold small mb-2">Lien indisponible</p>
                    <h1 class="h3 fw-bold mb-2">Ce lien n’est plus valide</h1>
                    <p class="text-secondary mb-0">Il a déjà été ouvert, supprimé, ou sa durée de validité de 3 jours est dépassée.</p>
                {% endif %}
            </div>
        </main>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    </body>
</html>
