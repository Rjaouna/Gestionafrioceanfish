{% extends 'base.html.twig' %}

{% block title %}Paiements interimaires{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Paiements interimaires</h1>
        <p class="text-secondary mb-0">{{ pagination.total }} paiement{{ pagination.total > 1 ? 's' : '' }} visible{{ pagination.total > 1 ? 's' : '' }}.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="{{ path('app_interim_attendance_details') }}">
            <i class="bi bi-clipboard-data me-2"></i>Details pointage
        </a>
        <a class="btn btn-outline-secondary" href="{{ path('app_interim_attendance_index') }}">
            <i class="bi bi-calendar-check me-2"></i>Pointage
        </a>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createInterimPaymentModal">
            <i class="bi bi-wallet2 me-2"></i>Nouveau paiement
        </button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Total filtre</div>
                <div class="h3 mb-0">{{ totals.amount|number_format(2, ',', ' ') }} MAD</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Payes</div>
                <div class="h5 mb-0 text-success">{{ totals.paid|number_format(2, ',', ' ') }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">A payer</div>
                <div class="h5 mb-0 text-warning">{{ totals.pending|number_format(2, ',', ' ') }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Paiements</div>
                <div class="h5 mb-0">{{ totals.count }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-secondary">Interimaires</div>
                <div class="h5 mb-0">{{ totals.workers }}</div>
            </div>
        </div>
    </div>
</div>

<form class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-xl-3">
                <label class="form-label" for="paymentSearch">Recherche</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="paymentSearch" class="form-control" type="search" name="q" value="{{ filters.q }}" placeholder="Nom, matricule, reference">
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <label class="form-label" for="paymentWorker">Interimaire</label>
                <select id="paymentWorker" class="form-select" name="workerId">
                    <option value="">Tous</option>
                    {% for worker in workers %}
                        <option value="{{ worker.id }}" {{ filters.workerId == worker.id ? 'selected' : '' }}>{{ worker.fullName }} - {{ worker.registrationNumber ?: 'sans matricule' }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-6 col-md-3 col-xl-2">
                <label class="form-label" for="paymentStatus">Statut</label>
                <select id="paymentStatus" class="form-select" name="status">
                    <option value="">Tous</option>
                    {% for value, label in status_choices %}
                        <option value="{{ value }}" {{ filters.status == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-6 col-md-3 col-xl-2">
                <label class="form-label" for="paymentMethod">Moyen</label>
                <select id="paymentMethod" class="form-select" name="paymentMethod">
                    <option value="">Tous</option>
                    {% for value, label in method_choices %}
                        <option value="{{ value }}" {{ filters.paymentMethod == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-6 col-md-3 col-xl-1">
                <label class="form-label" for="paymentDateFrom">Du</label>
                <input id="paymentDateFrom" class="form-control" type="date" name="dateFrom" value="{{ filters.dateFrom }}">
            </div>
            <div class="col-6 col-md-3 col-xl-1">
                <label class="form-label" for="paymentDateTo">Au</label>
                <input id="paymentDateTo" class="form-control" type="date" name="dateTo" value="{{ filters.dateTo }}">
            </div>
            <div class="col-6 col-md-3 col-xl-2">
                <label class="form-label" for="paymentPeriodFrom">Periode du</label>
                <input id="paymentPeriodFrom" class="form-control" type="date" name="periodFrom" value="{{ filters.periodFrom }}">
            </div>
            <div class="col-6 col-md-3 col-xl-2">
                <label class="form-label" for="paymentPeriodTo">Periode au</label>
                <input id="paymentPeriodTo" class="form-control" type="date" name="periodTo" value="{{ filters.periodTo }}">
            </div>
            <div class="col-12 col-xl-2 d-grid">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-funnel me-2"></i>Filtrer
                </button>
            </div>
        </div>
    </div>
</form>

{% include 'interim_payment/_grid.html.twig' with {items: items, pagination: pagination} %}

<div class="modal fade" id="createInterimPaymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            {% include 'interim_payment/_form_modal.html.twig' with {
                form: create_form,
                payment: create_form.vars.data,
                title: 'Nouveau paiement',
                submit_label: 'Enregistrer'
            } %}
        </div>
    </div>
</div>
{% endblock %}
